@model IEnumerable<AdoptameLiberia.Models.Voluntariado.ParticipacionVoluntario>

@{
    ViewBag.Title = "Participación de voluntarios";
}

<h2>Participación de voluntarios</h2>

<p>
    @Html.ActionLink("Nueva participación", "Create", null, new { @class = "btn btn-success" })
</p>

<table class="table">
    <tr>
        <th>Voluntario</th>
        <th>Tarea</th>
        <th>Asistió</th>
        <th>Observaciones</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Voluntario.Nombre @item.Voluntario.Apellido1</td>
            <td>@item.Tarea.Titulo</td>
            <td>@(item.Asistio ? "Sí" : "No")</td>
            <td>@item.Observaciones</td>
        </tr>
    }
</table>