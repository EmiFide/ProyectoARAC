@model AdoptameLiberia.Models.Voluntariado.ParticipacionVoluntario

@{
    ViewBag.Title = "Asignar tarea a voluntario";
}

@section styles{
    <link href="~/Content/estilos/Voluntarios.css" rel="stylesheet" />
}

<div class="vol-shell">
    <div class="vol-form-card">
        <div class="vol-panel-title">Asignar tarea a voluntario</div>
        <div class="vol-panel-subtitle">
            Cuando guardes esta asignación, el voluntario dejará de salir en la lista pendiente.
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="vol-form-grid">
                <div class="vol-group">
                    @Html.LabelFor(m => m.ID_Voluntario, "Voluntario")
                    @Html.DropDownListFor(m => m.ID_Voluntario, (SelectList)ViewBag.ID_Voluntario, "Seleccione voluntario", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.ID_Voluntario, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(m => m.ID_Tarea, "Tarea")
                    @Html.DropDownListFor(m => m.ID_Tarea, (SelectList)ViewBag.ID_Tarea, "Seleccione tarea", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.ID_Tarea, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(m => m.Observaciones)
                    @Html.TextAreaFor(m => m.Observaciones, new { @class = "form-control", rows = 4, placeholder = "Observaciones adicionales..." })
                </div>

                <div class="vol-group full">
                    <div class="vol-info-strip">
                        <strong>Asistencia</strong>
                        <div style="margin-top:10px;">
                            @Html.CheckBoxFor(m => m.Asistio)
                            <span style="margin-left:8px;">Marcar si ya asistió</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="vol-form-actions">
                <button type="submit" class="vol-btn">Guardar asignación</button>
                @Html.ActionLink("Volver", "Index", "Voluntarios", null, new { @class = "vol-btn-outline" })
            </div>
        }
    </div>
</div>