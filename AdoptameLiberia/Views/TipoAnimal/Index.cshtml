@model List<AdoptameLiberia.Models.TiposAnimales.TipoAnimal>

<div class="container mt-4">

    <div class="card shadow-sm border-0 bg-beige">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="font-weight-bold text-vino mb-0">
                    Tipos de Animales
                </h2>

                <a href="@Url.Action("Create", "TipoAnimal")"
                   class="btn btn-vino">
                    + Nuevo Tipo
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover bg-white">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Descripción</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="font-weight-bold">
                                    @item.Nombre_Tipo_Animal
                                </td>

                                <td>
                                    @item.Descripcion
                                </td>

                                <td>
                                    @if (item.Estado)
                                    {
                                        <span class="badge badge-success">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">
                                            Inactivo
                                        </span>
                                    }
                                </td>

                                <td class="text-center">
                                    <a href="@Url.Action("Edit", new { id = item.ID_TipoAnimal })"
                                       class="btn btn-sm btn-outline-secondary mr-2">
                                        Editar
                                    </a>

                                    <a href="@Url.Action("Eliminar", "TipoAnimal",
                                                new { id = item.ID_TipoAnimal })"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('¿Seguro que desea eliminar este tipo de animal?');">
                                        Eliminar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>