@model IEnumerable<AdoptameLiberia.Models.Finanzas.Gasto>

<h2 class="mb-4">💸 Gestión de Gastos</h2>

<div class="mb-3">
    @Html.ActionLink("➕ Nuevo Gasto", "Create", null, new { @class = "btn-crear" })
</div>

<!-- RESUMEN -->
<div class="resumen">
    <div class="box rojo">
        <h6>Total Gastos</h6>
        <h3>₡ @Model.Sum(g => g.Monto ?? 0).ToString("N2")</h3>
    </div>

    <div class="box azul">
        <h6>Registros</h6>
        <h3>@Model.Count()</h3>
    </div>
</div>

<table class="tabla">
    <thead>
        <tr>
            <th>📌 Categoría</th>
            <th>💰 Monto</th>
            <th>📝 Descripción</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(item.Categoria != null ? item.Categoria.Nombre : "-")</td>
                <td>₡ @(item.Monto ?? 0)</td>
                <td>@item.Descripcion</td>
            </tr>
        }
    </tbody>
</table>

<style>
    .btn-crear {
        background: #28a745;
        color: white;
        padding: 10px 15px;
        border-radius: 8px;
        text-decoration: none;
    }

    .resumen {
        display: flex;
        gap: 20px;
        margin-bottom: 25px;
    }

    .box {
        flex: 1;
        padding: 20px;
        border-radius: 12px;
        color: white;
        text-align: center;
    }

    .rojo {
        background: #dc3545;
    }

    .azul {
        background: #007bff;
    }

    .tabla {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 10px;
    }

        .tabla th {
            background: #8b0000;
            color: white;
            padding: 10px;
        }

        .tabla td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        .tabla tr:hover {
            background: #f5f5f5;
        }
</style>