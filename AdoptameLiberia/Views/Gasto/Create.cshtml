@model AdoptameLiberia.Models.Finanzas.Gasto

@{
    ViewBag.Title = "Crear Gasto";
}

<h2>Registrar Gasto</h2>

@using (Html.BeginForm())
{
    <div class="form-group">
        <label>Categoría</label>
        @Html.DropDownList("ID_Categoria", null, "Seleccione una categoría", new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Monto</label>
        @Html.TextBoxFor(m => m.Monto, new { @class = "form-control", type = "number", step = "0.01" })
    </div>

    <div class="form-group">
        <label>Descripción</label>
        @Html.TextBoxFor(m => m.Descripcion, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Fecha</label>
        @Html.TextBoxFor(m => m.Fecha, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
    </div>

    <br />

    <button type="submit" class="btn btn-success">Guardar</button>
}