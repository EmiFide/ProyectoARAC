@model AdoptameLiberia.Models.Voluntariado.Voluntario

@{
    ViewBag.Title = "Crear voluntario";
}

@section styles{
    <link href="~/Content/estilos/Voluntarios.css" rel="stylesheet" />
}

<div class="vol-shell">
    <div class="vol-hero">
        <div class="vol-hero-content">
            <h1>Registrar voluntario</h1>
            <p>
                Completa la información del voluntario para dejarlo listo dentro del módulo
                administrativo de ARAC.
            </p>
        </div>
        <div class="vol-hero-image">
            <img src="~/Content/img/GatoPerro.png" alt="Crear voluntario" />
        </div>
    </div>

    <div class="vol-form-card">
        <div class="vol-panel-title">Formulario de registro</div>
        <div class="vol-panel-subtitle">Ingresa los datos principales del voluntario.</div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="vol-form-grid">
                <div class="vol-group">
                    @Html.LabelFor(model => model.Nombre)
                    @Html.TextBoxFor(model => model.Nombre, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(model => model.Apellido1)
                    @Html.TextBoxFor(model => model.Apellido1, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.Apellido1, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(model => model.Apellido2)
                    @Html.TextBoxFor(model => model.Apellido2, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.Apellido2, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(model => model.Correo)
                    @Html.TextBoxFor(model => model.Correo, new { @class = "form-control", type = "email" })
                    @Html.ValidationMessageFor(model => model.Correo, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(model => model.Telefono)
                    @Html.TextBoxFor(model => model.Telefono, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.Telefono, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(model => model.Estado)
                    <div class="vol-info-strip">
                        <strong>Estado del voluntario:</strong>
                        <div style="margin-top:10px;">
                            @Html.CheckBoxFor(model => model.Estado)
                            <span style="margin-left:8px;">Activo</span>
                        </div>
                    </div>
                    @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(model => model.Disponibilidad)
                    @Html.TextAreaFor(model => model.Disponibilidad, new { @class = "form-control", rows = "4", placeholder = "Ejemplo: fines de semana, tardes, apoyo en eventos..." })
                    @Html.ValidationMessageFor(model => model.Disponibilidad, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(model => model.Habilidades)
                    @Html.TextAreaFor(model => model.Habilidades, new { @class = "form-control", rows = "4", placeholder = "Ejemplo: atención al público, limpieza, apoyo con animales, transporte..." })
                    @Html.ValidationMessageFor(model => model.Habilidades, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="vol-form-actions">
                <button type="submit" class="vol-btn">Guardar voluntario</button>
                @Html.ActionLink("Volver", "Index", null, new { @class = "vol-btn-outline" })
            </div>
        }
    </div>
</div>