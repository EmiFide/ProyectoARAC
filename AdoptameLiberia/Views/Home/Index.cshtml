@{
    ViewBag.Title = "Inicio";
}

@section styles {
    <link href="~/Content/estilos/Index.css?v=2" rel="stylesheet" />
}

<div class="home-shell">
    <section class="home-hero">
        <div class="home-hero-left">
            <div class="home-badge">🐾 ARAC Refugio</div>

            <h1 class="home-hero-title">
                Cuidamos vidas,
                conectamos
                mascotas con un
                nuevo hogar
            </h1>

            <p class="home-hero-text">
                En ARAC Refugio trabajamos por el rescate, la protección y la adopción responsable de perros y gatos.
                Queremos que cada visita al sistema se sienta más humana, clara y cercana.
            </p>

            <div class="home-actions">
                <a href="@Url.Action("Catalogo", "Animal")" class="home-btn-alt">Ver Mascotas Disponibles</a>

                @if (Request.IsAuthenticated)
                {
                <a href="@Url.Action("Index", "Comunidad")" class="home-btn-alt">Ir a Comunidad</a>
                }
            </div>

            <div class="home-mini-stats">
                <div class="home-mini-stat">
                    <strong>+15</strong>
                    <span>Mascotas registradas</span>
                </div>
                <div class="home-mini-stat">
                    <strong>+12</strong>
                    <span>Tipos de donación</span>
                </div>
                <div class="home-mini-stat">
                    <strong>24/7</strong>
                    <span>Apoyo y gestión</span>
                </div>
            </div>
        </div>

        <div class="home-hero-right">
            <img src="~/Content/img/Refugio.png" alt="Mascotas ARAC" />
            <div class="home-hero-float">
                <h4>Adopta, ayuda y transforma</h4>
                <p>
                    Cada acción cuenta: adoptar, donar, participar en campañas o compartir una historia puede cambiar la vida de un animal.
                </p>
            </div>
        </div>
    </section>

    <section class="home-split">
        <div class="home-photo-panel">
            <div class="home-section-kicker">Nuestro compromiso</div>
            <h2>Un espacio más claro, cálido y útil</h2>
            <p>
                Este sistema fue pensado para que cualquier persona pueda encontrar rápido lo que
                necesita: adoptar, apoyar al refugio, revisar campañas o formar parte de la comunidad.
            </p>
            <img src="~/Content/img/PerroyGato.png" alt="Perro y gato" />
        </div>

        <div class="home-info-panel">

            <div class="home-list-item">
                <span>
                    <svg width="28" height="28" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#67171c" stroke-width="2" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M11.9932 5.13581C9.9938 2.7984 6.65975 2.16964 4.15469 4.31001C1.64964 6.45038 1.29697 10.029 3.2642 12.5604C4.89982 14.6651 9.84977 19.1041 11.4721 20.5408C11.6536 20.7016 11.7444 20.7819 11.8502 20.8135C11.9426 20.8411 12.0437 20.8411 12.1361 20.8135C12.2419 20.7819 12.3327 20.7016 12.5142 20.5408C14.1365 19.1041 19.0865 14.6651 20.7221 12.5604C22.6893 10.029 22.3797 6.42787 19.8316 4.31001C17.2835 2.19216 13.9925 2.7984 11.9932 5.13581Z" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div>
                    <strong>Adopción responsable</strong>
                    <p>Conecta a las mascotas con familias que sí puedan darles estabilidad y cariño.</p>
                </div>
            </div>

            <div class="home-list-item">
                <span>
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 11V19C4 20.1046 4.89543 21 6 21H18C19.1046 21 20 20.1046 20 19V11" stroke="#67171c" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M6 4.5C6 3.11929 7.11929 2 8.5 2V2C10.433 2 12 3.567 12 5.5V7H8.5C7.11929 7 6 5.88071 6 4.5V4.5Z" stroke="#67171c" stroke-linejoin="round" />
                        <path d="M18 4.5C18 3.11929 16.8807 2 15.5 2V2C13.567 2 12 3.567 12 5.5V7H15.5C16.8807 7 18 5.88071 18 4.5V4.5Z" stroke="#67171c" stroke-linejoin="round" />
                        <path d="M3 7H21V11H3V7Z" stroke="#67171c" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M12 11V21" stroke="#67171c" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div>
                    <strong>Apoyo real al refugio</strong>
                    <p>Desde insumos hasta medicina, cada ayuda suma al bienestar diario de los animales.</p>
                </div>
            </div>

            <div class="home-list-item">
                <span>
                    <svg width="30" height="30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" stroke-width="3" stroke="#67171c" fill="none">
                        <path d="M11.51,20.66h8.38a0,0,0,0,1,0,0V37.21a0,0,0,0,1,0,0H11.51a2,2,0,0,1-2-2V22.66A2,2,0,0,1,11.51,20.66Z" />
                        <path d="M19.89,37.21V20.66s4.37.1,11.64,0,15.78-4.7,21.31-9.4a1,1,0,0,1,1.65.75V45.9a1,1,0,0,1-1.61.79c-3.56-2.8-12.42-9.06-21-9.32C26.86,37.21,22.8,37.21,19.89,37.21Z" />
                        <path d="M23.29,53h-4.8a2,2,0,0,1-2-2l-1-13.78h8.8l1,13.78A2,2,0,0,1,23.29,53Z" />
                    </svg>
                </span>
                <div>
                    <strong>Comunidad activa</strong>
                    <p>Campañas, comunidad y donaciones en un solo lugar, con navegación más clara.</p>
                </div>
            </div>
        </div>
    </section>


    <section class="home-grid-3">
        <article class="home-card">
            <div class="home-card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="#67171c"><path d="M21 6h-2l-1.27-1.27A2.49 2.49 0 0 0 16 4h-2.5A2.64 2.64 0 0 0 11 2v6.36a4.38 4.38 0 0 0 1.13 2.72 6.57 6.57 0 0 0 4.13 1.82l3.45-1.38a3 3 0 0 0 1.73-1.84L22 8.15a1.06 1.06 0 0 0 0-.31V7a1 1 0 0 0-1-1zm-5 2a1 1 0 1 1 1-1 1 1 0 0 1-1 1z" fill="#67171c" /><path d="M11.38 11.74A5.24 5.24 0 0 1 10.07 9H6a1.88 1.88 0 0 1-2-2 1 1 0 0 0-2 0 4.69 4.69 0 0 0 .48 2A3.58 3.58 0 0 0 4 10.53V22h3v-5h6v5h3v-8.13a7.35 7.35 0 0 1-4.62-2.13z" fill="#67171c" /></svg>
            </div>
            <h3>Adopta con confianza</h3>
            <p>
                Explora mascotas disponibles y conoce perfiles más claros para tomar una decisión responsable.
            </p>
            <a href="@Url.Action("Catalogo", "Animal")">Ir a Adopta</a>
        </article>

        <article class="home-card">
            <div class="home-card-icon">
                <svg width="30" height="30" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M34 16C34 21.5228 29.5228 26 24 26C18.4772 26 14 21.5228 14 16C14 10.4772 18.4772 6 24 6C29.5228 6 34 10.4772 34 16ZM32 16C32 20.4183 28.4183 24 24 24C19.5817 24 16 20.4183 16 16C16 11.5817 19.5817 8 24 8C28.4183 8 32 11.5817 32 16Z" fill="#67171c" />
