 36.5742 16.5384 37.0147 16 37.0147C15.4616 37.0147 15 36.5742 15 36C15 35.4258 15.4616 34.9853 16 34.9853C16.5384 34.9853 17 35.4258 17 36Z" fill="#67171c" />
                </svg>
            </div>
            <h3>Campañas activas</h3>
            <p>
                Consulta campañas de castración, revisa cupos y registra a tu mascota de una forma sencilla.
            </p>
            <a href="@Url.Action("Index", "Campanias")">Ver campañas</a>
        </article>

        <article class="home-card">
            <div class="home-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 11V19C4 20.1046 4.89543 21 6 21H18C19.1046 21 20 20.1046 20 19V11" stroke="#67171c" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M6 4.5C6 3.11929 7.11929 2 8.5 2V2C10.433 2 12 3.567 12 5.5V7H8.5C7.11929 7 6 5.88071 6 4.5V4.5Z" stroke="#67171c" stroke-linejoin="round" />
                    <path d="M18 4.5C18 3.11929 16.8807 2 15.5 2V2C13.567 2 12 3.567 12 5.5V7H15.5C16.8807 7 18 5.88071 18 4.5V4.5Z" stroke="#67171c" stroke-linejoin="round" />
                    <path d="M3 7H21V11H3V7Z" stroke="#67171c" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M12 11V21" stroke="#67171c" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <h3>Apoya al refugio</h3>
            <p>
                Las donaciones ayudan con alimento, medicina, higiene, transporte y cuidado diario.
            </p>
            <a href="@Url.Action("Index", "Donaciones")">Ir a donaciones</a>
        </article>
    </section>

    <section class="home-grid-3" style="margin-top: 24px;">
        <article class="home-card">
            <div class="home-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 20.9999C16.9706 20.9999 21 16.9705 21 11.9999C21 7.02938 16.9706 2.99994 12 2.99994C7.02944 2.99994 3 7.02938 3 11.9999C3 13.4876 3.36093 14.8909 4 16.1271L3 20.9999L7.8728 19.9999C9.10904 20.639 10.5124 20.9999 12 20.9999Z" stroke="#67171c" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <h3>Comunidad ARAC</h3>
            <p>
                Comparte publicaciones, experiencias, consejos y comentarios con otras personas que apoyan al refugio.
            </p>

            @if (Request.IsAuthenticated)
            {
            <a href="@Url.Action("Index", "Comunidad")">Entrar a comunidad</a>
            }
            else
            {
            <a href="@Url.Action("Login", "Account")">Inicia sesión para entrar</a>
            }
        </article>

        <article class="home-card">
            <div class="home-card-icon">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M4.41377 17.859C4.77159 17.6504 5.23081 17.7713 5.43947 18.1291C6.26633 19.5471 7.53043 20.6193 9.0893 21.3151C9.46755 21.4839 9.63733 21.9274 9.46851 22.3057C9.29969 22.6839 8.85621 22.8537 8.47796 22.6849C6.66645 21.8764 5.14664 20.6046 4.14369 18.8847C3.93503 18.5269 4.05595 18.0677 4.41377 17.859Z" fill="#67171c" />
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M18.9058 3.92194C17.8919 2.88646 16.4459 2.50452 15.0303 2.9073C14.6319 3.02066 14.2171 2.78959 14.1037 2.39119C13.9904 1.99279 14.2214 1.57792 14.6198 1.46456C16.558 0.913072 18.5745 1.43959 19.9775 2.8725C20.2673 3.16846 20.2623 3.64331 19.9664 3.9331C19.6704 4.2229 19.1956 4.2179 18.9058 3.92194Z" fill="#67171c" />
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.1901 3.30839C10.9761 2.94131 10.3523 2.7187 9.71858 3.08085C9.08722 3.44168 8.97618 4.07772 9.18651 4.4384L11.7122 8.76952C11.9208 9.12734 11.7999 9.58656 11.4421 9.79522C11.0843 10.0039 10.6251 9.88296 10.4164 9.52514L7.04885 3.75032C6.83479 3.38324 6.21098 3.16063 5.57731 3.52278C4.94595 3.88361 4.83491 4.51965 5.04525 4.88033L8.83373 11.377C9.04239 11.7348 8.92147 12.1941 8.56365 12.4027C8.20583 12.6114 7.74661 12.4905 7.53795 12.1326L5.85418 9.24522C5.64012 8.87814 5.01631 8.65553 4.38264 9.01768C3.75128 9.37851 3.64024 10.0145 3.85058 10.3752L7.63906 16.8719C9.248 19.631 13.2184 20.5264 16.5853 18.6021C19.95 16.6792 21.146 12.8377 19.5408 10.085L17.0152 5.75387C16.8011 5.38679 16.1773 5.16418 15.5436 5.52633C14.9123 5.88716 14.8012 6.5232 15.0116 6.88389L16.6953 9.7713C16.7961 9.94411 16.8237 10.15 16.7719 10.3432C16.7201 10.5365 16.5933 10.701 16.4196 10.8003C14.8771 11.6818 14.4044 13.3863 15.0797 14.5443C15.2884 14.9022 15.1675 15.3614 14.8096 15.57C14.4518 15.7787 13.9926 15.6578 13.7839 15.3C12.8712 13.7348 13.24 11.8501 14.4189 10.5181C14.7485 10.1457 14.8613 9.60396 14.6108 9.17438L11.1901 3.30839Z" fill="#67171c" />
                </svg>
            </div>
            <h3>Voluntariado</h3>
            <p>
                Forma parte de las actividades del refugio y apoya en eventos, cuidado y acompañamiento.
            </p>
            <a href="@Url.Action("Create", "SolicitudesVoluntariado")">Ser voluntario</a>
        </article>

        <article class="home-card">
            <div class="home-card-icon">
                <svg width="30" height="30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" stroke-width="3" stroke="#67171c" fill="none"><path d="M11.51,20.66h8.38a0,0,0,0,1,0,0V37.21a0,0,0,0,1,0,0H11.51a2,2,0,0,1-2-2V22.66A2,2,0,0,1,11.51,20.66Z" /><path d="M19.89,37.21V20.66s4.37.1,11.64,0,15.78-4.7,21.31-9.4a1,1,0,0,1,1.65.75V45.9a1,1,0,0,1-1.61.79c-3.56-2.8-12.42-9.06-21-9.32C26.86,37.21,22.8,37.21,19.89,37.21Z" /><path d="M23.29,53h-4.8a2,2,0,0,1-2-2l-1-13.78h8.8l1,13.78A2,2,0,0,1,23.29,53Z" /></svg>
            </div>
            <h3>Participa más fácil</h3>
            <p>
                El sistema reúne adopciones, campañas, comunidad, donaciones y apoyo voluntario en un solo lugar.
            </p>
            <a href="@Url.Action("Index", "Home")">Seguir explorando</a>
        </article>
    </section>
</div>