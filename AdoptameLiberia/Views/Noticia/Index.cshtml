@model IEnumerable<AdoptameLiberia.Models.Noticias.Noticia>

@{
    ViewBag.Title = "Noticias";
}

<h2 class="mb-4">📰 Noticias del Refugio</h2>

@if (Request.IsAuthenticated && User.IsInRole("Administrador"))
{
    <p>
        @Html.ActionLink("➕ Crear Noticia", "Create", null, new { @class = "btn btn-primary mb-3" })
    </p>
}

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm rounded h-100 noticia-card">

                <div class="card-body d-flex flex-column">

                    <!-- TÍTULO -->
                    <h5 class="card-title fw-bold">
                        @item.Titulo
                    </h5>

                    <!-- FECHA -->
                    <p class="text-muted" style="font-size: 13px;">
                        📅 @(item.Fecha_Publicacion.HasValue
                            ? item.Fecha_Publicacion.Value.ToString("dd/MM/yyyy HH:mm")
                            : "")
                    </p>

                    <!-- CONTENIDO -->
                    <p class="card-text">
                        @item.Contenido
                    </p>

                    <hr />

                    <!-- FOOTER -->
                    <div class="d-flex justify-content-between align-items-center mt-auto">

                        <!-- LIKES -->
                        <span class="fw-bold text-primary">
                            👍 @item.Likes
                        </span>

                        <!-- BOTÓN LIKE -->
                        @using (Html.BeginForm("Like", "Noticia", new { id = item.ID_Noticia }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken() <!-- 🔥 SOLUCIÓN AL ERROR -->

                            <button type="submit" class="btn btn-outline-primary btn-sm">
                                👍 Me gusta
                            </button>
                        }

                    </div>

                </div>

            </div>
        </div>
    }

</div>

<!-- ESTILO EXTRA (UX PRO) -->
<style>
    .noticia-card {
        transition: all 0.2s ease-in-out;
    }

        .noticia-card:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
</style>