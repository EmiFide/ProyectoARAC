@model AdoptameLiberia.Models.Noticias.Noticia

@{
    ViewBag.Title = "Crear Noticia";
}

<div class="contenedor">

    <div class="card-post">

        <h2>📰 Crear Noticia</h2>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <!-- TÍTULO -->
            <div class="form-group">
                <label>Título</label>
                @Html.TextBoxFor(m => m.Titulo, new { @class = "input", placeholder = "Ej: Rescate de perritos 🐾" })
            </div>

            <!-- CONTENIDO -->
            <div class="form-group">
                <label>Contenido</label>
                @Html.TextAreaFor(m => m.Contenido, new { @class = "textarea", rows = 5, placeholder = "Escribe la historia..." })
            </div>

            <!-- ESTADO -->
            <div class="form-check">
                @Html.CheckBoxFor(m => m.Estado)
                <label>Publicar ahora</label>
            </div>

            <!-- BOTÓN -->
            <div class="text-center mt-3">
                <button type="submit" class="btn-publicar">🚀 Publicar</button>
            </div>
        }

    </div>

</div>

<style>
    /* CONTENEDOR GENERAL */
    .contenedor {
        display: flex;
        justify-content: center;
        margin-top: 40px;
    }

    /* CARD */
    .card-post {
        width: 600px;
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    /* INPUTS */
    .input, .textarea {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ccc;
        margin-top: 5px;
        margin-bottom: 15px;
    }

        .input:focus, .textarea:focus {
            border-color: #8b0000;
            outline: none;
        }

    /* BOTÓN */
    .btn-publicar {
        background: #8b0000;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        font-weight: bold;
    }

        .btn-publicar:hover {
            background: #a30000;
        }
</style>