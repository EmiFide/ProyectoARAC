@model AdoptameLiberia.Models.Noticias.Noticia

<h2>Crear Noticia</h2>

@using (Html.BeginForm())
{
    <div class="form-group">
        @Html.LabelFor(m => m.Titulo)
        @Html.TextBoxFor(m => m.Titulo, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Contenido)
        @Html.TextAreaFor(m => m.Contenido, new { @class = "form-control" })
    </div>

    <button class="btn btn-success">Publicar</button>
}