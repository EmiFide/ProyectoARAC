@model AdoptameLiberia.Models.Campanias.InscripcionCastracion

@{
    ViewBag.Title = "Registrar Mascota";
}

<link href="~/Content/estilos/Campanias.css" rel="stylesheet" />

<div class="page-shell">
    <div class="hero-campania">
        <div class="hero-campania-content">
            <h1>Registrar mascota en campaña</h1>
            <p>Completa este formulario para inscribir a tu mascota en la campaña seleccionada.</p>
        </div>
    </div>

    <div class="info-layout">
        <div class="form-card">
            @using (Html.BeginForm("Inscribir", "Campanias", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.CampaniaCastracionId)

                <div class="form-grid">
                    <div class="form-group-campania">
                        <label>Campaña</label>
                        <input type="text" value="@ViewBag.CampaniaNombre" readonly />
                    </div>

                    <div class="form-group-campania">
                        <label>Fecha</label>
                        <input type="text" value="@(((DateTime)ViewBag.CampaniaFecha).ToShortDateString())" readonly />
                    </div>

                    <div class="form-group-campania full">
                        <label>Lugar</label>
                        <input type="text" value="@ViewBag.CampaniaLugar" readonly />
                    </div>

                    <div class="form-group-campania full">
                        <label>Seleccione la mascota</label>
                        @Html.DropDownListFor(
                            m => m.AnimalId,
                            (SelectList)ViewBag.AnimalId,
                            "Seleccione una mascota",
                            new { @class = "" }
                        )
                    </div>
                </div>

                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                <div class="page-actions">
                    <button type="submit" class="btn-campania-success">Registrar mascota</button>
                    <a href="@Url.Action("Index", "Campanias")" class="btn-campania-outline">Volver</a>
                </div>
            }
        </div>

        <div class="side-image">
            <img src="~/Content/img/Gato.png" alt="Mascotas" />
        </div>
    </div>
</div>