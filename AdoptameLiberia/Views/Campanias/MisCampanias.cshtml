@model IEnumerable<AdoptameLiberia.Models.Campanias.InscripcionCastracion>

@{
    ViewBag.Title = "Mis registros en campañas";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Campanias.InscripcionCastracion>();
}

<link href="~/Content/estilos/Campanias.css" rel="stylesheet" />

<div class="page-shell">
    <div class="hero-campania">
        <div class="hero-campania-content">
            <h1>Mis registros en campañas</h1>
            <p>Aquí puedes revisar las mascotas que has inscrito y ver el estado de cada una.</p>
        </div>
    </div>

    <div class="section-card">
        <div class="action-buttons">
            <a href="@Url.Action("Index", "Campanias")" class="btn-campania-outline">Volver a campañas</a>
        </div>
    </div>

    <div class="section-card">
        <div class="table-shell">
            <table class="table-campania">
                <thead>
                    <tr>
                        <th>Campaña</th>
                        <th>Fecha</th>
                        <th>Lugar</th>
                        <th>Mascota</th>
                        <th>Veterinario</th>
                        <th>Resultado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (lista.Any())
                    {
                        foreach (var item in lista)
                        {
                            <tr>
                                <td><strong>@(item.Campania != null ? item.Campania.Nombre : "")</strong></td>
                                <td>@(item.Campania != null ? item.Campania.Fecha.ToShortDateString() : "")</td>
                                <td>@(item.Campania != null ? item.Campania.Lugar : "")</td>
                                <td>@(item.Animal != null ? item.Animal.Nombre_Animal : "")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.VeterinarioAsignado))
                                    {
                                        <span class="badge-ok">@item.VeterinarioAsignado</span>
                                    }
                                    else
                                    {
                                        <span class="badge-pendiente">Pendiente</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.Resultado))
                                    {
                                        <span class="badge-ok">@item.Resultado</span>
                                    }
                                    else
                                    {
                                        <span class="badge-pendiente">Sin resultado</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    Aún no tienes mascotas registradas en campañas.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>