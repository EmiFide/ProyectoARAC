@model IEnumerable<AdoptameLiberia.Models.Campanias.CampaniaCastracion>

@{
    ViewBag.Title = "Campañas de Castración";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Campanias.CampaniaCastracion>();
    var cuposMap = ViewBag.CuposDisponibles as Dictionary<int, int> ?? new Dictionary<int, int>();
    var totalCampanias = ViewBag.TotalCampanias != null ? (int)ViewBag.TotalCampanias : lista.Count;
    var campaniasDisponibles = ViewBag.CampaniasDisponibles != null ? (int)ViewBag.CampaniasDisponibles : 0;
}

<link href="~/Content/estilos/Campanias.css" rel="stylesheet" />

<div class="campanias-container">

    <div class="hero-campania">
        <div class="hero-campania-content">
            <h1>Campañas de Castración</h1>
            <p>Protege a tus mascotas y contribuye al bienestar animal.</p>
        </div>
    </div>
    <div class="pet-cards">
        <div class="pet-card pet-card-overlay">
            <img src="~/Content/img/MitadPerro.png" alt="Canino" />
            <div class="pet-card-text"><span>BIENESTAR CANINO</span></div>
        </div>
        <div class="pet-card pet-card-overlay">
            <img src="~/Content/img/MitadGato.png" alt="Felino" />
            <div class="pet-card-text"><span>BIENESTAR FELINO</span></div>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-card">
            <h4>Total de campañas</h4>
            <p>@totalCampanias</p>
        </div>
        <div class="stat-card">
            <h4>Disponibles</h4>
            <p>@campaniasDisponibles</p>
        </div>
    </div>

    <div class="section-card">
        <div class="section-header">
            <h3>Listado de Campañas</h3>
            <div class="action-buttons">
                @if (User.IsInRole("Administrador"))
                {
                <a href="@Url.Action("Create", "Campanias")" class="btn-campania">
                    <i class="fas fa-plus"></i> Nueva Campaña
                </a>
                }
                else
                {
                <a href="@Url.Action("MisCampanias", "Campanias")" class="btn-campania-alt">
                    Mis Registros
                </a>
                }
            </div>
        </div>

        <div class="table-shell">
            <table class="table-campania">
                <thead>
                    <tr>
                        <th>Campaña</th>
                        <th>Fecha</th>
                        <th>Ubicación</th>
                        <th class="text-center">Cupos</th>
                        <th class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (lista.Any())
                    {
                        foreach (var item in lista)
                        {
                            var disponibles = cuposMap.ContainsKey(item.Id) ? cuposMap[item.Id] : item.Cupos;
                    <tr>
                        <td><strong>@item.Nombre</strong></td>
                        <td>@item.Fecha.ToShortDateString()</td>
                        <td><i class="fas fa-map-marker-alt"></i> @item.Lugar</td>
                        <td class="text-center"><span class="badge-cupos">@disponibles</span></td>
                        <td class="text-right">
                            @if (User.IsInRole("Administrador"))
                                    {
                            <a href="@Url.Action("VerInscripciones", "Campanias", new { id = item.Id })" class="btn-campania-info">Ver</a>
                                    }
                                    else
                                    {
                            <a href="@Url.Action("Inscribir", "Campanias", new { id = item.Id })" class="btn-campania-success">Inscribir</a>
                                    }
                        </td>
                    </tr>
                        }
                    }
                    else
                    {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">No hay campañas activas en este momento.</div>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>