@model AdoptameLiberia.Models.Campanias.InscripcionCastracion

@{
    ViewBag.Title = "Registrar Resultado";
}

<div class="container mt-4">
    <h2>Registrar resultado</h2>

    @using (Html.BeginForm("RegistrarResultado", "Campanias", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(m => m.Id)
        @Html.HiddenFor(m => m.CampaniaCastracionId)
        @Html.HiddenFor(m => m.AnimalId)
        @Html.HiddenFor(m => m.VeterinarioAsignado)

        <div class="card shadow p-4">
            <div class="form-group mb-3">
                <label class="form-label">Mascota</label>
                <input type="text" class="form-control" value="@(Model.Animal != null ? Model.Animal.Nombre_Animal : "Sin nombre")" readonly />
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Veterinario asignado</label>
                <input type="text" class="form-control" value="@Model.VeterinarioAsignado" readonly />
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Resultado del procedimiento</label>
                @Html.TextAreaFor(m => m.Resultado, new { @class = "form-control", rows = "5", placeholder = "Escriba aquí el resultado del procedimiento realizado" })
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">Guardar resultado</button>
                <a href="@Url.Action("VerInscripciones", "Campanias", new { id = Model.CampaniaCastracionId })" class="btn btn-secondary">Volver</a>
            </div>
        </div>
    }
</div>