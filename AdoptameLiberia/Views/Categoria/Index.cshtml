@model IEnumerable<AdoptameLiberia.Models.Finanzas.CategoriaFinanciera>

@{
    ViewBag.Title = "Categorías Financieras";
}

<h2 class="mb-4">💰 Categorías Financieras</h2>

<div class="mb-3">
    @Html.ActionLink("➕ Nueva Categoría", "Create", null, new { @class = "btn-crear" })
</div>

<!-- RESUMEN -->
<div class="resumen">

    <div class="box azul">
        <h6>Total</h6>
        <h3>@Model.Count()</h3>
    </div>

    <div class="box verde">
        <h6>Ingresos</h6>
        <h3>@Model.Count(c => c.Tipo == "Ingreso")</h3>
    </div>

    <div class="box rojo">
        <h6>Gastos</h6>
        <h3>@Model.Count(c => c.Tipo == "Gasto")</h3>
    </div>

</div>

<!-- TABLA -->
<table class="tabla">
    <thead>
        <tr>
            <th>📌 Nombre</th>
            <th>💱 Tipo</th>
            <th>⚙ Estado</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <!-- NOMBRE -->
                <td>
                    <b>@item.Nombre</b>
                </td>

                <!-- TIPO -->
                <td>
                    @if (item.Tipo == "Ingreso")
                    {
                        <span class="tag verde">Ingreso</span>
                    }
                    else
                    {
                        <span class="tag rojo">Gasto</span>
                    }
                </td>

                <!-- ESTADO -->
                <td>
                    @if (item.Estado == true)
                    {
                        <span class="tag azul">Activo</span>
                    }
                    else
                    {
                        <span class="tag gris">Inactivo</span>
                    }
                </td>

            </tr>
        }
    </tbody>
</table>

<!-- ESTILOS -->
<style>
    /* BOTÓN */
    .btn-crear {
        background: #28a745;
        color: white;
        padding: 10px 15px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

        .btn-crear:hover {
            background: #218838;
            color: white;
        }

    /* RESUMEN */
    .resumen {
        display: flex;
        gap: 20px;
        margin-bottom: 25px;
    }

    .box {
        flex: 1;
        padding: 20px;
        border-radius: 12px;
        color: white;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .azul {
        background: #007bff;
    }

    .verde {
        background: #28a745;
    }

    .rojo {
        background: #dc3545;
    }

    .gris {
        background: #6c757d;
    }

    /* TABLA */
    .tabla {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 10px;
        overflow: hidden;
    }

        .tabla th {
            background: #8b0000;
            color: white;
            padding: 12px;
            text-align: left;
        }

        .tabla td {
            padding: 12px;
            border-bottom: 1px solid #eee;
        }

        .tabla tr:hover {
            background: #f5f5f5;
            transition: 0.2s;
        }

    /* TAGS */
    .tag {
        padding: 6px 12px;
        border-radius: 12px;
        color: white;
        font-size: 12px;
        font-weight: bold;
    }
</style>