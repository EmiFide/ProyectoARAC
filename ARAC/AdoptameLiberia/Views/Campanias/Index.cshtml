@model IEnumerable<AdoptameLiberia.Models.Campanias.CampaniaCastracion>

@{
    ViewBag.Title = "Campañas de Castración";
}

<div class="container mt-4">
    <h2>Campañas de Castración</h2>

    @if (User.IsInRole("Administrador"))
    {
        <p>
            @Html.ActionLink("Nueva Campaña", "Create", "Campanias", null, new { @class = "btn btn-primary" })
        </p>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Fecha</th>
                <th>Lugar</th>
                <th>Cupos</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Fecha.ToShortDateString()</td>
                    <td>@item.Lugar</td>
                    <td>@item.Cupos</td>
                    <td>
                        @if (User.IsInRole("Administrador"))
                        {
                            <a href="@Url.Action("VerInscripciones", "Campanias", new { id = item.Id })" class="btn btn-primary btn-sm">Ver inscripciones</a>
                        }
                        else
                        {
                            <a href="@Url.Action("Inscribir", "Campanias", new { id = item.Id })" class="btn btn-success btn-sm">Registrar mascota</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!User.IsInRole("Administrador"))
    {
        <p>
            <a href="@Url.Action("MisCampanias", "Campanias")" class="btn btn-info">Ver mis registros</a>
        </p>
    }
</div>