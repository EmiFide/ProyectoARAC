@model IEnumerable<AdoptameLiberia.Models.Campanias.InscripcionCastracion>

@{
    ViewBag.Title = "Mis Registros en Campañas";
}

<div class="container mt-4">
    <h2>Mis registros en campañas</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <p>
        <a href="@Url.Action("Index", "Campanias")" class="btn btn-secondary">Volver a campañas</a>
    </p>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Campaña</th>
                <th>Fecha</th>
                <th>Lugar</th>
                <th>Mascota</th>
                <th>Veterinario</th>
                <th>Resultado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.Campania != null ? item.Campania.Nombre : "")</td>
                    <td>@(item.Campania != null ? item.Campania.Fecha.ToShortDateString() : "")</td>
                    <td>@(item.Campania != null ? item.Campania.Lugar : "")</td>
                    <td>@(item.Animal != null ? item.Animal.Nombre_Animal : "")</td>
                    <td>@item.VeterinarioAsignado</td>
                    <td>@item.Resultado</td>
                </tr>
            }
        </tbody>
    </table>
</div>