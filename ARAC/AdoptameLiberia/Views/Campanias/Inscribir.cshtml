@model AdoptameLiberia.Models.Campanias.InscripcionCastracion

@{
    ViewBag.Title = "Registrar Mascota en Campaña";
}

<div class="container mt-4">
    <h2>Registrar mascota en campaña</h2>

    <div class="card shadow p-4">
        <div class="mb-3">
            <label class="form-label"><strong>Campaña</strong></label>
            <input type="text" class="form-control" value="@ViewBag.CampaniaNombre" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label"><strong>Fecha</strong></label>
            <input type="text" class="form-control" value="@(((DateTime)ViewBag.CampaniaFecha).ToShortDateString())" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label"><strong>Lugar</strong></label>
            <input type="text" class="form-control" value="@ViewBag.CampaniaLugar" readonly />
        </div>

        @using (Html.BeginForm("Inscribir", "Campanias", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            @Html.HiddenFor(m => m.CampaniaCastracionId)

            <div class="form-group mb-3">
                <label class="form-label">Seleccione la mascota</label>
                @Html.DropDownListFor(m => m.AnimalId, (SelectList)ViewBag.AnimalId, "Seleccione una mascota", new { @class = "form-control" })
            </div>

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mt-3">
                <button type="submit" class="btn btn-success">Registrar mascota</button>
                <a href="@Url.Action("Index", "Campanias")" class="btn btn-secondary">Volver</a>
            </div>
        }
    </div>
</div>