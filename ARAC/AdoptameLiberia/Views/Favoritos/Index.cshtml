@model IEnumerable<AdoptameLiberia.Models.Mascotas.AnimalModel>

@{
    ViewBag.Title = "Mis favoritos";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Mascotas.AnimalModel>();
}

<link href="~/Content/estilos/Mascotas.css" rel="stylesheet" />

<div class="mascota-shell">
    <div class="mascota-hero">
        <div class="mascota-hero-content">
            <h1>Mis favoritos</h1>
            <p>Aquí puedes consultar rápidamente las mascotas que guardaste.</p>
        </div>
    </div>

    <div class="mascota-form-card">
        <div class="mascota-actions" style="margin-top:0; margin-bottom:20px; justify-content:space-between;">
            <a href="@Url.Action("Catalogo", "Animal")" class="mascota-btn-outline">Volver al catálogo</a>
        </div>

        @if (lista.Any())
        {
            <div class="favoritos-grid">
                @foreach (var item in lista)
                {
                    <div class="favorito-card">
                        <div class="favorito-card-header">
                            <div>
                                <span class="favorito-badge">@(!string.IsNullOrWhiteSpace(item.NombreTipo) ? item.NombreTipo : "Mascota")</span>
                                <h3>@item.Nombre_Animal</h3>
                            </div>

                            @{
                                using (Html.BeginForm("Toggle", "Favoritos", FormMethod.Post, new { @class = "favorito-form" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("idAnimal", item.ID_Animal)
                                    @Html.Hidden("returnUrl", Request.RawUrl)
                                    <button type="submit" class="favorito-toggle-btn activo" title="Quitar de favoritos">❤</button>
                                }
                            }
                        </div>

                        <div class="favorito-card-body">
                            <p><strong>Raza:</strong> @(string.IsNullOrWhiteSpace(item.NombreRaza) ? "No registrada" : item.NombreRaza)</p>
                            <p><strong>Edad:</strong> @(item.Edad.HasValue ? item.Edad + " años" : "No registrada")</p>
                            <p><strong>Sexo:</strong> @item.Sexo</p>
                            <p><strong>Tamaño:</strong> @item.Tamano</p>
                            <p><strong>Peso:</strong> @(item.Peso.HasValue ? item.Peso + " kg" : "No registrado")</p>
                            <p><strong>Estado:</strong> @item.Estado</p>
                            <p><strong>Descripción:</strong> @item.Descripcion</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-light border" role="alert">
                Todavía no has guardado mascotas en favoritos.
            </div>
        }
    </div>
</div>