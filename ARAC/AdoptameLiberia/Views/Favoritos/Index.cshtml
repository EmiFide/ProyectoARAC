@model IEnumerable<AdoptameLiberia.Models.Educativo.ContenidoFavorito>
@{
    ViewBag.Title = "Mis favoritos";
}

<h2>Mis recursos favoritos</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No tienes recursos guardados en favoritos.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Título</th>
                <th>Tipo</th>
                <th>Tema</th>
                <th>Fecha agregado</th>
                <th style="width:220px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ContenidoEducativo.Titulo</td>
                    <td>@item.ContenidoEducativo.TipoContenido</td>
                    <td>@item.ContenidoEducativo.Tema</td>
                    <td>@item.FechaAgregado.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @Html.ActionLink("Ver", "Detalle", "Educativo", new { id = item.IdContenidoEducativo }, new { @class = "btn btn-info btn-xs" })

                        @using (Html.BeginForm("Eliminar", "Favoritos", FormMethod.Post, new { style = "display:inline-block;" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("idContenidoEducativo", item.IdContenidoEducativo)
                            <button type="submit" class="btn btn-danger btn-xs">Quitar</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}