@model IEnumerable<AdoptameLiberia.Models.Campanias.CampaniaCastracion>

@{
    ViewBag.Title = "Campañas";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Campanias.CampaniaCastracion>();
    var cuposMap = ViewBag.CuposDisponibles as Dictionary<int, int> ?? new Dictionary<int, int>();
    var totalCampanias = ViewBag.TotalCampanias != null ? (int)ViewBag.TotalCampanias : lista.Count;
    var campaniasDisponibles = ViewBag.CampaniasDisponibles != null ? (int)ViewBag.CampaniasDisponibles : 0;
}

<link href="~/Content/estilos/Campanias.css" rel="stylesheet" />

<div class="camp-shell">
    <section class="camp-hero">
        <div class="camp-hero-copy">
            <span class="section-kicker">Castración responsable</span>
            <h1>Campañas con mejor orden, presencia y navegación</h1>
            <p>Consulta fechas, lugares, cupos disponibles y registra mascotas con una interfaz más clara.</p>
        </div>
        <div class="camp-hero-image">
            <img src="~/Content/img/MitadPerro.png" alt="Campañas" />
        </div>
    </section>

    <section class="camp-stats">
        <div class="camp-stat-card">
            <strong>@totalCampanias</strong>
            <span>Total de campañas</span>
        </div>
        <div class="camp-stat-card">
            <strong>@campaniasDisponibles</strong>
            <span>Disponibles</span>
        </div>
        <div class="camp-stat-card">
            <strong>@lista.Count</strong>
            <span>Mostradas</span>
        </div>
    </section>

    <section class="camp-actions-panel">
        @if (User.IsInRole("Administrador"))
        {
            <a href="@Url.Action("Create", "Campanias")" class="camp-btn-main">Nueva campaña</a>
        }
        else
        {
            <a href="@Url.Action("MisCampanias", "Campanias")" class="camp-btn-main">Ver mis registros</a>
        }
    </section>

    <section class="camp-table-panel">
        <div class="camp-table-head">
            <h2>Próximas campañas</h2>
            <p>Listado principal de jornadas disponibles en el sistema.</p>
        </div>

        <div class="camp-table-wrap">
            <table class="table-campania">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Fecha</th>
                        <th>Lugar</th>
                        <th>Cupos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (lista.Any())
                    {
                        foreach (var item in lista)
                        {
                            var disponibles = cuposMap.ContainsKey(item.Id) ? cuposMap[item.Id] : item.Cupos;

                            <tr>
                                <td><strong>@item.Nombre</strong></td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@item.Lugar</td>
                                <td><span class="camp-cupo">@disponibles</span></td>
                                <td>
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <a href="@Url.Action("VerInscripciones", "Campanias", new { id = item.Id })" class="camp-btn-soft">Ver inscripciones</a>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("Inscribir", "Campanias", new { id = item.Id })" class="camp-btn-register">Registrar mascota</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="camp-empty">Todavía no hay campañas registradas.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>