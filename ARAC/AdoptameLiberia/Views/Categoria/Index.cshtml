@model IEnumerable<AdoptameLiberia.Models.Finanzas.CategoriaFinanciera>
@using System.Linq

@{
    ViewBag.Title = "Categoría";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Finanzas.CategoriaFinanciera>();

    var totalCategorias = lista.Count;
    var totalActivas = lista.Count(x => x.Estado == true);
    var totalGastos = lista.Count(x => x.Tipo == "Gasto");
}

<link href="~/Content/estilos/Categoria.css" rel="stylesheet" />

<div class="categoria-shell">
    <section class="categoria-hero">
        <div class="categoria-hero-copy">
            <span class="categoria-kicker">Gestión financiera</span>
            <h1>Categorías financieras del sistema</h1>
            <p>
                Organiza de forma clara las categorías utilizadas para registrar gastos,
                manteniendo una estructura ordenada y visualmente integrada con el resto del sitio.
            </p>
        </div>

        <div class="categoria-hero-image">
            <img src="@Url.Content("~/Content/img/GatoPerro.png")" alt="Categorías financieras" />
        </div>
    </section>

    <section class="categoria-stats">
        <article class="categoria-stat-card">
            <strong>@totalCategorias</strong>
            <span>Total categorías</span>
        </article>

        <article class="categoria-stat-card">
            <strong>@totalActivas</strong>
            <span>Activas</span>
        </article>

        <article class="categoria-stat-card">
            <strong>@totalGastos</strong>
            <span>Tipo gasto</span>
        </article>

        <article class="categoria-stat-card">
            <strong>@DateTime.Now.ToString("dd/MM/yyyy")</strong>
            <span>Fecha actual</span>
        </article>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="categoria-alert-success">
            @TempData["Success"]
        </div>
    }

    <section class="categoria-table-panel">
        <div class="categoria-table-head">
            <div>
                <h2>Listado de categorías</h2>
                <p>Consulta las categorías registradas actualmente en el módulo financiero.</p>
            </div>

            <div class="categoria-table-actions">
                <a href="@Url.Action("Create", "Categoria")" class="categoria-btn-soft">Registrar categoría</a>
            </div>
        </div>

        @if (lista.Any())
        {
            <div class="categoria-table-wrap">
                <table class="categoria-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Fecha de registro</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in lista)
                        {
                            <tr>
                                <td>#@item.ID_Categoria</td>
                                <td>@item.Nombre</td>
                                <td>
                                    <span class="categoria-badge categoria-badge-expense">Gasto</span>
                                </td>
                                <td>
                                    @if (item.Estado == true)
                                    {
                                        <span class="categoria-status categoria-status-active">Activa</span>
                                    }
                                    else
                                    {
                                        <span class="categoria-status categoria-status-inactive">Inactiva</span>
                                    }
                                </td>
                                <td>
                                    @(item.FechaRegistro.HasValue ? item.FechaRegistro.Value.ToString("dd/MM/yyyy HH:mm") : "Sin fecha")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="categoria-empty">
                <h3>No hay categorías registradas</h3>
                <p>
                    Cuando registres nuevas categorías, aparecerán aquí con el mismo diseño del resto del sistema.
                </p>
            </div>
        }
    </section>
</div>