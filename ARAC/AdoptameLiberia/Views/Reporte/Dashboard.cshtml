@model AdoptameLiberia.Models.Finanzas.ReporteFinancieroVM

@{
    ViewBag.Title = "Dashboard Financiero";
}

<h2 class="mb-4">📊 Transparencia de Donaciones</h2>

<!-- RESUMEN -->
<div class="row text-center mb-4">

    <div class="col-md-4">
        <div class="card shadow-sm p-3 bg-success text-white rounded">
            <h5>💰 Total Donado</h5>
            <h3>₡ @Model.TotalIngresos.ToString("N2")</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3 bg-danger text-white rounded">
            <h5>🧾 Total Utilizado</h5>
            <h3>₡ @Model.TotalGastos.ToString("N2")</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3 bg-info text-white rounded">
            <h5>🐾 Disponible</h5>
            <h3>₡ @Model.Balance.ToString("N2")</h3>
        </div>
    </div>

</div>

<!-- EXPLICACIÓN -->
<div class="alert alert-light border mb-4">
    <strong>¿Cómo se usan las donaciones?</strong><br />
    Las donaciones se destinan a cubrir alimentación, atención veterinaria,
    medicamentos y mantenimiento del refugio.
</div>

<!-- BARRA DE USO -->
@{
    var total = Model.TotalIngresos == 0 ? 1 : Model.TotalIngresos;
    var porcentaje = (Model.TotalGastos / total) * 100;
}

<h5>📊 Uso de las donaciones</h5>

<div class="progress mb-4">
    <div class="progress-bar bg-danger" style="width:@porcentaje%">
        @porcentaje.ToString("0")%
    </div>
</div>

<!-- TABLA -->
<h4>🐾 ¿En qué se usan los fondos?</h4>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Categoría</th>
            <th>Monto</th>
            <th>Descripción</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model.Gastos)
        {
            <tr>
                <!-- CATEGORÍA -->
                <td>
                    @(item.Categoria != null
                ? item.Categoria.Nombre
                : "Sin categoría")
                </td>

                <!-- MONTO -->
                <td class="fw-bold text-success">
                    ₡ @(item.Monto.HasValue
                ? item.Monto.Value.ToString("N2")
                : "0.00")
                </td>

                <!-- DESCRIPCIÓN -->
                <td>@item.Descripcion</td>
            </tr>
        }

    </tbody>
</table>