@model AdoptameLiberia.Models.Finanzas.ReporteFinancieroVM

@using System.Globalization

@{
    ViewBag.Title = "Dashboard Financiero";

    var total = Model.TotalIngresos == 0 ? 1 : Model.TotalIngresos;
    var porcentaje = (Model.TotalGastos / total) * 100;
}

@section styles {
    <link href="~/Content/estilos/Dashboard.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
}

<h2 class="titulo">
    <i class="fas fa-chart-pie"></i> Transparencia de Donaciones
</h2>

<!-- KPI -->
<div class="kpi-container">

    <div class="kpi-card">
        <i class="fas fa-coins"></i>
        <h5>Total Donado</h5>
        <h2>₡ @Model.TotalIngresos.ToString("N2")</h2>
    </div>

    <div class="kpi-card">
        <i class="fas fa-file-invoice"></i>
        <h5>Total Utilizado</h5>
        <h2>₡ @Model.TotalGastos.ToString("N2")</h2>
    </div>

    <div class="kpi-card">
        <i class="fas fa-wallet"></i>
        <h5>Disponible</h5>
        <h2>₡ @Model.Balance.ToString("N2")</h2>
    </div>

</div>

<!-- INFO -->
<div class="info-box">
    <strong>¿Cómo se usan las donaciones?</strong><br />
    Alimentación, atención veterinaria, medicamentos y mantenimiento del refugio.
</div>

<!-- PROGRESO -->
<div class="uso-section">

    <div class="uso-header">
        <h5>Uso de las donaciones</h5>
        <span>@porcentaje.ToString("0")% utilizado</span>
    </div>

    <div class="progress-bar-container">
        <div class="progress-bar-fill" style="width:@porcentaje%"></div>
    </div>

    <div class="uso-labels">
        <span>Utilizado: ₡ @Model.TotalGastos.ToString("N2")</span>
        <span>Disponible: ₡ @Model.Balance.ToString("N2")</span>
    </div>

</div>

<!-- GRID -->
<div class="dashboard-grid">

    <!-- GRAFICO -->
    <div class="card">
        <h5>
            <i class="fas fa-chart-pie"></i> Distribución de gastos
        </h5>
        <canvas id="grafico"></canvas>
    </div>

    <!-- TABLA -->
    <div class="card">
        <h5>¿En qué se usan los fondos?</h5>

        <table class="tabla-pro">
            <thead>
                <tr>
                    <th>Categoría</th>
                    <th>Monto</th>
                    <th>Descripción</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Gastos)
                {
                    <tr>
                        <td>
                            @(item.Categoria != null ? item.Categoria.Nombre : "Sin categoría")
                        </td>

                        <td class="monto">
                            ₡ @(item.Monto.HasValue ? item.Monto.Value.ToString("N2") : "0.00")
                        </td>

                        <td>@item.Descripcion</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>

<!-- CHART -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    var labels = [];
    var data = [];
    var colores = [];

    @{
        var grupos = Model.Gastos
            .GroupBy(g =>
            {
                if (g.Categoria != null && !string.IsNullOrWhiteSpace(g.Categoria.Nombre))
                    return g.Categoria.Nombre.Trim().ToLower();

                // 🔥 fallback a descripción (aquí entra Bryan)
                if (!string.IsNullOrWhiteSpace(g.Descripcion))
                    return g.Descripcion.Trim().ToLower();

                return "otros";
            })
            .Select(g => new
            {
                Nombre = CultureInfo.CurrentCulture.TextInfo.ToTitleCase(g.Key),
                Total = g.Sum(x => x.Monto ?? 0)
            })
            .OrderByDescending(g => g.Total)
            .ToList();

        var colorList = new List<string> {
            "#3B82F6", // Azul principal (base)
            "#10B981", // Verde (bueno / saludable)
            "#F59E0B", // Naranja (advertencia)
            "#EF4444", // Rojo (gasto fuerte)
            "#8B5CF6", // Morado (extra)
            "#06B6D4", // Cyan (detalle)
            "#84CC16"  // Verde claro (balance positivo)
        };

        int i = 0;
    }

    @{
        var coloresCategorias = new Dictionary<string, string>
        {
            { "vacunas", "#3B82F6" }, // azul
            { "bryan", "#F59E0B" },   // amarillo
            { "otros", "#9CA3AF" }    // gris
        };

        var coloresDisponibles = new List<string>
        {
            "#10B981", // verde
            "#8B5CF6", // morado
            "#EF4444", // rojo
            "#06B6D4", // cyan
            "#84CC16", // verde claro
            "#F97316", // naranja fuerte
            "#E11D48"  // rosado fuerte
        };

        int colorIndex = 0;
    }

    @foreach (var item in grupos)
    {
        string key = item.Nombre.ToLower();
        string color;

        if (coloresCategorias.ContainsKey(key))
        {
            color = coloresCategorias[key];
        }
        else
        {
            color = coloresDisponibles[colorIndex % coloresDisponibles.Count];
            colorIndex++;
        }

        <text>
            labels.push("@item.Nombre");
            data.push(@item.Total);
            colores.push("@color");
        </text>
    }

    const centerText = {
        id: 'centerText',
        beforeDraw(chart) {
            const { width, height, ctx } = chart;

            ctx.restore();

            let total = chart.data.datasets[0].data.reduce((a, b) => a + b, 0);

            ctx.font = "bold 18px sans-serif";
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.fillStyle = "#2c3e63";

            ctx.fillText("₡" + total.toLocaleString(), width / 2, height / 2);

            ctx.save();
        }
    };

    const ctx = document.getElementById('grafico');

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: data,
                backgroundColor: colores,
                borderWidth: 0,
                hoverOffset: 18
            }]
        },
        options: {
            cutout: '72%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        usePointStyle: true,
                        padding: 18
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let total = context.dataset.data.reduce((a, b) => a + b, 0);
                            let value = context.raw;
                            let percentage = ((value / total) * 100).toFixed(1);

                            return context.label + ': ₡' + value.toLocaleString() +
                                   ' (' + percentage + '%)';
                        }
                    }
                }
            },
            animation: {
                duration: 1200
            }
        },
        plugins: [centerText]
    });
</script>