@section styles {
    <link href="~/Content/estilos/About.css" rel="stylesheet" />
}

<!-- HERO -->
<div class="hero">

    <div class="hero-content">

        <div class="hero-text">
            <h1>Aprende a cuidar mejor <br /> a tu mascota 🐾</h1>

            <p>
                Descubre cómo mantener a tus mascotas saludables, felices y seguras
                con consejos y guías de cuidado responsable.
            </p>

            <div class="hero-buttons">
                <a href="#contenido" class="btn-primary">Explorar contenido</a>
            </div>
        </div>

        <div class="hero-image">
            <img src="@Url.Content("~/Content/img/Refugio.png")" />
        </div>

    </div>

</div>


<!-- CATEGORÍAS -->
<div class="categorias">

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-bone"></i></div>
        <h3>Alimentación</h3>
    </div>

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-syringe"></i></div>
        <h3>Salud</h3>
    </div>

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-soap"></i></div>
        <h3>Higiene</h3>
    </div>

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-house"></i></div>
        <h3>Ambiente</h3>
    </div>

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-heart"></i></div>
        <h3>Bienestar emocional</h3>
    </div>

</div>

<!-- CONTENIDO -->
<div id="contenido" class="contenido">

    <h2>Contenido educativo disponible</h2>

    <div class="contenido-grid">

        <a href="https://www.hillspet.co.cr/" target="_blank" class="contenido-card">
            <img src="https://placedog.net/400/250?id=1" />
            <h3>Alimentación adecuada</h3>
            <p>Consejos para una dieta balanceada.</p>
        </a>

        <a href="https://purina.co.cr/purina/perros/vacunas-para-perros" target="_blank" class="contenido-card">
            <img src="https://placedog.net/400/250?id=2" />
            <h3>Cuidados de salud</h3>
            <p>Vacunación y revisiones importantes.</p>
        </a>

        <a href="https://purina.co.cr/purina/perros/higiene-de-mascotas" target="_blank" class="contenido-card">
            <img src="https://placedog.net/400/250?id=3" />
            <h3>Higiene y vacunación</h3>
            <p>Rutinas básicas de limpieza.</p>
        </a>

        <!-- CONSEJO -->
        <div class="tip-card">
            <h3>✔ Consejo del día 🐶</h3>
            <p>
                El ejercicio diario es clave para mantener a tu mascota saludable
                y feliz. ¡Dale su paseo diario!
            </p>
        </div>

    </div>

</div>