@section styles {
    <link href="~/Content/estilos/About.css" rel="stylesheet" />
}

<div class="hero">
    <div class="hero-content">
        <div class="hero-text">
            <h1>Aprende a cuidar mejor a tu mascota</h1>

            <p>
                Descubre cómo mantener a tus mascotas saludables, seguras y bien atendidas
                con contenido práctico sobre alimentación, salud, higiene y bienestar diario.
            </p>
        </div>

        <div class="hero-image">
            <img src="@Url.Content("~/Content/img/Refugio.png")" alt="Cuidado animal" />
        </div>
    </div>
</div>

<div class="categorias">
    <div class="categoria-card">
        <div class="icon"><i class="fas fa-bone"></i></div>
        <h3>Alimentación</h3>
    </div>

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-syringe"></i></div>
        <h3>Salud</h3>
    </div>

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-soap"></i></div>
        <h3>Higiene</h3>
    </div>

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-house"></i></div>
        <h3>Ambiente</h3>
    </div>

    <div class="categoria-card">
        <div class="icon"><i class="fas fa-heart"></i></div>
        <h3>Bienestar emocional</h3>
    </div>
</div>

<div id="contenido" class="contenido">
    <h2>Contenido educativo disponible</h2>

    <div class="contenido-grid">
        <a href="https://www.hillspet.co.cr/" target="_blank" class="contenido-card">
            <img src="@Url.Content("~/Content/img/Perro.png")" alt="Alimentación adecuada" />
            <h3>Alimentación adecuada</h3>
            <p>Consejos para una dieta balanceada según la etapa de vida de tu mascota.</p>
        </a>

        <a href="https://purina.co.cr/purina/perros/vacunas-para-perros" target="_blank" class="contenido-card">
            <img src="@Url.Content("~/Content/img/Gato.png")" alt="Cuidados de salud" />
            <h3>Cuidados de salud</h3>
            <p>Información sobre vacunas, controles veterinarios y prevención básica.</p>
        </a>

        <a href="https://purina.co.cr/purina/perros/higiene-de-mascotas" target="_blank" class="contenido-card">
            <img src="@Url.Content("~/Content/img/PerroyGato.png")" alt="Higiene y cuidados" />
            <h3>Higiene y cuidados</h3>
            <p>Rutinas recomendadas para mantener una buena limpieza y bienestar diario.</p>
        </a>

        <div class="tip-card">
            <h3>Consejo del día</h3>
            <p>
                El ejercicio diario, una alimentación adecuada y revisiones periódicas
                ayudan a mantener a tu mascota en mejores condiciones físicas y emocionales.
            </p>
        </div>
    </div>
</div>