@{
    ViewBag.Title = "Inicio";
}

<link href="~/Content/estilos/Index.css" rel="stylesheet" />

<div class="home-shell">
    <section class="home-hero">
        <div class="home-hero-copy">
            <span class="hero-mini">Cuidado, adopción y apoyo</span>
            <h1>Un refugio digital con una imagen más moderna, clara y profesional</h1>
            <p>
                Explora mascotas disponibles, campañas de castración, donaciones, noticias y comunidad
                desde una sola plataforma con mejor navegación y presencia visual.
            </p>

            <div class="home-hero-actions">
                <a href="@Url.Action("Catalogo", "Animal")" class="home-btn home-btn-primary">Ver mascotas</a>
                <a href="@Url.Action("Index", "Campanias")" class="home-btn home-btn-light">Ver campañas</a>
            </div>

            <div class="home-stat-strip">
                <div class="home-stat">
                    <strong>Adopciones</strong>
                    <span>Perfiles claros de perros y gatos</span>
                </div>
                <div class="home-stat">
                    <strong>Donaciones</strong>
                    <span>Apoyo rápido y ordenado</span>
                </div>
                <div class="home-stat">
                    <strong>Comunidad</strong>
                    <span>Publicaciones y noticias del refugio</span>
                </div>
            </div>
        </div>

        <div class="home-hero-visual">
            <div class="hero-circle hero-circle-lg">
                <img src="~/Content/img/PerroyGato.png" alt="Mascotas" />
            </div>
            <div class="hero-circle hero-circle-sm">
                <img src="~/Content/img/Cachorro.png" alt="Veterinaria" />
            </div>
            <div class="hero-pill hero-pill-top">Adopción responsable</div>
            <div class="hero-pill hero-pill-bottom">Campañas y donaciones</div>
        </div>
    </section>

    <section class="home-categories">
        <a href="@Url.Action("Catalogo", "Animal")" class="home-cat-card">
            <h3>Mascotas</h3>
            <p>Consulta perros y gatos disponibles</p>
        </a>

        <a href="@Url.Action("Index", "Campanias")" class="home-cat-card">
            <h3>Campañas</h3>
            <p>Inscripciones y seguimiento</p>
        </a>

        <a href="@Url.Action("Index", "Donaciones")" class="home-cat-card">
            <h3>Donaciones</h3>
            <p>Apoya económicamente al refugio</p>
        </a>

        <a href="@Url.Action("Index", "Comunidad")" class="home-cat-card">
            <h3>Comunidad</h3>
            <p>Publicaciones, mensajes y apoyo</p>
        </a>
    </section>

    <section class="home-showcase">
        <div class="showcase-copy">
            <span class="section-kicker">Una sola línea visual</span>
            <h2>Las vistas dejan de verse como CRUD y pasan a sentirse como un sitio real</h2>
            <p>
                La lógica sigue funcionando igual, pero la presentación cambia con héroes visuales,
                tarjetas grandes, fondos limpios y botones más modernos.
            </p>

            <div class="showcase-list">
                <div><span></span>Catálogo más visual para adopciones</div>
                <div><span></span>Campañas con apariencia más clara y usable</div>
                <div><span></span>Donaciones y comunidad con mejor jerarquía</div>
            </div>
        </div>

        <div class="showcase-image">
            <img src="~/Content/img/Refugio.png" alt="Refugio" />
        </div>
    </section>
</div>