@model IEnumerable<AdoptameLiberia.Models.Noticias.Noticia>

@{
    ViewBag.Title = "Noticias";
    int currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
}

@section styles{
    <link href="~/Content/estilos/Noticias.css" rel="stylesheet" />
}

<div class="news-page">
    <section class="news-header-card">
        <div class="news-header-top">
            <div>
                <span class="news-kicker">ARAC · NOTICIAS</span>
                <h1>Noticias y novedades</h1>
                <p>
                    Mantente al tanto de campañas, rescates, actividades y anuncios importantes
                    del refugio en una vista más limpia, ordenada y moderna.
                </p>
            </div>

            @if (Request.IsAuthenticated && User.IsInRole("Administrador"))
            {
                <div class="news-header-actions">
                    @Html.ActionLink("Crear noticia", "Create", null, new { @class = "news-btn news-btn-primary" })
                </div>
            }
        </div>
    </section>

    <section class="news-list-section">
        <div class="news-section-head">
            <div>
                <h2>Últimas publicaciones</h2>
                <p>Consulta las noticias publicadas.</p>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="news-grid">
                @foreach (var item in Model)
                {
                    var liked = Session["like_" + item.ID_Noticia] != null;

                    <article class="news-card">
                        <div class="news-card-top">
                            <span class="news-date">
                                @(item.Fecha_Publicacion.HasValue ? item.Fecha_Publicacion.Value.ToString("dd/MM/yyyy HH:mm") : "Sin fecha")
                            </span>

                            <span class="news-like-count">
                                @item.Likes @(item.Likes == 1 ? "like" : "likes")
                            </span>
                        </div>

                        <h3>@item.Titulo</h3>

                        <p class="news-text">
                            @item.Contenido
                        </p>

                        <div class="news-card-actions">
                            @using (Html.BeginForm("Like", "Noticia", FormMethod.Post, new { @class = "news-like-form" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("id", item.ID_Noticia)
                                @Html.Hidden("page", currentPage)

                                if (liked)
                                {
                                    <button type="submit" class="news-like-btn liked" disabled="disabled">
                                        <span class="news-like-icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M2 21h4V9H2v12zm20-11.5c0-.83-.67-1.5-1.5-1.5h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L13.67 1 7.59 7.09C7.22 7.45 7 7.95 7 8.5V19c0 1.1.9 2 2 2h8c.82 0 1.52-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2.5z" />
                                            </svg>
                                        </span>
                                        <span>Ya diste like</span>
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="news-like-btn">
                                        <span class="news-like-icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M2 21h4V9H2v12zm20-11.5c0-.83-.67-1.5-1.5-1.5h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L13.67 1 7.59 7.09C7.22 7.45 7 7.95 7 8.5V19c0 1.1.9 2 2 2h8c.82 0 1.52-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2.5z" />
                                            </svg>
                                        </span>
                                        <span>Me gusta</span>
                                    </button>
                                }
                            }
                        </div>
                    </article>
                }
            </div>

            if (totalPages > 1)
            {
                <div class="news-pagination">
                    @if (currentPage > 1)
                    {
                        <a href="@Url.Action("Index", "Noticia", new { page = currentPage - 1 })" class="news-page-btn news-page-arrow" aria-label="Página anterior">
                            &#8249;
                        </a>
                    }
                    else
                    {
                        <span class="news-page-btn news-page-arrow disabled">&#8249;</span>
                    }

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == currentPage)
                        {
                            <span class="news-page-btn active">@i</span>
                        }
                        else
                        {
                            <a href="@Url.Action("Index", "Noticia", new { page = i })" class="news-page-btn">@i</a>
                        }
                    }

                    @if (currentPage < totalPages)
                    {
                        <a href="@Url.Action("Index", "Noticia", new { page = currentPage + 1 })" class="news-page-btn news-page-arrow" aria-label="Página siguiente">
                            &#8250;
                        </a>
                    }
                    else
                    {
                        <span class="news-page-btn news-page-arrow disabled">&#8250;</span>
                    }
                </div>
            }
        }
        else
        {
            <div class="news-empty">
                <strong>No hay noticias publicadas todavía.</strong>
                <p>Cuando se agreguen nuevas publicaciones aparecerán aquí.</p>
            </div>
        }
    </section>
</div>