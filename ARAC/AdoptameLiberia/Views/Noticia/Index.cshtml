@model IEnumerable<AdoptameLiberia.Models.Noticias.Noticia>

@{
    ViewBag.Title = "Noticias";
}

<div class="news-shell">
    <section class="page-hero">
        <span class="section-kicker">Noticias del refugio</span>
        <h1>Actualizaciones, comunicados y novedades</h1>
        <p>Consulta las noticias publicadas dentro del sistema con una presentación más consistente con el resto del sitio.</p>

        @if (Request.IsAuthenticated && User.IsInRole("Administrador"))
        {
            <div style="margin-top:18px;">
                @Html.ActionLink("Crear noticia", "Create", null, new { @class = "btn btn-primary" })
            </div>
        }
    </section>

    <section class="news-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <article class="news-card">
                    <div class="news-card-top">
                        <span class="news-date">
                            @(item.Fecha_Publicacion.HasValue ? item.Fecha_Publicacion.Value.ToString("dd/MM/yyyy HH:mm") : "")
                        </span>
                        <span class="news-likes">@item.Likes Me gusta</span>
                    </div>

                    <h3>@item.Titulo</h3>
                    <p>@item.Contenido</p>

                    <div class="news-card-actions">
                        @using (Html.BeginForm("Like", "Noticia", new { id = item.ID_Noticia }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-primary">Me gusta</button>
                        }
                    </div>
                </article>
            }
        }
        else
        {
            <div class="news-empty">No hay noticias registradas.</div>
        }
    </section>
</div>

<style>
    .news-shell {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .news-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

    .news-card {
        background: #fff;
        border: 1px solid #dcecf2;
        border-radius: 28px;
        padding: 24px;
        box-shadow: 0 14px 26px rgba(17, 92, 109, .08);
    }

    .news-card-top {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .news-date,
    .news-likes {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: .84rem;
        font-weight: 700;
    }

    .news-date {
        background: #eef9fc;
        color: #0d4c5a;
    }

    .news-likes {
        background: #f6fbff;
        color: #1498b9;
    }

    .news-card h3 {
        margin-bottom: 12px;
        font-size: 1.24rem;
    }

    .news-card p {
        color: #67818c;
        min-height: 88px;
    }

    .news-card-actions {
        margin-top: 16px;
    }

    .news-empty {
        grid-column: 1 / -1;
        background: #fff;
        border: 1px solid #dcecf2;
        border-radius: 28px;
        padding: 30px;
        text-align: center;
        color: #67818c;
    }

    @@media (max-width: 768px) {
        .news-grid {
            grid-template-columns: 1fr;
        }
    }
</style>