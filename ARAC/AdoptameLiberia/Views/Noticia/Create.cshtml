@model AdoptameLiberia.Models.Noticias.Noticia

@{
    ViewBag.Title = "Crear Noticia";
}

<div class="contenedor">

    <div class="card-post">

        <!-- HEADER -->
        <div class="header">
            <h2>Crear Noticia</h2>
            <p>Comparte una historia y conecta con la comunidad 🐾</p>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <!-- VALIDACIÓN GENERAL -->
            @Html.ValidationSummary(true, "", new { @class = "alert-error" })

            <!-- TÍTULO -->
            <div class="form-group">
                <label>Título *</label>
                @Html.TextBoxFor(m => m.Titulo, new
                {
                    @class = "input",
                    placeholder = "Ej: Rescate de perritos 🐾",
                    required = "required"
                })
                @Html.ValidationMessageFor(m => m.Titulo, "", new { @class = "text-danger" })
            </div>

            <!-- CONTENIDO -->
            <div class="form-group">
                <label>Contenido *</label>
                @Html.TextAreaFor(m => m.Contenido, new
                {
                    @class = "textarea",
                    rows = 5,
                    placeholder = "Escribe la historia...",
                    required = "required"
                })
                @Html.ValidationMessageFor(m => m.Contenido, "", new { @class = "text-danger" })
            </div>

            <!-- BOTÓN -->
            <div class="text-center mt-3">
                <button type="submit" class="btn-publicar">
                    Publicar noticia 🚀
                </button>
            </div>
        }

    </div>

</div>

<style>
    .contenedor {
        display: flex;
        justify-content: center;
        margin-top: 50px;
        padding: 20px;
    }

    .card-post {
        width: 100%;
        max-width: 650px;
        background: #ffffff;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .card-post:hover {
            transform: translateY(-3px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.12);
        }

    .header {
        text-align: center;
        margin-bottom: 25px;
    }

        .header h2 {
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 5px;
        }

        .header p {
            color: #6b7280;
            font-size: 0.95rem;
        }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        font-weight: 600;
        color: #374151;
        font-size: 0.9rem;
    }

    .input, .textarea {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        margin-top: 6px;
        transition: 0.2s;
        font-size: 0.95rem;
    }

        .input:focus, .textarea:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
            outline: none;
        }

    /* ERRORES */
    .text-danger {
        color: #dc2626;
        font-size: 0.85rem;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 15px;
        font-size: 0.9rem;
    }

    /* BOTÓN */
    .btn-publicar {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
        padding: 12px 25px;
        border-radius: 12px;
        border: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: 0.3s;
        box-shadow: 0 10px 20px rgba(59,130,246,0.2);
    }

        .btn-publicar:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 25px rgba(59,130,246,0.3);
        }
</style>