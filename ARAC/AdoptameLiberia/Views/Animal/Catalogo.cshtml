@model IEnumerable<AdoptameLiberia.Models.Mascotas.AnimalModel>
@using System.Collections.Generic

@{
    ViewBag.Title = "Mascotas";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Mascotas.AnimalModel>();
    var favoritos = ViewBag.Favoritos as HashSet<int> ?? new HashSet<int>();
    bool esAdmin = ViewBag.EsAdmin != null && (bool)ViewBag.EsAdmin;
}

<link href="~/Content/estilos/Mascotas.css" rel="stylesheet" />

<div class="catalog-shell">
    <section class="catalog-hero">
        <div class="catalog-copy">
            <span class="section-kicker">Catálogo ARAC</span>

            @if (Request.IsAuthenticated)
            {
                if (esAdmin)
                {
                    <h1>Gestión de mascotas</h1>
                    <p>Administra las mascotas registradas dentro del refugio con una vista más limpia y profesional.</p>
                }
                else
                {
                    <h1>Mis mascotas registradas</h1>
                    <p>Consulta y administra las mascotas asociadas a tu cuenta desde un catálogo visual.</p>
                }
            }
            else
            {
                <h1>Encuentra tu próxima compañía</h1>
                <p>Explora perros y gatos disponibles en adopción con información clara y accesible.</p>
            }

            @if (Request.IsAuthenticated)
            {
                <div class="catalog-hero-actions">
                    <a href="@Url.Action("Crear", "Animal")" class="catalog-btn-main">
                        @(esAdmin ? "Registrar mascota" : "Registrar mi mascota")
                    </a>
                    <a href="@Url.Action("Index", "Favoritos")" class="catalog-btn-soft">Ver favoritos</a>
                </div>
            }
        </div>

        <div class="catalog-visual">
            <div class="catalog-visual-card">
                <img src="~/Content/img/GatoPerro.png" alt="Mascotas ARAC" />
            </div>
        </div>
    </section>

    @if (lista.Any())
    {
        <section class="catalog-grid">
            @foreach (var item in lista)
            {
                var esFavorito = favoritos.Contains(item.ID_Animal);

                <article class="pet-card-pro">
                    <div class="pet-card-media">
                        <img src="@(item.NombreTipo == "Gato" ? Url.Content("~/Content/img/Gatillo.png") : Url.Content("~/Content/img/Cachorro.png"))" alt="@item.Nombre_Animal" />
                        <span class="pet-chip">@(string.IsNullOrWhiteSpace(item.NombreTipo) ? "Mascota" : item.NombreTipo)</span>

                        @if (Request.IsAuthenticated)
                        {
                            using (Html.BeginForm("Toggle", "Favoritos", FormMethod.Post, new { @class = "pet-fav-form" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("idAnimal", item.ID_Animal)
                                @Html.Hidden("returnUrl", Request.RawUrl)
                                <button type="submit" class="pet-fav-btn @(esFavorito ? "active" : "")" title="Favorito">
                                    @(esFavorito ? "Quitar" : "Guardar")
                                </button>
                            }
                        }
                    </div>

                    <div class="pet-card-body">
                        <h3>@item.Nombre_Animal</h3>
                        <p class="pet-description">@(string.IsNullOrWhiteSpace(item.Descripcion) ? "Mascota disponible en el refugio." : item.Descripcion)</p>

                        <div class="pet-data-grid">
                            <div><span>Raza</span><strong>@(string.IsNullOrWhiteSpace(item.NombreRaza) ? "No registrada" : item.NombreRaza)</strong></div>
                            <div><span>Edad</span><strong>@(item.Edad.HasValue ? item.Edad + " años" : "No registrada")</strong></div>
                            <div><span>Sexo</span><strong>@(string.IsNullOrWhiteSpace(item.Sexo) ? "No registrado" : item.Sexo)</strong></div>
                            <div><span>Tamaño</span><strong>@(string.IsNullOrWhiteSpace(item.Tamano) ? "No registrado" : item.Tamano)</strong></div>
                            <div><span>Peso</span><strong>@(item.Peso.HasValue ? item.Peso + " kg" : "No registrado")</strong></div>
                            <div><span>Estado</span><strong>@(string.IsNullOrWhiteSpace(item.Estado) ? "Disponible" : item.Estado)</strong></div>
                        </div>

                        @if (Request.IsAuthenticated)
                        {
                            <div class="pet-card-actions">
                                <a href="@Url.Action("Editar", "Animal", new { id = item.ID_Animal })" class="catalog-btn-soft">Editar</a>
                                <a href="@Url.Action("Desactivar", "Animal", new { id = item.ID_Animal })"
                                   class="catalog-btn-danger"
                                   onclick="return confirm('¿Seguro que deseas desactivar esta mascota?');">
                                    Desactivar
                                </a>
                            </div>
                        }
                    </div>
                </article>
            }
        </section>
    }
    else
    {
        <section class="catalog-empty">
            <h3>No hay mascotas disponibles por el momento</h3>
            <p>Cuando se registren nuevas mascotas aparecerán aquí con este mismo diseño.</p>
        </section>
    }
</div>