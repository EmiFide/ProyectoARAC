@model IEnumerable<AdoptameLiberia.Models.Mascotas.AnimalModel>
@using System.Collections.Generic
@using System.Linq

@{
    ViewBag.Title = "Mascotas";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Mascotas.AnimalModel>();
    var favoritos = ViewBag.Favoritos as HashSet<int> ?? new HashSet<int>();
    bool esAdmin = ViewBag.EsAdmin != null && (bool)ViewBag.EsAdmin;
}

<link href="~/Content/estilos/Mascotas.css" rel="stylesheet" />

<style>
    .mascota-ideal-cta {
        margin-top: 34px;
        background: linear-gradient(135deg, #f7fbff 0%, #ffffff 100%);
        border: 1px solid #dcecf2;
        border-radius: 24px;
        padding: 24px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 18px;
        align-items: center;
        box-shadow: 0 12px 24px rgba(17, 92, 109, .07);
    }

        .mascota-ideal-cta h3 {
            margin: 0 0 8px;
            color: #264653;
            font-size: 1.45rem;
        }

        .mascota-ideal-cta p {
            margin: 0;
            color: #67818c;
            line-height: 1.8;
            max-width: 760px;
        }

    .mascota-ideal-cta-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 20px;
        border-radius: 14px;
        background: linear-gradient(135deg, #2d6cdf 0%, #1d4fb8 100%);
        color: #fff !important;
        font-weight: 700;
        text-decoration: none !important;
        box-shadow: 0 10px 18px rgba(45, 108, 223, .20);
        white-space: nowrap;
    }

        .mascota-ideal-cta-btn:hover {
            color: #fff !important;
            text-decoration: none !important;
            background: linear-gradient(135deg, #255fcd 0%, #1746a9 100%);
        }

    @@media (max-width: 768px) {
        .mascota-ideal-cta {
            grid-template-columns: 1fr;
        }

        .mascota-ideal-cta-btn {
            width: 100%;
        }
    }
</style>

<div class="catalog-shell">
    <section class="catalog-hero">
        <div class="catalog-copy">
            <h1>Catálogo de mascotas</h1>
            <p>
                Explora perros y gatos registrados en la plataforma en una vista más compacta,
                ordenada y cómoda de usar.
            </p>

            <div class="catalog-hero-actions">
                @if (esAdmin)
                {
                    <a href="@Url.Action("Crear", "Animal")" class="catalog-btn-main">Registrar mascota</a>
                }

                <a href="@Url.Action("Index", "Favoritos")" class="catalog-btn-soft">Ver favoritos</a>
            </div>
        </div>

        <div class="catalog-visual">
            <div class="catalog-visual-card">
                <img src="~/Content/img/GatoPerro.png" alt="Mascotas ARAC" />
            </div>
        </div>
    </section>

    @if (lista.Any())
    {
        <section class="catalog-grid">
            @foreach (var item in lista)
            {
                var esFavorito = favoritos.Contains(item.ID_Animal);

                <article class="pet-card-pro">
                    <div class="pet-card-media">
                        @{
                            string imagenMostrar;

                            if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                imagenMostrar = Url.Content(item.ImagenUrl);
                            }
                            else if (item.NombreTipo == "Gato")
                            {
                                imagenMostrar = Url.Content("~/Content/img/Gatillo.png");
                            }
                            else
                            {
                                imagenMostrar = Url.Content("~/Content/img/Cachorro.png");
                            }
                        }

                        <img src="@imagenMostrar" alt="@item.Nombre_Animal" />

                        <span class="pet-chip">
                            @(string.IsNullOrWhiteSpace(item.NombreTipo) ? "Mascota" : item.NombreTipo)
                        </span>

                        @using (Html.BeginForm("Toggle", "Favoritos", FormMethod.Post, new { @class = "pet-fav-form" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("idAnimal", item.ID_Animal)
                            @Html.Hidden("returnUrl", Request.RawUrl)

                            <button type="submit"
                                    class="pet-fav-btn @(esFavorito ? "active" : "")"
                                    title="Agregar a favoritos">
                                <span class="heart-icon">❤</span>
                            </button>
                        }
                    </div>

                    <div class="pet-card-body">
                        <h3>@item.Nombre_Animal</h3>

                        <p class="pet-description">
                            @(string.IsNullOrWhiteSpace(item.Descripcion) ? "Mascota disponible en el refugio." : item.Descripcion)
                        </p>

                        <div class="pet-data-grid">
                            <div><span>Raza</span><strong>@(string.IsNullOrWhiteSpace(item.NombreRaza) ? "No registrada" : item.NombreRaza)</strong></div>
                            <div><span>Edad</span><strong>@(item.Edad.HasValue ? item.Edad + " años" : "No registrada")</strong></div>
                            <div><span>Sexo</span><strong>@(string.IsNullOrWhiteSpace(item.Sexo) ? "No registrado" : item.Sexo)</strong></div>
                            <div><span>Tamaño</span><strong>@(string.IsNullOrWhiteSpace(item.Tamano) ? "No registrado" : item.Tamano)</strong></div>
                            <div><span>Peso</span><strong>@(item.Peso.HasValue ? item.Peso + " kg" : "No registrado")</strong></div>

                            <div>
                                <span>Estado</span>
                                <strong class="badge-estado @(item.Estado == "Disponible" ? "ok" : "no")">
                                    @(string.IsNullOrWhiteSpace(item.Estado) ? "Disponible" : item.Estado)
                                </strong>
                            </div>
                        </div>

                        @if (esAdmin)
                        {
                            <div class="pet-card-actions">
                                <a href="@Url.Action("Editar", "Animal", new { id = item.ID_Animal })" class="pet-edit-btn">
                                    Editar
                                </a>
                                <a href="@Url.Action("Desactivar", "Animal", new { id = item.ID_Animal })"
                                   class="catalog-btn-danger"
                                   onclick="return confirm('¿Seguro que deseas quitar esta mascota?');">
                                    Quitar
                                </a>
                            </div>
                        }

                        <div class="pet-card-actions">
                            @if (item.Estado == "Disponible")
                            {
                                <a href="@Url.Action("RegistrarSolicitud", "Adopciones", new { idAnimal = item.ID_Animal })"
                                   class="catalog-btn-main">
                                    Adoptar
                                </a>
                            }
                            else
                            {
                                <span class="catalog-btn-disabled">
                                    No disponible
                                </span>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>
    }
    else
    {
        <section class="catalog-empty">
            <h3>No hay mascotas disponibles en este momento</h3>
            <p>Pronto tendremos nuevas mascotas esperando un hogar.</p>
        </section>
    }

    <section class="mascota-ideal-cta">
        <div>
            <h3>¿No encontraste mascota?</h3>
            <p>
                Usa nuestro buscador de mascota ideal para encontrar a tu compañero ideal.
            </p>
        </div>

        <div>
            <a href="@Url.Action("MascotaIdeal", "Animal")" class="mascota-ideal-cta-btn">
                Buscar mascota ideal
            </a>
        </div>
    </section>
</div>