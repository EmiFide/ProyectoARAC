@model IEnumerable<AdoptameLiberia.Models.Mascotas.AnimalModel>

@{
    ViewBag.Title = "Catálogo de Mascotas";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Mascotas.AnimalModel>();
}

<link href="~/Content/estilos/Mascotas.css" rel="stylesheet" />

<div class="mascota-shell">
    <div class="mascota-hero">
        <div class="mascota-hero-content">
            <h1>Catálogo de mascotas</h1>
            <p>Consulta las mascotas registradas y administra su información.</p>
        </div>
    </div>

    <div class="mascota-form-card">
        <div class="mascota-actions" style="margin-top:0; margin-bottom:20px;">
            <a href="@Url.Action("Crear", "Animal")" class="mascota-btn">Registrar mascota</a>
        </div>

        @if (lista.Any())
        {
            <div style="overflow-x:auto;">
                <table class="table table-bordered table-striped" style="background:white; border-radius:18px; overflow:hidden;">
                    <thead style="background:#40090b; color:white;">
                        <tr>
                            <th>Nombre</th>
                            <th>Edad</th>
                            <th>Sexo</th>
                            <th>Tamaño</th>
                            <th>Peso</th>
                            <th>Descripción</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in lista)
                        {
                            <tr>
                                <td>@item.Nombre_Animal</td>
                                <td>@item.Edad</td>
                                <td>@item.Sexo</td>
                                <td>@item.Tamano</td>
                                <td>@item.Peso Kg</td>
                                <td>@item.Descripcion</td>
                                <td>
                                    <div class="mascota-actions" style="margin-top:0;">
                                        <a href="@Url.Action("Editar", new { id = item.ID_Animal })" class="mascota-btn-outline">Editar</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div style="text-align:center; padding:30px; color:#7c5649;">
                No hay mascotas registradas todavía.
            </div>
        }
    </div>
</div>