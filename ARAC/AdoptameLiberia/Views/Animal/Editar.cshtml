@model AdoptameLiberia.Models.Mascotas.AnimalModel
@using System.Collections.Generic
@using System.Web.Mvc

@{
    ViewBag.Title = "Editar mascota";
    var listaRazas = ViewBag.ListaRazas as List<SelectListItem> ?? new List<SelectListItem>();
    var listaTipos = ViewBag.ListaTipos as List<SelectListItem> ?? new List<SelectListItem>();
}

<link href="~/Content/estilos/Mascotas.css" rel="stylesheet" />

<div class="mascota-shell">
    <div class="mascota-hero">
        <div class="mascota-hero-content">
            <h1>Editar mascota</h1>
            <p>Actualiza los datos de la mascota registrada.</p>
        </div>
    </div>

    <div class="mascota-form-card">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.ID_Animal)

            <div class="mascota-form-grid">
                <div class="mascota-group">
                    <label>Nombre de la mascota</label>
                    @Html.TextBoxFor(m => m.Nombre_Animal, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Nombre_Animal, "", new { @class = "text-danger" })
                </div>

                <div class="mascota-group">
                    <label>Raza</label>
                    @Html.DropDownListFor(
                        m => m.ID_Raza,
                        new SelectList(listaRazas, "Value", "Text", Model != null ? Model.ID_Raza : 0),
                        "Seleccione una raza",
                        new { @class = "form-control" }
                    )
                    @Html.ValidationMessageFor(m => m.ID_Raza, "", new { @class = "text-danger" })
                </div>

                <div class="mascota-group">
                    <label>Tipo de animal</label>
                    @Html.DropDownListFor(
                        m => m.ID_TipoAnimal,
                        new SelectList(listaTipos, "Value", "Text", Model != null ? Model.ID_TipoAnimal : 0),
                        "Seleccione un tipo",
                        new { @class = "form-control" }
                    )
                    @Html.ValidationMessageFor(m => m.ID_TipoAnimal, "", new { @class = "text-danger" })
                </div>

                <div class="mascota-group">
                    <label>Edad</label>
                    @Html.TextBoxFor(m => m.Edad, new { @class = "form-control", type = "number", min = "0" })
                </div>

                <div class="mascota-group">
                    <label>Sexo</label>
                    @Html.DropDownListFor(
                        m => m.Sexo,
                        new List<SelectListItem>
                        {
                            new SelectListItem { Text = "Macho", Value = "Macho", Selected = Model != null && Model.Sexo == "Macho" },
                            new SelectListItem { Text = "Hembra", Value = "Hembra", Selected = Model != null && Model.Sexo == "Hembra" }
                        },
                        "Seleccione el sexo",
                        new { @class = "form-control" }
                    )
                </div>

                <div class="mascota-group">
                    <label>Tamaño</label>
                    @Html.DropDownListFor(
                        m => m.Tamano,
                        new List<SelectListItem>
                        {
                            new SelectListItem { Text = "Pequeño", Value = "Pequeño", Selected = Model != null && Model.Tamano == "Pequeño" },
                            new SelectListItem { Text = "Mediano", Value = "Mediano", Selected = Model != null && Model.Tamano == "Mediano" },
                            new SelectListItem { Text = "Grande", Value = "Grande", Selected = Model != null && Model.Tamano == "Grande" }
                        },
                        "Seleccione el tamaño",
                        new { @class = "form-control" }
                    )
                </div>

                <div class="mascota-group">
                    <label>Peso kg</label>
                    @Html.TextBoxFor(m => m.Peso, new { @class = "form-control", type = "number", step = "0.01", min = "0" })
                </div>

                <div class="mascota-group full">
                    <label>Descripción</label>
                    @Html.TextAreaFor(m => m.Descripcion, new { @class = "form-control", rows = "5" })
                </div>
            </div>

            <div class="mascota-actions">
                <button type="submit" class="mascota-btn">Guardar cambios</button>
                <a href="@Url.Action("Catalogo", "Animal")" class="mascota-btn-outline">Volver</a>
            </div>
        }
    </div>
</div>

@section scripts{
    @Scripts.Render("~/bundles/jqueryval")
}