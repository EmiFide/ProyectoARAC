@model AdoptameLiberia.Models.Mascotas.AnimalModel
@using System.Collections.Generic
@using System.Web.Mvc

@{
    ViewBag.Title = "Registrar mascota";
    var listaRazas = ViewBag.ListaRazas as List<SelectListItem> ?? new List<SelectListItem>();
    var listaTipos = ViewBag.ListaTipos as List<SelectListItem> ?? new List<SelectListItem>();
}

<link href="~/Content/estilos/Mascotas.css" rel="stylesheet" />

<div class="edit-shell">

    <div class="edit-card">
        <div class="edit-header">
            <h2>Registrar mascota 🐾</h2>
            <p>Completa la información de la mascota registrada</p>
        </div>

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="edit-grid">

                <div class="edit-group">
                    <label>Nombre</label>
                    @Html.TextBoxFor(m => m.Nombre_Animal, new { @class = "edit-input" })
                    @Html.ValidationMessageFor(m => m.Nombre_Animal, "", new { @class = "text-danger" })
                </div>

                <div class="edit-group">
                    <label>Raza</label>
                    @Html.DropDownListFor(
                        m => m.ID_Raza,
                        new SelectList(listaRazas, "Value", "Text"),
                        "Seleccione una raza",
                        new { @class = "edit-input" }
                    )
                </div>

                <div class="edit-group">
                    <label>Tipo</label>
                    @Html.DropDownListFor(
                        m => m.ID_TipoAnimal,
                        new SelectList(listaTipos, "Value", "Text"),
                        "Seleccione un tipo",
                        new { @class = "edit-input" }
                    )
                </div>

                <div class="edit-group">
                    <label>Edad</label>
                    @Html.TextBoxFor(m => m.Edad, new { @class = "edit-input", type = "number" })
                </div>

                <div class="edit-group">
                    <label>Sexo</label>
                    @Html.DropDownListFor(
                        m => m.Sexo,
                        new List<SelectListItem>
                        {
                            new SelectListItem { Text = "Macho", Value = "Macho" },
                            new SelectListItem { Text = "Hembra", Value = "Hembra" }
                        },
                        "Seleccione",
                        new { @class = "edit-input" }
                    )
                </div>

                <div class="edit-group">
                    <label>Tamaño</label>
                    @Html.DropDownListFor(
                        m => m.Tamano,
                        new List<SelectListItem>
                        {
                            new SelectListItem { Text = "Pequeño", Value = "Pequeño" },
                            new SelectListItem { Text = "Mediano", Value = "Mediano" },
                            new SelectListItem { Text = "Grande", Value = "Grande" }
                        },
                        "Seleccione",
                        new { @class = "edit-input" }
                    )
                </div>

                <div class="edit-group">
                    <label>Peso (kg)</label>
                    @Html.TextBoxFor(m => m.Peso, new { @class = "edit-input", type = "number", step = "0.01" })
                </div>

                <div class="edit-group full">
                    <label>Descripción</label>
                    @Html.TextAreaFor(m => m.Descripcion, new { @class = "edit-input", rows = "4" })
                </div>

            </div>

            <div class="edit-actions">
                <button type="submit" class="edit-btn-primary">
                    Guardar mascota
                </button>

                <a href="@Url.Action("Catalogo", "Animal")" class="edit-btn-secondary">
                    Volver
                </a>
            </div>
        }
    </div>
</div>

@section scripts{
    @Scripts.Render("~/bundles/jqueryval")
}