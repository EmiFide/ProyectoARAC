@model AdoptameLiberia.Models.Mascotas.AnimalModel

@{
    ViewBag.Title = "Registrar Mascota";
}

<link href="~/Content/estilos/Mascotas.css" rel="stylesheet" />

<div class="mascota-shell">
    <div class="mascota-hero">
        <div class="mascota-hero-content">
            <h1>Registrar nueva mascota</h1>
            <p>Agrega la información principal de la mascota manteniendo la misma estética del sistema.</p>
        </div>
    </div>

    <div class="mascota-layout">
        <div class="mascota-form-card">
            @using (Html.BeginForm())
            {
                <div class="mascota-form-grid">
                    <div class="mascota-group">
                        <label>Nombre</label>
                        @Html.TextBoxFor(m => m.Nombre_Animal)
                    </div>

                    <div class="mascota-group">
                        <label>Edad</label>
                        @Html.TextBoxFor(m => m.Edad, new { type = "number", min = "0" })
                    </div>

                    <div class="mascota-group">
                        <label>Sexo</label>
                        @Html.TextBoxFor(m => m.Sexo)
                    </div>

                    <div class="mascota-group">
                        <label>ID Tipo Animal</label>
                        @Html.TextBoxFor(m => m.ID_TipoAnimal)
                    </div>

                    <div class="mascota-group">
                        <label>ID Raza</label>
                        @Html.TextBoxFor(m => m.ID_Raza)
                    </div>

                    <div class="mascota-group">
                        <label>Tamaño</label>
                        @Html.TextBoxFor(m => m.Tamano)
                    </div>

                    <div class="mascota-group">
                        <label>Peso</label>
                        <div style="display:flex; gap:8px;">
                            @Html.TextBoxFor(m => m.Peso, new { type = "number", step = "0.01", style = "flex:1;" })
                            <input type="text" value="Kg" readonly style="width:80px;" />
                        </div>
                    </div>

                    <div class="mascota-group full">
                        <label>Descripción</label>
                        @Html.TextAreaFor(m => m.Descripcion)
                    </div>
                </div>

                <div class="mascota-actions">
                    <button type="submit" class="mascota-btn">Guardar</button>
                    <a href="@Url.Action("Catalogo", "Animal")" class="mascota-btn-outline">Volver</a>
                </div>
            }
        </div>

        <div class="mascota-side-photo">
            <img src="~/Content/img/GatoPerro.png" alt="GatoEncimaPerro.webp" />
        </div>
    </div>
</div>