@model AdoptameLiberia.Models.ViewModel.EvaluarSolicitudVM

@{
    ViewBag.Title = "Evaluar solicitud";
}

@section Styles {
    <link href="~/Content/estilos/Evaluar.css" rel="stylesheet" />
}

<div class="evaluar-container">

    <!-- HEADER -->
    <div class="evaluar-hero">
        <h1>Evaluar solicitud #@Model.ID_Solicitud</h1>
        <p>Revisa la información del solicitante antes de tomar una decisión</p>
    </div>

    <!-- INFO -->
    <div class="evaluar-card">

        <div class="info-grid">

            <div class="info-item">
                <label>Usuario</label>
                <p>@Model.UsuarioNombre</p>
            </div>

            <div class="info-item">
                <label>Animal</label>
                <p>@Model.AnimalNombre</p>
            </div>

            <div class="info-item">
                <label>Motivo</label>
                <p>@Model.Motivo_Adopcion</p>
            </div>

            <div class="info-item">
                <label>Condiciones del hogar</label>
                <p>@Model.Condiciones_Hogar</p>
            </div>

            <div class="info-item">
                <label>Otros animales</label>
                <p>@(Model.Otros_Animales ? "Sí" : "No")</p>
            </div>

            <div class="info-item">
                <label>Detalle</label>
                <p>@Model.Detalle_Otros_Animales</p>
            </div>

        </div>

        <!-- FORM -->
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.ID_Solicitud)

            <div class="form-group-modern">
                <label>Nuevo estado</label>
                @Html.DropDownListFor(m => m.Estado, (SelectList)ViewBag.Estados, "Seleccione", new { @class = "select-modern" })
                @Html.ValidationMessageFor(m => m.Estado, "", new { @class = "text-danger" })
            </div>

            <div class="acciones">
                <button type="submit" class="btn-guardar">Guardar evaluación</button>
                @Html.ActionLink("Volver", "Solicitudes", null, new { @class = "btn-volver" })
            </div>
        }

    </div>

</div>