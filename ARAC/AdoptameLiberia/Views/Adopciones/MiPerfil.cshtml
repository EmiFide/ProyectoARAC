@model AdoptameLiberia.Models.ViewModel.MiPerfilAdopcionVM

@{
    ViewBag.Title = "Mi perfil de adopción";
}

@section Styles {
    <link href="~/Content/estilos/MiPerfil.css" rel="stylesheet" />
}

<div class="perfil-container">

    <!-- HERO -->
    <div class="perfil-hero">
        <div>
            <h2>Mi perfil de adopción</h2>
            <p>@Model.NombreUsuario</p>
        </div>

        @Html.ActionLink("Ver reporte", "ReporteAdopciones", null, new { @class = "btn btn-light btn-sm" })
    </div>

    <!-- STATS -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon bg-blue">📄</div>
            <div>
                <strong>@Model.Solicitudes.Count()</strong>
                <small>Solicitudes</small>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-green">🐾</div>
            <div>
                <strong>@Model.Adopciones.Count()</strong>
                <small>Adopciones</small>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-yellow">📋</div>
            <div>
                <strong>@Model.Seguimientos.Count()</strong>
                <small>Seguimientos</small>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon bg-red">⚠️</div>
            <div>
                <strong>@(Model.Devoluciones?.Count() ?? 0)</strong>
                <small>Devoluciones</small>
            </div>
        </div>
    </div>

    <!-- GRID -->
    <div class="grid-2">

        <!-- SOLICITUDES -->
        <div class="card-custom">
            <div class="card-header-custom">📄 Mis solicitudes</div>

            <div class="list-row list-header">
                <div>Animal</div>
                <div>Fecha</div>
                <div>Estado</div>
                <div>Motivo</div>
            </div>

            @foreach (var item in Model.Solicitudes)
            {
                <div class="list-row">
                    <div>@item.AnimalNombre</div>
                    <div>@(item.Fecha_Solicitud?.ToString("dd/MM/yyyy"))</div>
                    <div>
                        <span class="badge-custom estado-@item.Estado.ToLower()">
                            @item.Estado
                        </span>
                    </div>
                    <div>@item.Motivo_Adopcion</div>
                </div>
            }

        </div>

        <!-- ADOPCIONES -->
        <div class="card-custom">
            <div class="card-header-custom">🐾 Mis adopciones</div>

            <div class="list-row list-header">
                <div>Animal</div>
                <div>Estado</div>
                <div>Seguimiento</div>

                @if (User.IsInRole("Administrador"))
                {
                    <div>Acción</div>
                }
            </div>

            @foreach (var item in Model.Adopciones)
            {
                <div class="list-row">
                    <div>@item.AnimalNombre</div>

                    <div>
                        <span class="badge-custom estado-@item.Estado_Adopcion.ToLower()">
                            @item.Estado_Adopcion
                        </span>
                    </div>

                    <div>@item.Seguimiento_Inicial</div>

                    @if (User.IsInRole("Administrador"))
                    {
                        <div>
                            @Html.ActionLink("Registrar", "RegistrarSeguimiento",
                                new { id = item.ID_Adopcion },
                                new { @class = "btn-action" })
                        </div>
                    }
                </div>
            }

        </div>

        <!-- SEGUIMIENTOS -->
        <div class="card-custom">
            <div class="card-header-custom">📋 Seguimientos</div>

            <div class="list-row list-row-6 list-header">
                <div>Animal</div>
                <div>Fecha</div>
                <div>Tipo</div>
                <div>Mascota</div>
                <div>Hogar</div>
                <div>Comentario</div>
            </div>

            @foreach (var item in Model.Seguimientos)
            {
                <div class="list-row list-row-6">
                    <div>@item.AnimalNombre</div>
                    <div>@item.Fecha_Seguimiento.ToString("dd/MM/yyyy")</div>
                    <div>@item.Tipo_Seguimiento</div>
                    <div class="badge-soft">@item.Estado_Mascota</div>
                    <div class="badge-soft">@item.Estado_Hogar</div>
                    <div>@item.Comentario</div>
                </div>
            }

        </div>

        <!-- DEVOLUCIONES -->
        <div class="card-custom">
            <div class="card-header-custom">⚠️ Devoluciones</div>

            <div class="list-row list-header">
                <div>Animal</div>
                <div>Fecha</div>
                <div>Motivo</div>
                <div>Estado</div>
            </div>

            @foreach (var item in Model.Devoluciones)
            {
                <div class="list-row">
                    <div>@item.AnimalNombre</div>
                    <div>@item.Fecha_Devolucion.ToString("dd/MM/yyyy")</div>
                    <div>@item.Motivo</div>
                    <div class="badge-soft">@item.Estado_Final_Animal</div>
                </div>
            }

        </div>

    </div>

</div>