@model AdoptameLiberia.Models.ViewModel.RegistrarDevolucionVM

@{
    ViewBag.Title = "Registrar devolución";
}

<link href="~/Content/estilos/Devoluciones.css" rel="stylesheet" />

<div class="page-shell">

    <!-- HERO -->
    <section class="hero-devolucion">
        <div class="hero-text">
            <span class="kicker">Gestión de adopciones</span>
            <h1>Registrar devolución</h1>
            <p>
                Cuando una adopción no funciona, registramos la devolución para seguir cuidando al animal
                y encontrarle un nuevo hogar adecuado.
            </p>
        </div>

        <div class="hero-img">
            <img src="@Url.Content("~/Content/img/perro-triste.png")" alt="Devolución mascota" />
        </div>
    </section>

    <!-- CARD FORM -->
    <div class="form-card">

        <!-- INFO -->
        <div class="alert-custom">
            @Model.AdopcionInfo
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.ID_Adopcion)

            <div class="form-grid">

                <div class="form-group">
                    @Html.LabelFor(m => m.Fecha_Devolucion)
                    @Html.TextBoxFor(m => m.Fecha_Devolucion, "{0:yyyy-MM-ddTHH:mm}",
                        new { @class = "input-custom", type = "datetime-local" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Estado_Final_Animal)
                    @Html.DropDownListFor(m => m.Estado_Final_Animal,
                        (SelectList)ViewBag.EstadosFinales,
                        "Seleccione",
                        new { @class = "input-custom" })
                </div>

                <div class="form-group full">
                    @Html.LabelFor(m => m.Motivo)
                    @Html.TextAreaFor(m => m.Motivo,
                        new { @class = "input-custom", rows = 4, placeholder = "Explica el motivo de la devolución..." })
                    @Html.ValidationMessageFor(m => m.Motivo, "", new { @class = "text-danger" })
                </div>

                <div class="form-group full">
                    @Html.LabelFor(m => m.Observacion)
                    @Html.TextAreaFor(m => m.Observacion,
                        new { @class = "input-custom", rows = 3, placeholder = "Observaciones adicionales..." })
                </div>

            </div>

            <!-- BOTONES -->
            <div class="form-actions">
                <button type="submit" class="btn-main">
                    Guardar devolución
                </button>

                @Html.ActionLink("Volver", "Index", null, new { @class = "btn-secondary" })
            </div>
        }
    </div>

</div>