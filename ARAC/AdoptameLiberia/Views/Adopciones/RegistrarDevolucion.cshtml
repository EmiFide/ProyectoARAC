@model AdoptameLiberia.Models.ViewModel.RegistrarDevolucionVM

@{
    ViewBag.Title = "Registrar devolución";
}

<div class="container mt-4">
    <h2>Registrar devolución / adopción fallida</h2>

    <div class="alert alert-warning">
        @Model.AdopcionInfo
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.ID_Adopcion)

        <div class="form-group">
            @Html.LabelFor(m => m.Fecha_Devolucion)
            @Html.TextBoxFor(m => m.Fecha_Devolucion, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Motivo)
            @Html.TextAreaFor(m => m.Motivo, new { @class = "form-control", rows = 4 })
            @Html.ValidationMessageFor(m => m.Motivo, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Observacion)
            @Html.TextAreaFor(m => m.Observacion, new { @class = "form-control", rows = 3 })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Estado_Final_Animal)
            @Html.DropDownListFor(m => m.Estado_Final_Animal, (SelectList)ViewBag.EstadosFinales, "Seleccione", new { @class = "form-control" })
        </div>

        <button type="submit" class="btn btn-danger">Guardar devolución</button>
        @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary" })
    }
</div>
