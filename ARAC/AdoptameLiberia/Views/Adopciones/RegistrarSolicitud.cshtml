
@model AdoptameLiberia.Models.ViewModel.SolicitudAdopcionFormVM

@{
    ViewBag.Title = "Registrar solicitud";
}

<div class="container mt-4">
    <h2>Registrar solicitud de adopción</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.LabelFor(m => m.ID_Usuario)
                @Html.DropDownList("ID_Usuario", null, "Seleccione un usuario", new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.ID_Usuario, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.ID_Animal)
                @Html.DropDownList("ID_Animal", null, "Seleccione un animal", new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.ID_Animal, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Condiciones_Hogar)
                @Html.TextAreaFor(m => m.Condiciones_Hogar, new { @class = "form-control", rows = 3 })
                @Html.ValidationMessageFor(m => m.Condiciones_Hogar, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Motivo_Adopcion)
                @Html.TextAreaFor(m => m.Motivo_Adopcion, new { @class = "form-control", rows = 3 })
                @Html.ValidationMessageFor(m => m.Motivo_Adopcion, "", new { @class = "text-danger" })
            </div>

            <div class="form-group form-check">
                @Html.CheckBoxFor(m => m.Otros_Animales, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.Otros_Animales, new { @class = "form-check-label" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Detalle_Otros_Animales)
                @Html.TextBoxFor(m => m.Detalle_Otros_Animales, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Detalle_Otros_Animales, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">Guardar solicitud</button>
            @Html.ActionLink("Volver", "Solicitudes", null, new { @class = "btn btn-secondary" })
        </div>
    }
</div>