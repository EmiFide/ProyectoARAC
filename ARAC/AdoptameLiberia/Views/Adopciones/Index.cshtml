@model IEnumerable<AdoptameLiberia.Models.ViewModel.AdopcionResumenVM>

@{
    ViewBag.Title = "Adopciones";
}

<link href="@Url.Content("~/Content/estilos/Adopciones.css")" rel="stylesheet" />

<div class="adopciones-container">

    <!-- HEADER -->
    <div class="header-adopciones">
        <div>
            <h1> Adopciones registradas</h1>
            <p>Gestión y seguimiento de adopciones realizadas en el refugio</p>
        </div>

        <div class="acciones-header">
            @Html.ActionLink(" Ver solicitudes", "Solicitudes", null, new { @class = "btn-main" })
            @Html.ActionLink(" Reporte", "ReporteAdopciones", null, new { @class = "btn-secondary" })
        </div>
    </div>

    <!-- CARDS -->
    <div class="cards-grid">
        <div class="card-metric">
            <div class="icon"></div>
            <h2>@Model.Count()</h2>
            <span>Total adopciones</span>
        </div>

        <div class="card-metric">
            <div class="icon"></div>
            <h2>@Model.Count(x => x.Estado_Adopcion == "Activa")</h2>
            <span>Activas</span>
        </div>

        <div class="card-metric">
            <div class="icon"></div>
            <h2>@Model.Count(x => x.Estado_Adopcion == "Seguimiento")</h2>
            <span>En seguimiento</span>
        </div>

        <div class="card-metric">
            <div class="icon"></div>
            <h2>@Model.Count(x => x.Estado_Adopcion == "Devolución")</h2>
            <span>Devoluciones</span>
        </div>
    </div>

    <!-- ALERTAS -->
    @if (TempData["ok"] != null)
    {
        <div class="alert success"> @TempData["ok"]</div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert error"> @TempData["error"]</div>
    }

    <!-- TABLA -->
    <div class="tabla-card">

        <div class="tabla-header">
            <h3> Listado de adopciones</h3>
        </div>

        <table id="tablaAdopciones" class="tabla-moderna">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Usuario</th>
                    <th>Animal</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th>Seguimiento</th>
                    <th class="acciones-col">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="id">#@item.ID_Adopcion</td>

                        <td>
                            <div class="usuario">
                                <strong>@item.UsuarioNombre</strong>
                                <span>Solicitud #@item.ID_Solicitud</span>
                            </div>
                        </td>

                        <td>
                            <span class="animal"> @item.AnimalNombre</span>
                        </td>

                        <td>@item.Fecha_Adopcion.ToString("dd/MM/yyyy")</td>

                        <td>
                            <span class="badge @GetBadgeClass(item.Estado_Adopcion)">
                                @item.Estado_Adopcion
                            </span>
                        </td>

                        <td class="seguimiento">
                            @item.Seguimiento_Inicial
                        </td>

                        <td class="acciones">
                            @Html.ActionLink("Seguimiento", "RegistrarSeguimiento",
                                new { id = item.ID_Adopcion },
                                new { @class = "btn-icon success", title = "Seguimiento" })

                            @Html.ActionLink("Devolucion", "RegistrarDevolucion",
                                new { id = item.ID_Adopcion },
                                new { @class = "btn-icon danger", title = "Devolución" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

@functions{
    public string GetBadgeClass(string estado)
    {
        switch (estado)
        {
            case "Activa": return "badge-success";
            case "Seguimiento": return "badge-warning";
            case "Devolución": return "badge-danger";
            default: return "badge-default";
        }
    }
}


<script>
    $(document).ready(function () {
        $('#tablaAdopciones').DataTable({
            pageLength: 10,
            lengthChange: false,
            searching: false, // 👈 quitamos buscador
            info: true,
            paging: true,
            ordering: true,
            autoWidth: false,
            language: {
                info: "Mostrando _START_ a _END_ de _TOTAL_ adopciones",
                infoEmpty: "Mostrando 0 a 0 de 0",
                paginate: {
                    previous: "Anterior",
                    next: "Siguiente"
                },
                zeroRecords: "No se encontraron datos"
            },
            columnDefs: [
                { orderable: false, targets: 6 } // Acciones
            ]
        });
    });
</script>