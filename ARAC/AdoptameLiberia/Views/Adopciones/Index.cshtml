@model IEnumerable<AdoptameLiberia.Models.ViewModel.AdopcionResumenVM>

@{
    ViewBag.Title = "Adopciones";
}

<div class="container mt-4">
    <h2>Adopciones registradas</h2>

    @if (TempData["ok"] != null)
    {
        <div class="alert alert-success">@TempData["ok"]</div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <p>
        @Html.ActionLink("Ver solicitudes", "Solicitudes", null, new { @class = "btn btn-primary" })
        @Html.ActionLink("Reporte de adopciones", "ReporteAdopciones", null, new { @class = "btn btn-info" })
    </p>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID Adopción</th>
                <th>Solicitud</th>
                <th>Usuario</th>
                <th>Animal</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Seguimiento inicial</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ID_Adopcion</td>
                    <td>@item.ID_Solicitud</td>
                    <td>@item.UsuarioNombre</td>
                    <td>@item.AnimalNombre</td>
                    <td>@item.Fecha_Adopcion.ToString("dd/MM/yyyy")</td>
                    <td>@item.Estado_Adopcion</td>
                    <td>@item.Seguimiento_Inicial</td>
                    <td>
                        @Html.ActionLink("Seguimiento", "RegistrarSeguimiento", new { id = item.ID_Adopcion }, new { @class = "btn btn-sm btn-success" })
                        @Html.Raw(" ")
                        @Html.ActionLink("Devolución", "RegistrarDevolucion", new { id = item.ID_Adopcion }, new { @class = "btn btn-sm btn-danger" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>