@model AdoptameLiberia.Models.ViewModel.AsignarAnimalVM

@{
    ViewBag.Title = "Asignar animal";
}

<div class="container mt-4">
    <h2>Asignar animal a solicitud aprobada</h2>

    <div class="alert alert-info">
        @Model.SolicitudInfo
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.ID_Solicitud)

        <div class="form-group">
            @Html.LabelFor(m => m.ID_Animal)
            @Html.DropDownList("ID_Animal", null, "Seleccione un animal", new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.ID_Animal, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Fecha_Adopcion)
            @Html.TextBoxFor(m => m.Fecha_Adopcion, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
            @Html.ValidationMessageFor(m => m.Fecha_Adopcion, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Estado_Adopcion)
            @Html.TextBoxFor(m => m.Estado_Adopcion, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Estado_Adopcion, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Seguimiento_Inicial)
            @Html.TextAreaFor(m => m.Seguimiento_Inicial, new { @class = "form-control", rows = 3 })
        </div>

        <button type="submit" class="btn btn-success">Registrar adopción</button>
        @Html.ActionLink("Volver", "Solicitudes", null, new { @class = "btn btn-secondary" })
    }
</div>
