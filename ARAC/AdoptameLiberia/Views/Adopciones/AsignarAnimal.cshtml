@model AdoptameLiberia.Models.ViewModel.AsignarAnimalVM

@{
    ViewBag.Title = "Asignar animal";
}

@section Styles {
    <link href="~/Content/estilos/Asignar.css" rel="stylesheet" />
}

<div class="asignar-container">

    <!-- HERO -->
    <div class="asignar-hero">
        <h1>Asignar animal</h1>
        <p>Completa la información para registrar la adopción</p>
    </div>

    <!-- INFO SOLICITUD -->
    <div class="info-box">
        @Model.SolicitudInfo
    </div>

    <!-- FORM -->
    <div class="asignar-card">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.ID_Solicitud)

            <div class="form-grid">

                <div class="form-group-modern">
                    <label>Animal</label>
                    @Html.DropDownList("ID_Animal", null, "Seleccione un animal", new { @class = "select-modern" })
                    @Html.ValidationMessageFor(m => m.ID_Animal, "", new { @class = "text-danger" })
                </div>

                <div class="form-group-modern">
                    <label>Fecha de adopción</label>
                    @Html.TextBoxFor(m => m.Fecha_Adopcion, "{0:yyyy-MM-ddTHH:mm}", new { @class = "input-modern", type = "datetime-local" })
                    @Html.ValidationMessageFor(m => m.Fecha_Adopcion, "", new { @class = "text-danger" })
                </div>

                <div class="form-group-modern">
                    <label>Estado</label>
                    @Html.TextBoxFor(m => m.Estado_Adopcion, new { @class = "input-modern" })
                    @Html.ValidationMessageFor(m => m.Estado_Adopcion, "", new { @class = "text-danger" })
                </div>

            </div>

            <div class="form-group-modern">
                <label>Seguimiento inicial</label>
                @Html.TextAreaFor(m => m.Seguimiento_Inicial, new { @class = "textarea-modern", rows = 3 })
            </div>

            <div class="acciones">
                <button type="submit" class="btn-guardar">Registrar adopción</button>
                @Html.ActionLink("Volver", "Solicitudes", null, new { @class = "btn-volver" })
            </div>
        }
    </div>

</div>