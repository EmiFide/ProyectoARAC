@model AdoptameLiberia.Models.Educativo.VM.EducativoFiltro
@{
    ViewBag.Title = "Bienestar Animal";
}

<h2>Módulo Educativo</h2>
<p class="text-muted">Consulta recursos de bienestar animal clasificados por tipo y tema.</p>

<div class="panel panel-default">
    <div class="panel-heading"><strong>Filtros</strong></div>
    <div class="panel-body">
        @using (Html.BeginForm("Index", "Educativo", FormMethod.Get, new { @class = "form-horizontal" }))
        {
            <div class="form-group">
                <label class="control-label col-md-2">Tipo</label>
                <div class="col-md-3">
                    @Html.DropDownListFor(m => m.TipoContenido,
                        new SelectList(Model.Tipos, "Value", "Text", Model.TipoContenido),
                        "Todos",
                        new { @class = "form-control" })
                </div>

                <label class="control-label col-md-2">Tema</label>
                <div class="col-md-3">
                    @Html.DropDownListFor(m => m.Tema,
                        new SelectList(Model.Temas, "Value", "Text", Model.Tema),
                        "Todos",
                        new { @class = "form-control" })
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">Filtrar</button>
                </div>
            </div>

            <div class="form-group">
                <label class="control-label col-md-2">Buscar</label>
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.TextoBusqueda,
                        new { @class = "form-control", placeholder = "Título o descripción" })
                </div>
                <div class="col-md-4">
                    @Html.ActionLink("Limpiar", "Index", "Educativo", null, new { @class = "btn btn-default" })
                </div>
            </div>
        }
    </div>
</div>

@if (!Model.Resultados.Any())
{
    <div class="alert alert-info">No hay recursos disponibles con esos filtros.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Título</th>
                <th>Tipo</th>
                <th>Tema</th>
                <th>Descripción</th>
                <th style="width:120px;">Acción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Resultados)
            {
                <tr>
                    <td>@item.Titulo</td>
                    <td>@item.TipoContenido</td>
                    <td>@item.Tema</td>
                    <td>@item.Descripcion</td>
                    <td>
                        @Html.ActionLink("Ver", "Detalle", "Educativo", new { id = item.IdContenidoEducativo }, new { @class = "btn btn-info btn-xs" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
}