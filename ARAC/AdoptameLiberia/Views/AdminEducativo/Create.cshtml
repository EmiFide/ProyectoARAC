@model AdoptameLiberia.Models.Educativo.VM.ContenidoEducativoForm
@{
    ViewBag.Title = "Nuevo recurso";
}

<h2>Nuevo recurso educativo</h2>

@using (Html.BeginForm("Create", "AdminEducativo", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    @Html.Partial("_Form", Model)

    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <button type="submit" class="btn btn-primary">Guardar</button>
            @Html.ActionLink("Cancelar", "Index", "AdminEducativo", null, new { @class = "btn btn-default" })
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}