@model AdoptameLiberia.Models.Educativo.VM.ContenidoEducativoForm

<div class="form-group">
    @Html.LabelFor(m => m.Titulo, new { @class = "control-label col-md-2" })
    <div class="col-md-10">
        @Html.TextBoxFor(m => m.Titulo, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Titulo, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    @Html.LabelFor(m => m.Descripcion, new { @class = "control-label col-md-2" })
    <div class="col-md-10">
        @Html.TextAreaFor(m => m.Descripcion, 5, 40, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    @Html.LabelFor(m => m.TipoContenido, new { @class = "control-label col-md-2" })
    <div class="col-md-4">
        @Html.DropDownListFor(m => m.TipoContenido,
            new SelectList(Model.Tipos, "Value", "Text", Model.TipoContenido),
            "Seleccione",
            new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.TipoContenido, "", new { @class = "text-danger" })
    </div>

    @Html.LabelFor(m => m.Tema, new { @class = "control-label col-md-2" })
    <div class="col-md-4">
        @Html.DropDownListFor(m => m.Tema,
            new SelectList(Model.Temas, "Value", "Text", Model.Tema),
            "Seleccione",
            new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Tema, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    @Html.LabelFor(m => m.UrlContenido, new { @class = "control-label col-md-2" })
    <div class="col-md-10">
        @Html.TextBoxFor(m => m.UrlContenido, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.UrlContenido, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    @Html.LabelFor(m => m.Archivo, new { @class = "control-label col-md-2" })
    <div class="col-md-10">
        <input type="file" name="Archivo" class="form-control" />
        @if (!string.IsNullOrWhiteSpace(Model.RutaArchivoActual))
        {
            <p class="help-block">
                Archivo actual:
                <a href="@Url.Content(Model.RutaArchivoActual)" target="_blank">Ver archivo</a>
            </p>
        }
    </div>
</div>

<div class="form-group">
    @Html.LabelFor(m => m.Activo, new { @class = "control-label col-md-2" })
    <div class="col-md-10">
        <div class="checkbox">
            <label>
                @Html.CheckBoxFor(m => m.Activo) Activo
            </label>
        </div>
    </div>
</div>