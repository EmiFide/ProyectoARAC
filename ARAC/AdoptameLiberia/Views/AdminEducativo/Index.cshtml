@model IEnumerable<AdoptameLiberia.Models.Educativo.ContenidoEducativo>
@{
    ViewBag.Title = "Administrar contenido educativo";
}

<h2>Administración de Contenido Educativo</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<p>
    @Html.ActionLink("Nuevo recurso", "Create", "AdminEducativo", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Título</th>
            <th>Tipo</th>
            <th>Tema</th>
            <th>Activo</th>
            <th>Fecha creación</th>
            <th style="width:180px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Titulo</td>
                <td>@item.TipoContenido</td>
                <td>@item.Tema</td>
                <td>@(item.Activo ? "Sí" : "No")</td>
                <td>@item.FechaCreacion.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    @Html.ActionLink("Editar", "Edit", "AdminEducativo", new { id = item.IdContenidoEducativo }, new { @class = "btn btn-warning btn-xs" })
                    @Html.ActionLink("Eliminar", "Delete", "AdminEducativo", new { id = item.IdContenidoEducativo }, new { @class = "btn btn-danger btn-xs" })
                </td>
            </tr>
        }
    </tbody>
</table>