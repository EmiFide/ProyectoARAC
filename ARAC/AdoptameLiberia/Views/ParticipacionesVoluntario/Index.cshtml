@model IEnumerable<AdoptameLiberia.Models.Voluntariado.ParticipacionVoluntario>
@using System.Linq

@{
    ViewBag.Title = "Participación de voluntarios";
}

@section styles{
    <link href="~/Content/estilos/Voluntarios.css" rel="stylesheet" />
}

@functions{
    public bool EsNoAsistio(string observaciones)
    {
        return !string.IsNullOrWhiteSpace(observaciones) && observaciones.Contains("[NO_ASISTIO]");
    }

    public string LimpiarObservacion(string observaciones)
    {
        if (string.IsNullOrWhiteSpace(observaciones))
        {
            return "Sin observaciones";
        }

        return observaciones.Replace("[NO_ASISTIO]", "").Trim();
    }
}

<div class="vol-shell">
    <section class="vol-section">
        <div class="vol-section-header">
            <div>
                <h2 class="vol-section-title">Asignaciones de voluntariado</h2>
                <p class="vol-section-subtitle">
                    Consulta las relaciones existentes entre voluntarios y tareas y marca su asistencia.
                </p>
            </div>

            <div class="vol-toolbar-right">
                @Html.ActionLink("Nueva asignación", "Create", null, new { @class = "vol-btn" })
                @Html.ActionLink("Volver al módulo", "Index", "Voluntarios", null, new { @class = "vol-btn-outline" })
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="vol-table-wrap">
                <table class="vol-table">
                    <thead>
                        <tr>
                            <th>Voluntario</th>
                            <th>Tarea</th>
                            <th>Asistencia</th>
                            <th>Observaciones</th>
                            <th style="width:220px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            bool noAsistio = EsNoAsistio(item.Observaciones);

                            <tr>
                                <td class="vol-person-cell">
                                    <strong>@item.Voluntario.Nombre @item.Voluntario.Apellido1</strong>
                                    <span>@item.Voluntario.Correo</span>
                                </td>

                                <td class="vol-task-cell">
                                    <strong>@item.Tarea.Titulo</strong>
                                    <span>@item.Tarea.Lugar</span>
                                </td>

                                <td>
                                    @if (item.Asistio)
                                    {
                                        <span class="vol-badge vol-badge-active">Sí asistió</span>
                                    }
                                    else if (noAsistio)
                                    {
                                        <span class="vol-badge vol-badge-inactive">No asistió</span>
                                    }
                                    else
                                    {
                                        <span class="vol-badge vol-badge-pending">Pendiente</span>
                                    }
                                </td>

                                <td>@LimpiarObservacion(item.Observaciones)</td>

                                <td>
                                    <div class="vol-action-inline">
                                        @using (Html.BeginForm("MarcarAsistencia", "ParticipacionesVoluntario", FormMethod.Post, new { @class = "vol-inline-form" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            @Html.Hidden("idParticipacion", item.ID_Participacion)
                                            @Html.Hidden("asistio", true)
                                            @Html.Hidden("returnUrl", Request.RawUrl)
                                            <button type="submit" class="vol-btn-activar">Asistió</button>
                                        }

                                        @using (Html.BeginForm("MarcarAsistencia", "ParticipacionesVoluntario", FormMethod.Post, new { @class = "vol-inline-form" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            @Html.Hidden("idParticipacion", item.ID_Participacion)
                                            @Html.Hidden("asistio", false)
                                            @Html.Hidden("returnUrl", Request.RawUrl)
                                            <button type="submit" class="vol-btn-desactivar">No asistió</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="vol-empty">
                <strong>No hay asignaciones registradas.</strong>
                Cuando relaciones voluntarios con tareas, se mostrarán aquí.
            </div>
        }
    </section>
</div>