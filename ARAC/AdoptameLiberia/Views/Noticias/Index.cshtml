@model IEnumerable<AdoptameLiberia.Models.Noticias.Noticia>

<h2>Noticias</h2>

<!-- 🔥 BOTÓN AQUÍ -->
<p>
    @Html.ActionLink("Nueva Noticia", "Create", "Noticias", null, new { @class = "btn btn-success" })
</p>

@if (!Model.Any())
{
    <p>No hay noticias disponibles.</p>
}
else
{
    foreach (var item in Model)
    {
        <div class="card mb-3 p-3">
            <h4>@item.Titulo</h4>
            <p>@item.Contenido</p>
            <small>@(item.Fecha_Publicacion?.ToShortDateString() ?? "Sin fecha")</small>
        </div>
    }
}