<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - ARAC Refugio</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <link href="~/Content/estilos/Layout.css" rel="stylesheet" />

    @RenderSection("styles", required: false)
    @Scripts.Render("~/bundles/modernizr")
</head>
<body class="layout-body">

    <a href="@(Request.IsAuthenticated ? Url.Action("Index", "Favoritos") : Url.Action("Login", "Account", new { returnUrl = Url.Action("Index", "Favoritos") }))"
       class="favoritos-float"
       title="Favoritos"
       aria-label="Favoritos">
        <span class="favoritos-float-icon">❤</span>
        <span class="favoritos-float-text">Favoritos</span>
    </a>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-arac shadow-sm">
        <div class="container-fluid navbar-arac-container">

            <a href="@Url.Action("Index", "Home")" class="navbar-brand navbar-brand-arac">
                🐾 ARAC Refugio
            </a>

            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Mostrar menú">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">

                <ul class="navbar-nav navbar-main-links">
                    <li class="nav-item">
                        @Html.ActionLink("Mascotas", "Catalogo", "Animal", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Campañas", "Index", "Campanias", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Bienestar Animal", "About", "Home", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Donaciones", "Index", "Donaciones", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Ser voluntario", "Create", "SolicitudesVoluntariado", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Comunidad", "Index", "Comunidad", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Reporte Financiero", "Dashboard", "Reportes", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Noticias", "Index", "Noticia", null, new { @class = "nav-link" })
                    </li>

                    @if (Request.IsAuthenticated && User.IsInRole("Administrador"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="adminMenu" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                Administración
                            </a>
                            <div class="dropdown-menu dropdown-menu-right shadow" aria-labelledby="adminMenu">
                                <h6 class="dropdown-header">Gestión</h6>
                                @Html.ActionLink("Inventario", "Index", "Inventario", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Campañas", "Index", "Campanias", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Registrar Mascota", "Crear", "Animal", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Voluntarios", "Index", "Voluntarios", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Comunidad", "Index", "Comunidad", null, new { @class = "dropdown-item" })

                                <div class="dropdown-divider"></div>

                                <h6 class="dropdown-header">Administración</h6>
                                @Html.ActionLink("Usuarios", "Index", "AdminUsers", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Roles y permisos", "Index", "Roles", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Categorías", "Index", "Categorias", null, new { @class = "dropdown-item" })
                                @Html.ActionLink("Gastos", "Index", "Gastos", null, new { @class = "dropdown-item" })
                            </div>
                        </li>
                    }
                </ul>

                <div class="navbar-auth-links">
                    @Html.Partial("_LoginPartial")
                </div>
            </div>
        </div>
    </nav>

    <div class="main-container">
        @RenderBody()
    </div>

    <footer class="footer-arac">
        <div class="container text-center">
            <h5 class="footer-title">Síguenos en:</h5>

            <div class="social-icons mb-3">
                <span>📘</span>
                <span>📸</span>
                <span>▶️</span>
                <span>🐦</span>
            </div>

            <p>📞 8755-5475</p>
            <p>✉️ administracion@ARAC_Refugio.org</p>

            <hr />

            <p>© @DateTime.Now.Year - ARAC Refugio</p>
        </div>

        <img src="~/Content/img/perro.png" class="dog-left" alt="Decoración izquierda" />
        <img src="~/Content/img/perro.png" class="dog-right" alt="Decoración derecha" />
    </footer>

    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>