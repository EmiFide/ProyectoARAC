<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - ARAC Refugio</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />

    @Styles.Render("~/Content/css")
    <link href="~/Content/animal-theme.css" rel="stylesheet" />

    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("🐾 ARAC Refugio", "Index", "Home", null, new { @class = "navbar-brand" })

            <button type="button" class="navbar-toggler"
                    data-toggle="collapse"
                    data-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav flex-grow-1">
                    <li>@Html.ActionLink("Inicio", "Index", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Acerca de", "About", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Contacto", "Contact", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Donaciones", "Index", "Donaciones", null, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Catálogo Mascotas", "Catalogo", "Animal", null, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Comunidad", "Index", "Comunidad", null, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Voluntariado", "Create", "SolicitudesVoluntariado", null, new { @class = "nav-link" })</li>
                    @if (Request.IsAuthenticated && User.IsInRole("Administrador"))
                    {
                        <li>@Html.ActionLink("Inventario", "Index", "Inventario", null, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Campañas", "Index", "Campanias", null, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Registrar Mascota", "Crear", "Animal", null, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Usuarios", "Index", "AdminUsers", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Roles y permisos", "Index", "Roles", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Voluntarios", "Index", "Voluntarios", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Tareas Voluntariado", "Index", "TareasVoluntariado", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Participaciones", "Index", "ParticipacionesVoluntario", new { area = "" }, new { @class = "nav-link" })</li>
                    }

                    <li class="nav-item">
                        @Html.ActionLink("Tipos", "Index", "TipoAnimal", null, new { @class = "nav-link" })
                    </li>

                </ul>

                @Html.Partial("_LoginPartial")
            </div>
        </div>
    </nav>

    <!-- CONTENIDO -->
    <div class="container mt-4">
        @RenderBody()

        <hr />

        <footer class="text-center mt-4 mb-3">
            <p style="color:#6D4C41;">
                🐾 © @DateTime.Now.Year - ARAC Refugio
            </p>
        </footer>
    </div>

    <!-- SCRIPTS -->
    @Scripts.Render("~/bundles/jquery")

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)

</body>
</html>