<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - ARAC Refugio</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <link href="~/Content/estilos/Layout.css" rel="stylesheet" />

    @RenderSection("styles", required: false)
    @Scripts.Render("~/bundles/modernizr")
</head>
<body class="arac-body">

    <a href="@(Request.IsAuthenticated ? Url.Action("Index", "Favoritos") : Url.Action("Login", "Account", new { returnUrl = Url.Action("Index", "Favoritos") }))"
       class="favoritos-float"
       title="Favoritos"
       aria-label="Favoritos">
        <span class="favoritos-float-icon">❤</span>
        <span class="favoritos-float-text">Favoritos</span>
    </a>

    <header class="site-header-wrap">
        <nav class="navbar navbar-expand-xl navbar-light arac-navbar">
            <div class="container-fluid arac-navbar-container">
                <a href="@Url.Action("Index", "Home")" class="navbar-brand arac-brand">
                    <span class="arac-brand-mark"></span>
                    <span class="arac-brand-text">ARAC Refugio</span>
                </a>

                <button class="navbar-toggler arac-toggler" type="button" data-toggle="collapse" data-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Mostrar menú">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav arac-main-nav mx-auto">
                        <li class="nav-item">@Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Mascotas", "Catalogo", "Animal", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Campañas", "Index", "Campanias", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Donaciones", "Index", "Donaciones", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Comunidad", "Index", "Comunidad", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Noticias", "Index", "Noticia", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Voluntariado", "Create", "SolicitudesVoluntariado", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Bienestar Animal", "About", "Home", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("Reporte Financiero", "Dashboard", "Reportes", null, new { @class = "nav-link" })</li>

                        @if (Request.IsAuthenticated && User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminMenu" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    Administración
                                </a>
                                <div class="dropdown-menu dropdown-menu-right arac-dropdown shadow-sm" aria-labelledby="adminMenu">
                                    <h6 class="dropdown-header">Gestión</h6>
                                    @Html.ActionLink("Inventario", "Index", "Inventario", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Campañas", "Index", "Campanias", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Registrar Mascota", "Crear", "Animal", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Voluntarios", "Index", "Voluntarios", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Comunidad", "Index", "Comunidad", null, new { @class = "dropdown-item" })

                                    <div class="dropdown-divider"></div>

                                    <h6 class="dropdown-header">Administración</h6>
                                    @Html.ActionLink("Usuarios", "Index", "AdminUsers", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Roles y permisos", "Index", "Roles", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Categorías", "Index", "Categorias", null, new { @class = "dropdown-item" })
                                    @Html.ActionLink("Gastos", "Index", "Gastos", null, new { @class = "dropdown-item" })
                                </div>
                            </li>
                        }
                    </ul>

                    <div class="arac-auth-links">
                        @Html.Partial("_LoginPartial")
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="main-container arac-main-container">
        @RenderBody()
    </main>

    <footer class="arac-footer">
        <div class="container arac-footer-container">
            <div class="arac-footer-top">
                <div class="arac-footer-brand">
                    <div class="arac-footer-logo">
                        <span class="arac-brand-mark"></span>
                        <strong>ARAC Refugio</strong>
                    </div>
                    <p>
                        Plataforma para adopción, campañas, donaciones y participación comunitaria,
                        con una experiencia visual más moderna y ordenada.
                    </p>
                </div>

                <div class="arac-footer-subscribe">
                    <h5>Mantente informado</h5>
                    <p>Explora noticias, campañas activas y nuevas oportunidades para ayudar.</p>
                    <div class="arac-footer-actions">
                        <a href="@Url.Action("Index", "Campanias")" class="arac-footer-btn primary">Ver campañas</a>
                        <a href="@Url.Action("Index", "Donaciones")" class="arac-footer-btn secondary">Donar</a>
                    </div>
                </div>
            </div>

            <div class="arac-footer-bottom">
                <div>
                    <span>Contacto:</span>
                    <span> administracion@ARAC_Refugio.org</span>
                    <span class="mx-2">|</span>
                    <span>8755-5475</span>
                </div>
                <div>© @DateTime.Now.Year - ARAC Refugio</div>
            </div>
        </div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>
