<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - ARAC Refugio</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />

    <!-- CSS GLOBAL -->
    <link href="~/Content/estilos/Layout.css" rel="stylesheet" />

    @RenderSection("styles", required: false)

    @Scripts.Render("~/bundles/modernizr")
</head>

<body class="layout-body">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-arac shadow-sm">
        <div class="container">
            @Html.ActionLink("🐾 ARAC Refugio", "Index", "Home", null, new { @class = "navbar-brand" })

            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">

                <ul class="navbar-nav mx-auto">
                    <li>@Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Adopta", "Catalogo", "Animal", null, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Nosotros", "About", "Home", null, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Consultas", "Index", "Consultas", null, new { @class = "nav-link" })</li>
                    <li>@Html.ActionLink("Donaciones", "Index", "Donaciones", null, new { @class = "nav-link" })</li>
                </ul>

                <div class="d-flex align-items-center">
                    <a href="@Url.Action("Create","Donaciones")" class="btn btn-light btn-sm mr-2">
                        Apóyanos
                    </a>

                    @Html.Partial("_LoginPartial")
                </div>

            </div>
        </div>
    </nav>

    <!-- CONTENIDO -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer-arac">
        <div class="container text-center">

            <h5 class="footer-title">Síguenos en:</h5>

            <div class="social-icons mb-3">
                <span>📘</span>
                <span>📸</span>
                <span>▶️</span>
                <span>🐦</span>
            </div>

            <p>📞 8755-5475</p>
            <p>✉️ administracion@ARAC_Refugio.org</p>

            <hr />

            <p>© @DateTime.Now.Year - ARAC Refugio</p>

        </div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)

    <img src="~/Content/img/perro.png" class="dog-left" />
    <img src="~/Content/img/perro.png" class="dog-right" />
</body>
</html>