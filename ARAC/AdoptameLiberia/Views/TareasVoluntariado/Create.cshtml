@model AdoptameLiberia.Models.Voluntariado.TareaVoluntariado

@{
    ViewBag.Title = "Crear tarea";
}

@section styles{
    <link href="~/Content/estilos/Voluntarios.css" rel="stylesheet" />
}

<div class="vol-shell">
    <section class="vol-form-card">
        <div class="vol-section-header">
            <div>
                <h2 class="vol-section-title">Crear tarea de voluntariado</h2>
                <p class="vol-section-subtitle">
                    Registra una nueva actividad para asignar voluntarios dentro del módulo.
                </p>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="vol-form-grid">
                <div class="vol-group full">
                    @Html.LabelFor(model => model.Titulo)
                    @Html.TextBoxFor(model => model.Titulo, new { @class = "form-control", placeholder = "Título de la tarea" })
                    @Html.ValidationMessageFor(model => model.Titulo, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(model => model.Descripcion)
                    @Html.TextAreaFor(model => model.Descripcion, new { @class = "form-control", rows = 4, placeholder = "Describe en qué consiste la tarea..." })
                    @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(model => model.Fecha)
                    @Html.TextBoxFor(model => model.Fecha, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(model => model.Fecha, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(model => model.Hora)
                    @Html.TextBoxFor(model => model.Hora, "{0:hh\\:mm}", new { @class = "form-control", type = "time" })
                    @Html.ValidationMessageFor(model => model.Hora, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(model => model.Lugar)
                    @Html.TextBoxFor(model => model.Lugar, new { @class = "form-control", placeholder = "Lugar o punto de encuentro" })
                    @Html.ValidationMessageFor(model => model.Lugar, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    <div class="vol-switch-card">
                        <strong>Estado de la tarea</strong>
                        <label class="vol-check-row">
                            @Html.CheckBoxFor(model => model.Estado)
                            <span>Crear como tarea activa</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="vol-form-actions">
                <button type="submit" class="vol-btn">Guardar tarea</button>
                @Html.ActionLink("Volver", "Index", "Voluntarios", null, new { @class = "vol-btn-outline" })
            </div>
        }
    </section>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}