@model AdoptameLiberia.Models.Voluntariado.TareaVoluntariado

@{
    ViewBag.Title = "Eliminar tarea";
}

@section styles{
    <link href="~/Content/estilos/Voluntarios.css" rel="stylesheet" />
}

<div class="vol-shell">
    <section class="vol-detail-card">
        <div class="vol-section-header">
            <div>
                <h2 class="vol-section-title">Eliminar tarea</h2>
                <p class="vol-section-subtitle">
                    Vas a eliminar esta tarea junto con sus asignaciones relacionadas. Revisa bien antes de continuar.
                </p>
            </div>
        </div>

        <div class="vol-detail-grid">
            <div class="vol-detail-item">
                <strong>Título</strong>
                <span>@Model.Titulo</span>
            </div>

            <div class="vol-detail-item">
                <strong>Fecha</strong>
                <span>@Model.Fecha.ToShortDateString()</span>
            </div>

            <div class="vol-detail-item">
                <strong>Hora</strong>
                <span>@(Model.Hora.HasValue ? Model.Hora.Value.ToString(@"hh\:mm") : "Sin hora")</span>
            </div>

            <div class="vol-detail-item">
                <strong>Lugar</strong>
                <span>@Model.Lugar</span>
            </div>

            <div class="vol-detail-item full">
                <strong>Descripción</strong>
                <p>@Model.Descripcion</p>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="vol-form-actions">
                <button type="submit" class="vol-btn-danger">Eliminar tarea</button>
                @Html.ActionLink("Cancelar", "Index", "Voluntarios", null, new { @class = "vol-btn-outline" })
            </div>
        }
    </section>
</div>