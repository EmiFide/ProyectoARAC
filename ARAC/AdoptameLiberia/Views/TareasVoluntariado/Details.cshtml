@model AdoptameLiberia.Models.Voluntariado.TareaVoluntariado
@using System.Collections.Generic
@using System.Linq
@using AdoptameLiberia.Models.Voluntariado

@{
    ViewBag.Title = "Detalle de tarea";
    var voluntariosAsignados = ViewBag.VoluntariosAsignados as List<ParticipacionVoluntario>;
}

@section styles{
    <link href="~/Content/estilos/Voluntarios.css" rel="stylesheet" />
}

@functions{
    public bool EsNoAsistio(string observaciones)
    {
        return !string.IsNullOrWhiteSpace(observaciones) && observaciones.Contains("[NO_ASISTIO]");
    }

    public string LimpiarObservacion(string observaciones)
    {
        if (string.IsNullOrWhiteSpace(observaciones))
        {
            return "Sin observaciones";
        }

        return observaciones.Replace("[NO_ASISTIO]", "").Trim();
    }
}

<div class="vol-shell">
    <section class="vol-detail-card">
        <div class="vol-section-header">
            <div>
                <h2 class="vol-section-title">Detalle de la tarea</h2>
                <p class="vol-section-subtitle">
                    Consulta la información completa y los voluntarios vinculados a esta actividad.
                </p>
            </div>
        </div>

        <div class="vol-detail-grid">
            <div class="vol-detail-item">
                <strong>Título</strong>
                <span>@Model.Titulo</span>
            </div>

            <div class="vol-detail-item">
                <strong>Estado</strong>
                @if (Model.Estado)
                {
                    <span class="vol-badge vol-badge-active">Activa</span>
                }
                else
                {
                    <span class="vol-badge vol-badge-inactive">Inactiva</span>
                }
            </div>

            <div class="vol-detail-item">
                <strong>Fecha</strong>
                <span>@Model.Fecha.ToShortDateString()</span>
            </div>

            <div class="vol-detail-item">
                <strong>Hora</strong>
                <span>@(Model.Hora.HasValue ? Model.Hora.Value.ToString(@"hh\:mm") : "Sin hora registrada")</span>
            </div>

            <div class="vol-detail-item full">
                <strong>Lugar</strong>
                <span>@Model.Lugar</span>
            </div>

            <div class="vol-detail-item full">
                <strong>Descripción</strong>
                <p>@Model.Descripcion</p>
            </div>
        </div>

        <div style="margin-top:26px;">
            <div class="vol-section-header">
                <div>
                    <h2 class="vol-section-title" style="font-size:1.3rem;">Voluntarios asignados</h2>
                    <p class="vol-section-subtitle">Listado actual de participantes relacionados con esta tarea.</p>
                </div>
            </div>

            @if (voluntariosAsignados != null && voluntariosAsignados.Any())
            {
                <ul class="vol-list-clean">
                    @foreach (var item in voluntariosAsignados)
                    {
                        var nombreCompleto = (item.Voluntario.Nombre + " " + item.Voluntario.Apellido1 + " " + item.Voluntario.Apellido2).Trim();
                        bool noAsistio = EsNoAsistio(item.Observaciones);

                        <li>
                            <strong style="display:block; color:#1c2d44; margin-bottom:8px;">@nombreCompleto</strong>

                            <div style="color:#56667a; line-height:1.8; margin-bottom:14px;">
                                <div><strong style="display:inline; margin:0;">Correo:</strong> @item.Voluntario.Correo</div>
                                <div><strong style="display:inline; margin:0;">Teléfono:</strong> @item.Voluntario.Telefono</div>
                                <div>
                                    <strong style="display:inline; margin:0;">Asistencia:</strong>
                                    @if (item.Asistio)
                                    {
                                        <span class="vol-badge vol-badge-active">Sí asistió</span>
                                    }
                                    else if (noAsistio)
                                    {
                                        <span class="vol-badge vol-badge-inactive">No asistió</span>
                                    }
                                    else
                                    {
                                        <span class="vol-badge vol-badge-pending">Pendiente</span>
                                    }
                                </div>
                                <div><strong style="display:inline; margin:0;">Observaciones:</strong> @LimpiarObservacion(item.Observaciones)</div>
                            </div>

                            <div class="vol-action-inline">
                                @using (Html.BeginForm("MarcarAsistencia", "ParticipacionesVoluntario", FormMethod.Post, new { @class = "vol-inline-form" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("idParticipacion", item.ID_Participacion)
                                    @Html.Hidden("asistio", true)
                                    @Html.Hidden("returnUrl", Request.RawUrl)
                                    <button type="submit" class="vol-btn-activar">Asistió</button>
                                }

                                @using (Html.BeginForm("MarcarAsistencia", "ParticipacionesVoluntario", FormMethod.Post, new { @class = "vol-inline-form" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("idParticipacion", item.ID_Participacion)
                                    @Html.Hidden("asistio", false)
                                    @Html.Hidden("returnUrl", Request.RawUrl)
                                    <button type="submit" class="vol-btn-desactivar">No asistió</button>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="vol-empty">
                    <strong>Esta tarea todavía no tiene voluntarios asignados.</strong>
                    Cuando realices una asignación, aparecerá aquí.
                </div>
            }
        </div>

        <div class="vol-form-actions">
            @Html.ActionLink("Editar", "Edit", new { id = Model.ID_Tarea }, new { @class = "vol-btn" })
            @Html.ActionLink("Volver", "Index", "Voluntarios", null, new { @class = "vol-btn-outline" })
        </div>
    </section>
</div>