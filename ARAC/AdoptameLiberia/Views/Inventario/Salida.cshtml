@model AdoptameLiberia.Models.Inventario.MovimientoSalida

@{
    ViewBag.Title = "Registrar salida";
}

@section styles{
    <link href="~/Content/estilos/Inventario.css" rel="stylesheet" />
}

<div class="inventory-shell">
    <section class="inventory-hero inventory-hero-danger">
        <div class="inventory-hero-content">
            <span class="inventory-kicker inventory-kicker-danger">ARAC · SALIDA DE INVENTARIO</span>
            <h1>Registrar salida</h1>
            <p>
                Registra el uso, entrega o consumo de unidades del artículo seleccionado
                de forma clara y controlada.
            </p>
        </div>
    </section>

    <section class="inventory-card">
        <div class="inventory-card-head">
            <div>
                <h2>Detalle del movimiento</h2>
                <p>Completa la información para descontar correctamente las unidades del inventario.</p>
            </div>
        </div>

        <div class="inventory-highlight inventory-highlight-danger">
            Artículo seleccionado: <strong>@Model.NombreItem</strong>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.IdItemInventario)
            @Html.HiddenFor(m => m.NombreItem)
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="inventory-form">
                <div class="inventory-group">
                    @Html.LabelFor(m => m.Cantidad)
                    @Html.TextBoxFor(m => m.Cantidad, new { @class = "form-control", type = "number", min = "1", placeholder = "Cantidad a retirar" })
                    @Html.ValidationMessageFor(m => m.Cantidad, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group">
                    @Html.LabelFor(m => m.Destinatario, "Destino o uso")
                    @Html.TextBoxFor(m => m.Destinatario, new { @class = "form-control", placeholder = "Ej: atención veterinaria, refugio, adopción, limpieza" })
                    @Html.ValidationMessageFor(m => m.Destinatario, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group full">
                    @Html.LabelFor(m => m.Motivo)
                    @Html.TextBoxFor(m => m.Motivo, new { @class = "form-control", placeholder = "Ej: consumo interno, entrega, uso médico, ajuste operativo" })
                    @Html.ValidationMessageFor(m => m.Motivo, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="inventory-form-actions">
                <button type="submit" class="inventory-btn-danger">Guardar salida</button>
                @Html.ActionLink("Volver al inventario", "Index", "Inventario", null, new { @class = "inventory-btn-outline" })
            </div>
        }
    </section>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}