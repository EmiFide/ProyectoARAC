@model AdoptameLiberia.Models.Inventario.AjusteInventario

@{
    ViewBag.Title = "Ajuste de inventario";
}

@section styles{
    <link href="~/Content/estilos/Inventario.css" rel="stylesheet" />
}

<div class="inventory-shell">
    <section class="inventory-card">
        <div class="inventory-card-head">
            <div>
                <h2>Ajuste de inventario</h2>
                <p>Actualiza el stock real del artículo cuando exista diferencia física o de conteo.</p>
            </div>
        </div>

        <div class="inventory-highlight">
            Artículo: <strong>@Model.NombreItem</strong> &nbsp; | &nbsp; Stock actual: <strong>@Model.StockActual</strong>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.IdItemInventario)
            @Html.HiddenFor(m => m.NombreItem)
            @Html.HiddenFor(m => m.StockActual)
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="inventory-form">
                <div class="inventory-group">
                    @Html.LabelFor(m => m.NuevoStock, "Nuevo stock")
                    @Html.TextBoxFor(m => m.NuevoStock, new { @class = "form-control", type = "number", min = "0" })
                    @Html.ValidationMessageFor(m => m.NuevoStock, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group">
                    @Html.LabelFor(m => m.Motivo)
                    @Html.TextBoxFor(m => m.Motivo, new { @class = "form-control", placeholder = "Ej: diferencia física, conteo, auditoría" })
                    @Html.ValidationMessageFor(m => m.Motivo, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="inventory-form-actions">
                <button type="submit" class="inventory-btn-info">Aplicar ajuste</button>
                @Html.ActionLink("Volver al inventario", "Index", "Inventario", null, new { @class = "inventory-btn-outline" })
            </div>
        }
    </section>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}