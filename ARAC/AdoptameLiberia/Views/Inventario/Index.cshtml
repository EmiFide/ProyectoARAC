@model IEnumerable<AdoptameLiberia.Models.Donaciones.ItemInventario>
@using System
@using System.Collections.Generic
@using System.Linq

@{
    ViewBag.Title = "Inventario";
    var lista = Model != null ? Model.ToList() : new List<AdoptameLiberia.Models.Donaciones.ItemInventario>();
}

@section styles{
    <link href="~/Content/estilos/Inventario.css" rel="stylesheet" />
}

<div class="inventory-shell">
    <section class="inventory-hero">
        <div class="inventory-hero-content">
            <span class="inventory-kicker">ARAC · INVENTARIO</span>
            <h1>Control de inventario</h1>
            <p>
                Administra artículos, movimientos, stock mínimo y productos próximos a vencer
                desde una interfaz más ordenada, visual y alineada con el estilo general del sitio.
            </p>
        </div>
    </section>

    <div class="inventory-stats">
        <div class="inventory-stat">
            <h4>Total de artículos</h4>
            <p>@lista.Count</p>
        </div>

        <div class="inventory-stat inventory-stat-danger">
            <h4>Stock bajo</h4>
            <p>@ViewBag.StockBajoCount</p>
        </div>

        <div class="inventory-stat">
            <h4>Próximos a vencer</h4>
            <p>@ViewBag.VencenProntoCount</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">@TempData["Success"]</div>
    }

    <section class="inventory-card">
        <div class="inventory-card-head">
            <div>
                <h2>Acciones rápidas</h2>
                <p>Accede rápidamente a las funciones principales del módulo.</p>
            </div>
        </div>

        <div class="inventory-actions">
            <a href="@Url.Action("Create", "Inventario")" class="inventory-btn">Registrar artículo</a>
            <a href="@Url.Action("Historial", "Inventario")" class="inventory-btn-alt">Historial de movimientos</a>
            <a href="@Url.Action("AlertasStockMinimo", "Inventario")" class="inventory-btn-danger">Alertas de stock</a>
            <a href="@Url.Action("Vencimientos", "Inventario")" class="inventory-btn-info">Ver vencimientos</a>
        </div>
    </section>

    <section class="inventory-card">
        <div class="inventory-card-head">
            <div>
                <h2>Panel de artículos</h2>
                <p>Consulta el estado actual del inventario y ejecuta acciones por cada artículo.</p>
            </div>
        </div>

        @if (lista.Any())
        {
            <div class="inventory-cards-grid">
                @foreach (var item in lista)
                {
                    var stockBajo = item.StockActual <= item.StockMinimo;
                    var vencePronto = item.FechaCaducidad.HasValue && item.FechaCaducidad.Value.Date <= DateTime.Today.AddDays(30);

                    <article class="inventory-product-card">
                        <div class="inventory-product-top">
                            <div>
                                <h3>@item.Nombre</h3>
                                <span>@(string.IsNullOrWhiteSpace(item.Categoria) ? "Sin categoría" : item.Categoria)</span>
                            </div>

                            <div class="inventory-summary-row">
                                @if (stockBajo)
                                {
                                    <span class="inventory-badge-danger">Stock bajo</span>
                                }

                                @if (vencePronto)
                                {
                                    <span class="inventory-badge-alert">Próximo a vencer</span>
                                }

                                @if (!stockBajo && !vencePronto)
                                {
                                    <span class="inventory-badge-soft">Estable</span>
                                }
                            </div>
                        </div>

                        <div class="inventory-product-body">
                            <p>
                                @(string.IsNullOrWhiteSpace(item.Descripcion)
                                    ? "Este artículo no tiene descripción registrada."
                                    : item.Descripcion)
                            </p>
                        </div>

                        <div class="inventory-product-metrics">
                            <div class="inventory-product-metric">
                                <small>Stock actual</small>
                                <strong>@item.StockActual</strong>
                            </div>
                            <div class="inventory-product-metric">
                                <small>Stock mínimo</small>
                                <strong>@item.StockMinimo</strong>
                            </div>
                            <div class="inventory-product-metric">
                                <small>Unidad</small>
                                <strong>@(string.IsNullOrWhiteSpace(item.UnidadMedida) ? "N/D" : item.UnidadMedida)</strong>
                            </div>
                            <div class="inventory-product-metric">
                                <small>Caducidad</small>
                                <strong>@(item.FechaCaducidad.HasValue ? item.FechaCaducidad.Value.ToString("yyyy-MM-dd") : "Sin fecha")</strong>
                            </div>
                        </div>

                        <div class="inventory-actions inventory-actions-full">
                            <a href="@Url.Action("Entrada", "Inventario", new { id = item.IdItemInventario })" class="inventory-btn-success">Entrada</a>
                            <a href="@Url.Action("Salida", "Inventario", new { id = item.IdItemInventario })" class="inventory-btn-danger">Salida</a>
                            <a href="@Url.Action("Ajuste", "Inventario", new { id = item.IdItemInventario })" class="inventory-btn-info">Ajuste</a>
                            <a href="@Url.Action("Edit", "Inventario", new { id = item.IdItemInventario })" class="inventory-btn-outline">Editar</a>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="inventory-empty">
                <strong>No hay artículos registrados.</strong>
                Cuando registres productos o suministros aparecerán aquí.
            </div>
        }
    </section>
</div>