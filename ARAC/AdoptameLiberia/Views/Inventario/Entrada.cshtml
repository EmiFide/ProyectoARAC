@model AdoptameLiberia.Models.Inventario.MovimientoEntrada

@{
    ViewBag.Title = "Registrar entrada";
}

@section styles{
    <link href="~/Content/estilos/Inventario.css" rel="stylesheet" />
}

<div class="inventory-shell">
    <section class="inventory-card">
        <div class="inventory-card-head">
            <div>
                <h2>Registrar entrada</h2>
                <p>Ingresa nuevas unidades al inventario del artículo seleccionado.</p>
            </div>
        </div>

        <div class="inventory-highlight">
            Artículo seleccionado: <strong>@Model.NombreItem</strong>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.IdItemInventario)
            @Html.HiddenFor(m => m.NombreItem)
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="inventory-form">
                <div class="inventory-group">
                    @Html.LabelFor(m => m.Cantidad)
                    @Html.TextBoxFor(m => m.Cantidad, new { @class = "form-control", type = "number", min = "1" })
                    @Html.ValidationMessageFor(m => m.Cantidad, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group">
                    @Html.LabelFor(m => m.Motivo)
                    @Html.TextBoxFor(m => m.Motivo, new { @class = "form-control", placeholder = "Ej: Compra, donación, reposición" })
                    @Html.ValidationMessageFor(m => m.Motivo, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="inventory-form-actions">
                <button type="submit" class="inventory-btn">Guardar entrada</button>
                @Html.ActionLink("Volver", "Index", "Inventario", null, new { @class = "inventory-btn-outline" })
            </div>
        }
    </section>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}