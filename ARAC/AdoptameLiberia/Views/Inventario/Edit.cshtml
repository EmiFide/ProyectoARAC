@model AdoptameLiberia.Models.Inventario.ItemInventarioCreateEdit

@{
    ViewBag.Title = "Editar artículo";
}

@section styles{
    <link href="~/Content/estilos/Inventario.css" rel="stylesheet" />
}

<div class="inventory-shell">
    <section class="inventory-hero">
        <div class="inventory-hero-content">
            <span class="inventory-kicker">ARAC · INVENTARIO</span>
            <h1>Editar artículo</h1>
            <p>
                Actualiza la información del artículo sin alterar el flujo principal del inventario.
            </p>
        </div>
    </section>

    <section class="inventory-card">
        <div class="inventory-card-head">
            <div>
                <h2>Actualizar datos</h2>
                <p>Modifica lo necesario y guarda los cambios.</p>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.IdItemInventario)
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="inventory-form">
                <div class="inventory-group full">
                    @Html.LabelFor(m => m.Nombre)
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Nombre del artículo" })
                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group full">
                    @Html.LabelFor(m => m.Descripcion)
                    @Html.TextAreaFor(m => m.Descripcion, 4, 40, new { @class = "form-control", placeholder = "Descripción del artículo" })
                    @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group">
                    @Html.LabelFor(m => m.Categoria)
                    @Html.TextBoxFor(m => m.Categoria, new { @class = "form-control", placeholder = "Categoría" })
                    @Html.ValidationMessageFor(m => m.Categoria, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group">
                    @Html.LabelFor(m => m.UnidadMedida, "Unidad de medida")
                    @Html.TextBoxFor(m => m.UnidadMedida, new { @class = "form-control", placeholder = "Ej: unidades, kg, bolsas" })
                    @Html.ValidationMessageFor(m => m.UnidadMedida, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group">
                    @Html.LabelFor(m => m.StockMinimo, "Stock mínimo")
                    @Html.TextBoxFor(m => m.StockMinimo, new { @class = "form-control", type = "number", min = "0" })
                    @Html.ValidationMessageFor(m => m.StockMinimo, "", new { @class = "text-danger" })
                </div>

                <div class="inventory-group">
                    @Html.LabelFor(m => m.FechaCaducidad, "Fecha de caducidad")
                    @Html.TextBoxFor(m => m.FechaCaducidad, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.FechaCaducidad, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="inventory-form-actions">
                <button type="submit" class="inventory-btn">Guardar cambios</button>
                @Html.ActionLink("Volver al inventario", "Index", "Inventario", null, new { @class = "inventory-btn-outline" })
            </div>
        }
    </section>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}