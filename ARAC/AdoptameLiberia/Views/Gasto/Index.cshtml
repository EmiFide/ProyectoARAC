@model IEnumerable<AdoptameLiberia.Models.Finanzas.Gasto>

@{
    ViewBag.Title = "Gestión de Gastos";

    decimal totalGastos = 0;
    int totalRegistros = 0;

    if (Model != null)
    {
        foreach (var g in Model)
        {
            totalGastos += g.Monto ?? 0;
            totalRegistros++;
        }
    }
}

<link href="~/Content/estilos/Gasto.css" rel="stylesheet" />

<div class="gasto-page">
    <div class="gasto-top">
        <div class="gasto-heading">
            <h1>Gestión de gastos</h1>
            <p>Administra los egresos registrados en el sistema.</p>
        </div>

        <div class="gasto-top-actions">
            @Html.ActionLink("Nuevo gasto", "Create", "Gasto", null, new { @class = "gasto-btn gasto-btn-primary" })
        </div>
    </div>

    <div class="gasto-resumen">
        <div class="gasto-resumen-card">
            <span>Total</span>
            <strong>₡ @totalGastos.ToString("N2")</strong>
        </div>

        <div class="gasto-resumen-card">
            <span>Registros</span>
            <strong>@totalRegistros</strong>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="gasto-validation">
            @TempData["Success"]
        </div>
    }

    <div class="gasto-panel">
        <h2>Listado</h2>

        @if (Model != null && Model.Any())
        {
            <table class="gasto-table">
                <thead>
                    <tr>
                        <th>Categoría</th>
                        <th>Monto</th>
                        <th>Descripción</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(item.Categoria != null ? item.Categoria.Nombre : "Sin categoría")</td>
                            <td>₡ @((item.Monto ?? 0).ToString("N2"))</td>
                            <td>@(String.IsNullOrWhiteSpace(item.Descripcion) ? "-" : item.Descripcion)</td>
                            <td>@(item.Fecha != null ? item.Fecha.Value.ToString("dd/MM/yyyy") : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No hay gastos registrados.</p>
        }
    </div>
</div>