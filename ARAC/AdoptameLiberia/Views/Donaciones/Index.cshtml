@model IEnumerable<AdoptameLiberia.Models.Donaciones.Donacion>

@{
    ViewBag.Title = "Donaciones";
    bool esAdmin = ViewBag.EsAdmin != null && (bool)ViewBag.EsAdmin;
}

<link href="~/Content/estilos/Donaciones.css" rel="stylesheet" />

<div class="don-shell">
    <section class="don-hero">
        <div class="don-hero-copy">
            <span class="section-kicker">Apoyo al refugio</span>
            <h1>Donaciones con mejor presentación y acceso rápido</h1>
            <p>Elige un monto sugerido o realiza una donación libre para apoyar alimento, medicina y campañas.</p>
        </div>
        <div class="don-hero-image">
            <img src="~/Content/img/Refugio.png" alt="Donaciones" />
        </div>
    </section>

    <section class="don-pack-grid">
        <div class="don-pack-card">
            <img src="~/Content/img/Cachorro.png" alt="Económico" />
            <h3>Económico</h3>
            <p>Apoya alimento básico y necesidades diarias.</p>
            <strong>₡5,000</strong>
            <a href="@Url.Action("Create", new { monto = 5000 })" class="don-btn-main">Donar</a>
        </div>

        <div class="don-pack-card">
            <img src="~/Content/img/Perro.png" alt="Estándar" />
            <h3>Estándar</h3>
            <p>Apoya tratamientos, cuidados y campañas.</p>
            <strong>₡10,000</strong>
            <a href="@Url.Action("Create", new { monto = 10000 })" class="don-btn-main">Donar</a>
        </div>

        <div class="don-pack-card">
            <img src="~/Content/img/Gato.png" alt="Premium" />
            <h3>Premium</h3>
            <p>Contribución alta para apoyo integral del refugio.</p>
            <strong>₡20,000</strong>
            <a href="@Url.Action("Create", new { monto = 20000 })" class="don-btn-main">Donar</a>
        </div>

        <div class="don-pack-card">
            <img src="~/Content/img/Gatillo.png" alt="Libre" />
            <h3>Donación libre</h3>
            <p>Ingresa el monto que desees aportar.</p>
            <input type="number" id="montoPersonalizado" class="input-monto-pro" placeholder="Ingresa monto" min="1000" />
            <a href="#" class="don-btn-soft" onclick="donarPersonalizado(); return false;">Continuar</a>
        </div>
    </section>

    @using (Html.BeginForm("Index", "Donaciones", FormMethod.Get, new { @class = "don-filter-panel" }))
    {
        <div class="don-filter-head">
            <h3>Filtrar historial</h3>
            <p>Selecciona un tipo de donación para ordenar la vista.</p>
        </div>

        @Html.DropDownList(
            "tipoDonacionId",
            (SelectList)ViewBag.TiposDonacion,
            "Todas",
            new { @class = "form-control", onchange = "this.form.submit();" }
        )
    }

    <section class="don-table-panel">
        <div class="don-table-head">
            <h2>@(esAdmin ? "Historial completo de donaciones" : "Mis últimas 5 donaciones")</h2>
            <p>Consulta los registros realizados dentro del sistema.</p>
        </div>

        <div class="tabla-container-pro">
            <table class="tabla-donaciones">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Monto</th>
                        <th>Método</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center">No hay donaciones registradas.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var d in Model)
                        {
                            <tr>
                                <td>@d.IdDonacion</td>
                                <td>@d.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(d.TipoDonacion != null ? d.TipoDonacion.Nombre : "Sin tipo")</td>
                                <td class="don-money">₡@d.Monto.ToString("N0")</td>
                                <td>@d.Metodo</td>
                                <td>
                                    <div class="don-table-actions">
                                        @Html.ActionLink("Detalles", "Details", new { id = d.IdDonacion }, new { @class = "don-btn-soft mini" })
                                        @Html.ActionLink("Comprobante", "Comprobante", new { id = d.IdDonacion }, new { @class = "don-btn-main mini" })
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<script>
    function donarPersonalizado() {
        var monto = document.getElementById("montoPersonalizado").value;
        if (!monto || parseFloat(monto) <= 0) {
            alert("Por favor ingresa un monto válido");
            return;
        }

        window.location.href = '@Url.Action("Create", "Donaciones")' + '?monto=' + monto;
    }
</script>