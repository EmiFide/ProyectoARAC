@model AdoptameLiberia.Models.Donaciones.VM.DonacionCreateVM

<link href="~/Content/estilos/CreateDonacion.css" rel="stylesheet" />

<div class="form-container">

    <h2 class="titulo">💖 Registrar Donación</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-grid">

            <div class="form-group">
                <label>Tipo Donación</label>
                @Html.DropDownListFor(m => m.IdTipoDonacion, Model.TiposDonacion, "-- Seleccione --", new { @class = "input" })
            </div>


            <div class="form-group">
                <label>Método</label>
                @Html.DropDownListFor(
                    m => m.Metodo,
                    Model.MetodosPago,
                    "-- Seleccione método --",
                    new { @class = "input" }
                )
            </div>

            <div class="form-group">
                <label>Descripción</label>
                @Html.TextBoxFor(m => m.Descripcion, new { @class = "input" })
            </div>

            <div class="form-group full">
                <label>Monto</label>
                @Html.TextBoxFor(m => m.Monto, new
                {
                    @class = "input monto",
                    @readonly = Model.Monto > 0 ? "readonly" : null
                })
            </div>

        </div>

        <div class="insumos">
            <h4>📦 Insumos</h4>

            @for (int i = 0; i < Model.Insumos.Count; i++)
            {
                <div class="insumo-item">
                    @Html.DropDownListFor(m => m.Insumos[i].IdItemInventario, Model.ItemsInventario, "-- opcional --", new { @class = "input" })
                    @Html.TextBoxFor(m => m.Insumos[i].Descripcion, new { @class = "input", placeholder = "Detalle" })
                    @Html.TextBoxFor(m => m.Insumos[i].Cantidad, new { @class = "input", placeholder = "Cantidad", type = "number" })
                </div>
            }
        </div>

        <button type="submit" class="btn-guardar">Guardar Donación</button>
    }

</div>

<script>
    function toggleTipoDonacion() {
        var tipo = document.getElementById("IdTipoDonacion").value;

        var montoDiv = document.querySelector(".monto").closest(".form-group");
        var insumosDiv = document.querySelector(".insumos");

        if (tipo == "2") { // 👈 asumimos 2 = Insumos
            montoDiv.style.display = "none";
            insumosDiv.style.display = "block";
        } else {
            montoDiv.style.display = "block";
            insumosDiv.style.display = "none";
        }
    }

    document.getElementById("IdTipoDonacion").addEventListener("change", toggleTipoDonacion);

    // Ejecutar al cargar
    window.onload = toggleTipoDonacion;
</script>