@model AdoptameLiberia.Models.Donaciones.VM.DonacionCreateVM

@{
    ViewBag.Title = "Registrar donación";
}

<link href="~/Content/estilos/CreateDonacion.css" rel="stylesheet" />

<div class="doncreate-shell">
    <section class="doncreate-hero">
        <div class="doncreate-hero-copy">
            <span class="doncreate-kicker">Nuevo aporte</span>
            <h1>Registrar donación</h1>
            <p>
                Completa la información del aporte monetario o de insumos con una vista
                más limpia, ordenada y alineada al diseño general del sitio.
            </p>
        </div>

        <div class="doncreate-hero-image">
            <img src="~/Content/img/GatoPerro.png" alt="Registrar donación" />
        </div>
    </section>

    <section class="doncreate-card">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "doncreate-validation" })

            <div class="doncreate-grid">
                <div class="doncreate-group">
                    <label>Tipo de aporte</label>
                    @Html.DropDownListFor(m => m.IdTipoDonacion, Model.TiposDonacion, "-- Selecciona una opción --", new { @class = "doncreate-input", id = "IdTipoDonacion" })
                    @Html.ValidationMessageFor(m => m.IdTipoDonacion, "Selecciona un tipo de aporte", new { @class = "text-danger" })
                </div>

                <div class="doncreate-group" id="grupoMetodo">
                    <label>Método</label>
                    @Html.DropDownListFor(m => m.Metodo, Model.MetodosPago, "-- Selecciona un método --", new { @class = "doncreate-input", id = "Metodo" })
                    @Html.ValidationMessageFor(m => m.Metodo, "", new { @class = "text-danger" })
                </div>

                <div class="doncreate-group full">
                    <label>Descripción</label>
                    @Html.TextBoxFor(m => m.Descripcion, new { @class = "doncreate-input", placeholder = "Puedes agregar un detalle adicional del aporte" })
                </div>

                <div class="doncreate-group full" id="grupoMonto">
                    <label>Monto</label>
                    @Html.TextBoxFor(m => m.Monto, new { @class = "doncreate-input doncreate-monto", id = "Monto", type = "number", step = "0.01", min = "0", placeholder = "Monto en colones" })
                    @Html.ValidationMessageFor(m => m.Monto, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="doncreate-insumos" id="bloqueInsumos">
                <div class="doncreate-block-head">
                    <h3>Detalle de insumos</h3>
                    <p>Completa esta parte cuando la donación sea de artículos o materiales.</p>
                </div>

                @for (int i = 0; i < Model.Insumos.Count; i++)
                {
                    <div class="doncreate-insumo-item">
                        @Html.DropDownListFor(m => m.Insumos[i].IdItemInventario, Model.ItemsInventario, "-- artículo opcional --", new { @class = "doncreate-input" })
                        @Html.TextBoxFor(m => m.Insumos[i].Descripcion, new { @class = "doncreate-input", placeholder = "Ej: alimento, medicina, juguetes..." })
                        @Html.TextBoxFor(m => m.Insumos[i].Cantidad, new { @class = "doncreate-input", placeholder = "Cantidad", type = "number", min = "1" })
                    </div>
                }
            </div>

            <div class="doncreate-actions">
                <button type="submit" class="doncreate-btn-main">Guardar aporte</button>
                <a href="@Url.Action("Index", "Donaciones")" class="doncreate-btn-soft">Volver</a>
            </div>
        }
    </section>
</div>

<script>
    function esMonetaria() {
        var combo = document.getElementById("IdTipoDonacion");
        if (!combo || combo.selectedIndex < 0) return false;
        var texto = combo.options[combo.selectedIndex].text.toLowerCase().trim();
        return texto === "monetaria";
    }

    function actualizarVistaDonacion() {
        var grupoMonto = document.getElementById("grupoMonto");
        var grupoMetodo = document.getElementById("grupoMetodo");
        var bloqueInsumos = document.getElementById("bloqueInsumos");
        var monto = document.getElementById("Monto");
        var metodo = document.getElementById("Metodo");

        if (esMonetaria()) {
            grupoMonto.style.display = "block";
            grupoMetodo.style.display = "block";
            bloqueInsumos.style.display = "none";

            if (monto) {
                monto.removeAttribute("readonly");
            }
        } else {
            grupoMonto.style.display = "none";
            grupoMetodo.style.display = "none";
            bloqueInsumos.style.display = "block";

            if (monto) {
                monto.value = "";
            }

            if (metodo) {
                metodo.value = "Entrega directa";
            }
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        var combo = document.getElementById("IdTipoDonacion");
        if (combo) {
            combo.addEventListener("change", actualizarVistaDonacion);
        }
        actualizarVistaDonacion();
    });
</script>