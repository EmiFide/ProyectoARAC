@model AdoptameLiberia.Models.Donaciones.Donacion

@{
    ViewBag.Title = "Detalle de donación";
    bool esAdmin = User.IsInRole("Administrador");
    }

<link href="~/Content/estilos/Donaciones.css" rel="stylesheet" />

<div class="don-shell">
    <section class="don-detail-hero">
        <div class="don-detail-hero-copy">
            <span class="don-kicker">Detalle del aporte</span>
            <h1>Información de la donación</h1>
            <p>
                Consulta los datos registrados, el detalle de artículos entregados
                y agrega observaciones cuando sea necesario.
            </p>
        </div>

        <div class="don-detail-hero-image">
            <img src="~/Content/img/PerroyGato.png" alt="Detalle de donación" />
        </div>
    </section>

    <section class="don-detail-panel">
        <div class="don-detail-grid">
            <div class="don-info-card">
                <h3>Información general</h3>
                <ul class="don-info-list">
                    <li>
                        <span>Correo</span>
                        <strong>@(Model.Usuario != null ? Model.Usuario.Correo : "No disponible")</strong>
                    </li>
                    <li>
                        <span>Tipo de aporte</span>
                        <strong>@(Model.TipoDonacion != null ? Model.TipoDonacion.Nombre : "No definido")</strong>
                    </li>
                    <li>
                        <span>Método</span>
                        <strong>@(string.IsNullOrWhiteSpace(Model.Metodo) ? "No definido" : Model.Metodo)</strong>
                    </li>
                    <li>
                        <span>Monto</span>
                        <strong>@(Model.Monto > 0 ? "₡" + Model.Monto.ToString("N2") : "No aplica")</strong>
                    </li>
                    <li>
                        <span>Fecha</span>
                        <strong>@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</strong>
                    </li>
                </ul>
            </div>

            <div class="don-info-card">
                <h3>Descripción</h3>
                <div class="don-description-box">
                    @(string.IsNullOrWhiteSpace(Model.Descripcion) ? "No se agregó una descripción adicional." : Model.Descripcion)
                </div>
            </div>
        </div>
    </section>

    <section class="don-detail-panel">
        <div class="don-panel-head">
            <h2>Detalle de insumos</h2>
            <p>Se muestran únicamente los artículos asociados a esta donación.</p>
        </div>

        @if (Model.Detalles != null && Model.Detalles.Any())
        {
            <div class="don-chip-list">
                @foreach (var det in Model.Detalles)
                {
                    <div class="don-chip-card">
                        <div class="don-chip-title">
                            @(string.IsNullOrWhiteSpace(det.Descripcion) ? "Artículo registrado" : det.Descripcion)
                        </div>
                        @if (det.Cantidad > 0)
                        {
                            <div class="don-chip-meta">Cantidad: @det.Cantidad</div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="don-empty">
                Esta donación no tiene artículos registrados.
            </div>
        }
    </section>

    <section class="don-detail-panel">
        <div class="don-panel-head">
            <h2>Observaciones</h2>
            <p>Agrega comentarios para complementar la información del aporte.</p>
        </div>

        <!-- 🔥 SOLO ADMIN PUEDE AGREGAR -->
        @if (esAdmin)
        {
            using (Html.BeginForm("AgregarObservacion", "Donaciones", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="idDonacion" value="@Model.IdDonacion" />

                <div class="don-observation-form">
                    <textarea class="don-textarea" name="comentario" rows="4" placeholder="Escribe una observación..."></textarea>
                    <button class="don-btn-main" type="submit">Agregar observación</button>
                </div>
            }
        }
        else
        {
            <div class="don-info">
                Solo el personal autorizado puede agregar observaciones.
            </div>
        }

        <!-- LISTADO DE OBSERVACIONES -->
        @if (Model.Observaciones != null && Model.Observaciones.Any())
        {
            <div class="don-observation-list">
                @foreach (var o in Model.Observaciones.OrderByDescending(x => x.Fecha))
                {
                    <article class="don-observation-card">
                        <div class="don-observation-date">@o.Fecha.ToString("dd/MM/yyyy HH:mm")</div>
                        <p>@o.Comentario</p>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="don-empty">
                Todavía no hay observaciones registradas.
            </div>
        }
    </section>

    <div class="don-bottom-actions">

        <!-- 🔥 SOLO ADMIN VE COMPROBANTE -->
        @if (esAdmin)
        {
            <a href="@Url.Action("Comprobante", "Donaciones", new { id = Model.IdDonacion })"
               class="don-btn-main">
                Ver comprobante
            </a>
        }

        <a href="@Url.Action("Index", "Donaciones")" class="don-btn-soft">
            Volver
        </a>
    </div>
</div>