@model AdoptameLiberia.Models.Donaciones.Donacion
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Comprobante de donación</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 30px;
            background: #eef3f9; /* fondo suave azul */
            font-family: 'Inter', sans-serif;
        }

        .receipt {
            max-width: 850px;
            margin: auto;
            background: white;
            border-radius: 25px;
            padding: 30px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
        }

        /* HEADER */
        .logo {
            font-weight: 800;
            font-size: 24px;
            color: #2563eb; /* azul principal */
        }

        .title {
            text-align: center;
            margin: 25px 0 10px;
            font-size: 30px;
            font-weight: 800;
            color: #1e3a8a; /* azul oscuro */
        }

        .subtitle {
            text-align: center;
            color: #6b7280;
            margin-bottom: 25px;
        }

        /* CARDS */
        .card {
            background: #f5f9ff;
            padding: 15px;
            border-radius: 15px;
            border: 1px solid #e0ecff;
        }

        .label {
            font-size: 13px;
            color: #6b7280;
        }

        .value {
            font-weight: 700;
            font-size: 16px;
            color: #1e3a8a;
        }

        /* SECCIONES */
        .section h3 {
            color: #2563eb;
            margin-bottom: 10px;
        }

        .box {
            background: #f5f9ff;
            padding: 15px;
            border-radius: 15px;
            border: 1px solid #e0ecff;
        }

        /* FOOTER */
        .footer {
            margin-top: 30px;
            background: #f5f9ff;
            border-radius: 20px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .footer-text {
            color: #1e3a8a;
        }

        .msg {
            color: #2563eb;
            font-style: italic;
            margin-top: 5px;
        }

        /* BOTÓN */
        .btn {
            padding: 10px 18px;
            border-radius: 20px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }

        .print {
            background: linear-gradient(135deg, #2563eb, #1e40af);
            color: white;
        }

        @@media print {
            body {
                background: white;
                padding: 0;
            }

            .actions {
                display: none;
            }
        }
    </style>
</head>

<body>

    <div class="receipt">

        <!-- HEADER -->
        <div class="header">
            <div class="logo">🐾 ARAC</div>

            <div class="header-info">
                <div>Comprobante N° @Model.IdDonacion</div>
                <div>@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>

        <div class="title">Comprobante de donación</div>
        <div class="subtitle">Gracias por ayudar a quienes más lo necesitan</div>

        <!-- DATOS -->
        <div class="grid">
            <div class="card">
                <div class="label">Fecha</div>
                <div class="value">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            <div class="card">
                <div class="label">Tipo</div>
                <div class="value">@(Model.TipoDonacion != null ? Model.TipoDonacion.Nombre : "No definido")</div>
            </div>

            <div class="card">
                <div class="label">Monto</div>
                <div class="value">@(Model.Monto > 0 ? "₡ " + Model.Monto.ToString("N2") : "No aplica")</div>
            </div>

            <div class="card">
                <div class="label">Método</div>
                <div class="value">@Model.Metodo</div>
            </div>
        </div>

        <!-- DESCRIPCIÓN -->
        <div class="section">
            <h3>Descripción</h3>
            <div class="box">
                @(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción" : Model.Descripcion)
            </div>
        </div>

        <!-- ARTÍCULOS -->
        @if (Model.Detalles != null && Model.Detalles.Any())
        {
            <div class="section">
                <h3>Artículos</h3>

                <div class="box">
                    @foreach (var item in Model.Detalles)
                    {
                        <div class="item">
                            <strong>@item.Descripcion</strong><br />
                            Cantidad: @item.Cantidad
                        </div>
                    }
                </div>
            </div>
        }

        <!-- FOOTER -->
        <div class="footer">
            <div style="font-size:40px;">🐶🐱</div>

            <div class="footer-text">
                <strong>ARAC</strong>
                Gracias por apoyar al refugio.
                <div class="msg">Tu ayuda salva vidas ❤️</div>
            </div>
        </div>

        <!-- BOTÓN -->
        <div class="actions">
            <button class="btn print" onclick="window.print()">Imprimir</button>
        </div>

    </div>

</body>
</html>