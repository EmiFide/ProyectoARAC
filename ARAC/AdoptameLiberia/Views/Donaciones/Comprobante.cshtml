@model AdoptameLiberia.Models.Donaciones.Donacion
@{
    Layout = null; // vista imprimible
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Comprobante de Donación</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">

    <style>

        body {
            background-color: #f5ebdd;
        }

        .comprobante-card {
            max-width: 700px;
            margin: 40px auto;
            border-radius: 8px;
        }

        .header-vino {
            background-color: #40090b;
            color: white;
            padding: 15px;
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }

        .info-label {
            font-weight: bold;
            color: #40090b;
        }

        .firma {
            margin-top: 60px;
        }


            body {
                background-color: white;
            }


    </style>
</head>

<body>

    <div class="card shadow comprobante-card">

        <div class="header-vino">
            <h4 class="mb-0">Comprobante de Donación</h4>
        </div>

        <div class="card-body bg-white">

            <div class="row mb-2">
                <div class="col-6">
                    <span class="info-label">ID:</span> @Model.IdDonacion
                </div>

                <div class="col-6 text-right">
                    <span class="info-label">Fecha:</span>
                    @Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            <hr />

            <div class="row mb-2">
                <div class="col-md-6">
                    <span class="info-label">Tipo:</span>
                    @(Model.TipoDonacion != null ? Model.TipoDonacion.Nombre : "")
                </div>

                <div class="col-md-6">
                    <span class="info-label">Monto:</span>
                    ₡ @Model.Monto
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-md-6">
                    <span class="info-label">Método:</span>
                    @Model.Metodo
                </div>
            </div>

            <div class="mt-3">
                <span class="info-label">Descripción:</span>
                <p class="mb-0">@Model.Descripcion</p>
            </div>

            @if (Model.Detalles != null && Model.Detalles.Any())
            {
                <div class="mt-4">
                    <h5 class="text" style="color:#7B1E3A;">Detalle de Insumos</h5>

                    <ul class="list-group">
                        @foreach (var det in Model.Detalles)
                        {
                            <li class="list-group-item">
                                @det.Descripcion
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="firma">
                <p>Firma:</p>
                <hr style="width:300px; margin-left:0;" />
            </div>

            <div class="text-right mt-4">
                <button class="btn text-white"
                        style="background-color: #40090b;"
                        onclick="window.print()">
                    Imprimir
                </button>
            </div>

        </div>

    </div>

</body>
</html>