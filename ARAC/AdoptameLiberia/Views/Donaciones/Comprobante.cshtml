@model AdoptameLiberia.Models.Donaciones.Donacion
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Comprobante de donación</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 32px;
            background: #eef4fb;
            font-family: 'Inter', Arial, sans-serif;
            color: #49576a;
        }

        .receipt-wrap {
            max-width: 820px;
            margin: 0 auto;
        }

        .receipt-card {
            background: #ffffff;
            border: 1px solid #d9e5f3;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 12px 32px rgba(20, 32, 51, 0.08);
        }

        .receipt-header {
            padding: 28px 32px;
            background: linear-gradient(135deg, #2d6cdf 0%, #1d4fb8 100%);
            color: #fff;
        }

            .receipt-header h1 {
                margin: 0 0 8px;
                font-size: 2rem;
                font-weight: 800;
            }

            .receipt-header p {
                margin: 0;
                line-height: 1.7;
                opacity: .95;
            }

        .receipt-body {
            padding: 28px 32px 32px;
        }

        .receipt-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
            margin-bottom: 22px;
        }

        .receipt-box {
            background: #f8fbff;
            border: 1px solid #e4edf9;
            border-radius: 18px;
            padding: 16px;
        }

        .receipt-label {
            display: block;
            color: #6f8197;
            font-size: .9rem;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .receipt-value {
            color: #1c2d44;
            font-size: 1rem;
            font-weight: 800;
        }

        .receipt-section {
            margin-top: 24px;
        }

            .receipt-section h2 {
                margin: 0 0 12px;
                color: #1c2d44;
                font-size: 1.2rem;
            }

        .receipt-description {
            background: #f8fbff;
            border: 1px solid #e4edf9;
            border-radius: 18px;
            padding: 16px;
            line-height: 1.7;
        }

        .receipt-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .receipt-item {
            background: #f8fbff;
            border: 1px solid #e4edf9;
            border-radius: 16px;
            padding: 14px 16px;
        }

            .receipt-item strong {
                display: block;
                color: #1c2d44;
                margin-bottom: 4px;
            }

        .receipt-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-top: 30px;
            flex-wrap: wrap;
        }

        .receipt-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-main,
        .btn-soft {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0 18px;
            border-radius: 999px;
            font-weight: 800;
            text-decoration: none;
            border: none;
            cursor: pointer;
        }

        .btn-main {
            background: linear-gradient(135deg, #2d6cdf 0%, #1d4fb8 100%);
            color: #fff;
        }

        .btn-soft {
            background: #eaf2ff;
            color: #1d4fb8;
            border: 1px solid #d6e4ff;
        }

        @@media print {
            body {
                background: #fff;
                padding: 0;
            }

            .receipt-wrap {
                max-width: 100%;
            }

            .receipt-card {
                border: none;
                box-shadow: none;
                border-radius: 0;
            }

            .receipt-actions {
                display: none;
            }
        }

        @@media (max-width: 700px) {
            .receipt-meta {
                grid-template-columns: 1fr;
            }

            .receipt-body,
            .receipt-header {
                padding: 22px 18px;
            }
        }
    </style>
</head>
<body>
    <div class="receipt-wrap">
        <div class="receipt-card">
            <div class="receipt-header">
                <h1>Comprobante de donación</h1>
                <p>Resumen del aporte registrado dentro del sistema.</p>
            </div>

            <div class="receipt-body">
                <div class="receipt-meta">
                    <div class="receipt-box">
                        <span class="receipt-label">Fecha de registro</span>
                        <span class="receipt-value">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>

                    <div class="receipt-box">
                        <span class="receipt-label">Tipo de aporte</span>
                        <span class="receipt-value">@(Model.TipoDonacion != null ? Model.TipoDonacion.Nombre : "No definido")</span>
                    </div>

                    <div class="receipt-box">
                        <span class="receipt-label">Monto</span>
                        <span class="receipt-value">@(Model.Monto > 0 ? "₡ " + Model.Monto.ToString("N2") : "No aplica")</span>
                    </div>

                    <div class="receipt-box">
                        <span class="receipt-label">Método</span>
                        <span class="receipt-value">@(!string.IsNullOrWhiteSpace(Model.Metodo) ? Model.Metodo : "No definido")</span>
                    </div>
                </div>

                <div class="receipt-section">
                    <h2>Descripción</h2>
                    <div class="receipt-description">
                        @(string.IsNullOrWhiteSpace(Model.Descripcion) ? "No se agregó una descripción adicional." : Model.Descripcion)
                    </div>
                </div>

                @if (Model.Detalles != null && Model.Detalles.Any())
                {
                    <div class="receipt-section">
                        <h2>Artículos registrados</h2>
                        <div class="receipt-list">
                            @foreach (var det in Model.Detalles)
                            {
                                <div class="receipt-item">
                                    <strong>@(string.IsNullOrWhiteSpace(det.Descripcion) ? "Artículo registrado" : det.Descripcion)</strong>
                                    @if (det.Cantidad > 0)
                                    {
                                        <span>Cantidad: @det.Cantidad</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="receipt-footer">
                    <div>
                        <strong style="color:#1c2d44;">ARAC</strong><br />
                        <span style="color:#6f8197;">Gracias por apoyar al refugio.</span>
                    </div>

                    <div class="receipt-actions">
                        <a href="@Url.Action("Details", "Donaciones", new { id = Model.IdDonacion })" class="btn-soft">Volver</a>
                        <button class="btn-main" onclick="window.print()">Imprimir</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>