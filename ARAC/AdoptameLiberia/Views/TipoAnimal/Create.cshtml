@model AdoptameLiberia.Models.TiposAnimales.TipoAnimal

@{
    ViewBag.Title = "Nuevo Tipo de Animal";
}

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="card shadow border-0">

                <div class="card-header text-white" style="background-color: #40090b;">
                    <h4 class="mb-0">Registrar Nuevo Tipo de Animal</h4>
                </div>

                <div class="card-body bg-light">

                    @using (Html.BeginForm())
                    {
                        <div class="form-group">
                            @Html.LabelFor(m => m.Nombre_Tipo_Animal, new { @class = "font-weight-bold" })
                            @Html.TextBoxFor(m => m.Nombre_Tipo_Animal,
                                new
                                     {
                                    @class = "form-control",
                                    placeholder = "Ej: Perro, Gato, Conejo",
                                    required = "required"
                                })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(m => m.Descripcion, new { @class = "font-weight-bold" })
                            @Html.TextAreaFor(m => m.Descripcion,
                                new
                                     {
                                    @class = "form-control",
                                    rows = "3",
                                    placeholder = "Describe el tipo de animal..."
                                })
                        </div>

                        <div class="d-flex justify-content-between mt-4">

                            <a href="@Url.Action("Index", "TipoAnimal")"
                               class="btn btn-outline-secondary">
                                ← Volver
                            </a>

                            <button type="submit"
                                    class="btn text-white"
                                    style="background-color: #40090b;">
                                Guardar
                            </button>

                        </div>
                    }

                </div>

            </div>

        </div>
    </div>

</div>