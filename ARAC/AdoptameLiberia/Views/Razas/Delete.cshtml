@model AdoptameLiberia.Models.Raza

@{
    ViewBag.Title = "Eliminar raza";
}

@section Styles{
    <link href="~/Content/estilos/Razas.css" rel="stylesheet" />
}

<div class="razas-page">
    <section class="razas-hero">
        <span class="razas-kicker">ARAC · RAZAS</span>
        <h1>Eliminar raza</h1>
        <p>
            Antes de eliminar, revisa cuidadosamente la información asociada a este registro.
        </p>
    </section>

    <section class="razas-delete-wrap">
        <div class="razas-delete-head">
            <h2>Confirmación de eliminación</h2>
            <p>Esta acción removerá el registro de la base de datos.</p>
        </div>

        <div class="razas-delete-alert">
            ¿Estás seguro de que deseas eliminar esta raza? Esta acción no se puede deshacer.
        </div>

        <div class="razas-detail-grid">
            <div class="razas-detail-item">
                <span>Nombre</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.Nombre) ? "Sin nombre registrado" : Model.Nombre)</strong>
            </div>

            <div class="razas-detail-item">
                <span>Descripción</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción registrada." : Model.Descripcion)</strong>
            </div>
        </div>

        <div class="razas-form-actions" style="margin-top:24px;">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="razas-btn-danger">Eliminar definitivamente</button>
            }

            <a href="@Url.Action("Index", "Razas")" class="razas-btn-outline">Cancelar</a>
        </div>
    </section>
</div>