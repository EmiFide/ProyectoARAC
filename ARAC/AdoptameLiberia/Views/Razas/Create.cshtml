@model AdoptameLiberia.Models.Raza

@{
    ViewBag.Title = "Crear raza";
}

@section Styles{
    <link href="~/Content/estilos/Razas.css" rel="stylesheet" />
}

<div class="razas-page">
    <section class="razas-hero">
        <span class="razas-kicker">ARAC · RAZAS</span>
        <h1>Registrar nueva raza</h1>
        <p>
            Completa la información necesaria para guardar una nueva raza en la base de datos.
        </p>
    </section>

    <section class="razas-form-wrap">
        <div class="razas-form-head">
            <h2>Formulario de registro</h2>
            <p>Ingresa únicamente la información necesaria para crear el nuevo registro.</p>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "" })

            <div class="razas-form-grid">
                <div class="razas-field">
                    @Html.LabelFor(model => model.Nombre)
                    @Html.TextBoxFor(model => model.Nombre, new { @class = "razas-input", placeholder = "Ejemplo: Labrador Retriever" })
                    @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "razas-validation" })
                </div>

                <div class="razas-field">
                    @Html.LabelFor(model => model.Descripcion)
                    @Html.TextAreaFor(model => model.Descripcion, new { @class = "razas-textarea", placeholder = "Describe brevemente la raza..." })
                    @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "razas-validation" })
                </div>

                <div class="razas-form-actions">
                    <button type="submit" class="razas-btn">Guardar raza</button>
                    <a href="@Url.Action("Index", "Razas")" class="razas-btn-outline">Volver al listado</a>
                </div>
            </div>
        }
    </section>
</div>