@model AdoptameLiberia.Models.RegisterViewModel

@{
    ViewBag.Title = "Registro";
}

<link href="~/Content/estilos/Login.css" rel="stylesheet" />

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-visual">
            <div class="auth-visual-inner">
                <span class="auth-kicker">Únete a ARAC</span>
                <h2>Crea tu cuenta</h2>
                <p>Accede a adopciones, campañas, donaciones, comunidad y más desde un solo lugar.</p>
                <img src="~/Content/img/GatoPerro.png" alt="Registro" />
            </div>
        </div>

        <div class="auth-form-side">
            <h1>Registro</h1>
            <p class="auth-subtext">¿Ya tienes cuenta? <a href="@Url.Action("Login", "Account")">Inicia sesión</a></p>

            @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form", @class = "auth-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="auth-group">
                    @Html.LabelFor(m => m.Email)
                    @Html.TextBoxFor(m => m.Email, new { @type = "email", @placeholder = "correo@ejemplo.com", @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="auth-group">
                    @Html.LabelFor(m => m.Password, "Contraseña")
                    @Html.PasswordFor(m => m.Password, new { @placeholder = "Crea tu contraseña", @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="auth-group">
                    @Html.LabelFor(m => m.ConfirmPassword, "Confirmar contraseña")
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @placeholder = "Confirma tu contraseña", @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="auth-submit">Crear cuenta</button>
            }
        </div>
    </div>
</div>