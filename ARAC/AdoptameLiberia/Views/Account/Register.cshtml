@model AdoptameLiberia.Models.RegisterViewModel

@{
    ViewBag.Title = "Registrarse";
}

@section styles {
    <link href="~/Content/estilos/login.css" rel="stylesheet" />
}

<div class="login-wrapper">
    <div class="login-container">

        <div class="login-left"></div>

        <div class="login-right">
            <div class="login-box">

                <h2>Crear Cuenta</h2>

                <p class="register-text">
                    ¿Ya tienes cuenta?
                    @Html.ActionLink("Inicia sesión", "Login", "Account")
                </p>

                @using (Html.BeginForm("Register", "Account",
                    FormMethod.Post,
                    new { @class = "login-form" }))
                {
                    @Html.AntiForgeryToken()

                    @Html.ValidationSummary(true, null, new { @class = "text-danger mb-3" })

                    <div class="form-group">
                        <label>Email</label>
                        @Html.TextBoxFor(m => m.Email,
                            new { @class = "form-control", placeholder = "ejemplo@gmail.com" })
                    </div>

                    <div class="form-group">
                        <label>Contraseña</label>
                        @Html.PasswordFor(m => m.Password,
                            new { @class = "form-control", placeholder = "********" })
                    </div>

                    <div class="form-group">
                        <label>Confirmar Contraseña</label>
                        @Html.PasswordFor(m => m.ConfirmPassword,
                            new { @class = "form-control", placeholder = "********" })
                    </div>

                    <button type="submit" class="btn-login">
                        Registrarse
                    </button>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}