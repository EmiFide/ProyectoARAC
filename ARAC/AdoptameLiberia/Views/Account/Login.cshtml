@using AdoptameLiberia.Models
@model LoginViewModel

@{
    ViewBag.Title = "Iniciar sesión";
}

@section styles {
    <link href="~/Content/estilos/login.css" rel="stylesheet" />
}

<div class="login-wrapper">
    <div class="login-container">

        <!-- IZQUIERDA -->
        <div class="login-left"></div>

        <!-- DERECHA -->
        <div class="login-right">

            <div class="login-box">

                <h2>Iniciar Sesión</h2>

                <p class="register-text">
                    ¿Eres nuevo?
                    @Html.ActionLink("Regístrate", "Register", "Account")
                </p>

                @using (Html.BeginForm("Login", "Account",
                    new { ReturnUrl = (string)ViewBag.ReturnUrl },
                    FormMethod.Post,
                    new { @class = "login-form" }))
                {
                    @Html.AntiForgeryToken()

                    @Html.ValidationSummary(true, null, new { @class = "text-danger mb-3" })

                    <div class="form-group">
                        <label>Email</label>
                        @Html.TextBoxFor(m => m.Email,
                            new { @class = "form-control", placeholder = "ejemplo@gmail.com" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label>Contraseña</label>
                        @Html.PasswordFor(m => m.Password,
                            new { @class = "form-control", placeholder = "********" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(m => m.RememberMe)
                        <label>Recordarme</label>
                    </div>

                    <button type="submit" class="btn-login">
                        Iniciar Sesión
                    </button>

                    <p class="forgot">
                        @Html.ActionLink("¿Olvidaste tu contraseña?", "ForgotPassword")
                    </p>
                }

            </div>

        </div>

    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}