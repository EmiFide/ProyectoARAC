@model AdoptameLiberia.Models.LoginViewModel

@{
    ViewBag.Title = "Iniciar Sesión";
}

<link href="~/Content/estilos/Login.css" rel="stylesheet" />

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-visual">
            <div class="auth-visual-inner">
                <span class="auth-kicker">ARAC Refugio</span>
                <h2>Bienvenido de nuevo</h2>
                <p>Accede a tus donaciones, publicaciones, favoritos y gestión de mascotas desde una interfaz más limpia.</p>
                <img src="~/Content/img/Cachorro.png" alt="Iniciar sesión" />
            </div>
        </div>

        <div class="auth-form-side">
            <h1>Iniciar sesión</h1>
            <p class="auth-subtext">¿No tienes cuenta? <a href="@Url.Action("Register", "Account")">Regístrate aquí</a></p>

            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { role = "form", @class = "auth-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="auth-group">
                    @Html.LabelFor(m => m.Email)
                    @Html.TextBoxFor(m => m.Email, new { @type = "email", @placeholder = "correo@ejemplo.com", @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="auth-group">
                    @Html.LabelFor(m => m.Password, "Contraseña")
                    @Html.PasswordFor(m => m.Password, new { @placeholder = "Ingresa tu contraseña", @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="auth-check">
                    @Html.CheckBoxFor(m => m.RememberMe)
                    <span>Recordarme</span>
                </div>

                <button type="submit" class="auth-submit">Entrar</button>

                <div class="auth-links">
                    <a href="@Url.Action("ForgotPassword", "Account")">¿Olvidaste tu contraseña?</a>
                </div>
            }
        </div>
    </div>
</div>