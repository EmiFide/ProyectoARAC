@model AdoptameLiberia.Models.ForgotPasswordViewModel

@{
    ViewBag.Title = "¿Olvidó su contraseña?";
}

@section Styles {
    <link href="~/Content/estilos/Login.css" rel="stylesheet" />
}

<div class="auth-page">
    <div class="container auth-page-container">
        <div class="auth-wrapper auth-wrapper-login">

            <section class="auth-showcase">
                <div class="auth-showcase-badge">Recuperación de acceso</div>

                <h1>Recupera tu cuenta</h1>
                <p class="auth-showcase-text">
                    Ingresa tu correo electrónico para enviarte un vínculo de recuperación
                    y ayudarte a restablecer tu contraseña de forma segura.
                </p>

                <div class="auth-feature-list">
                    <div class="auth-feature-item">
                        <span class="auth-feature-icon">•</span>
                        <span>Proceso rápido y claro</span>
                    </div>
                    <div class="auth-feature-item">
                        <span class="auth-feature-icon">•</span>
                        <span>Protección para tu cuenta</span>
                    </div>
                    <div class="auth-feature-item">
                        <span class="auth-feature-icon">•</span>
                        <span>Diseño alineado con el home</span>
                    </div>
                </div>

                <div class="auth-showcase-image">
                    <img src="~/Content/img/GatoPerro.png" alt="Recuperación de cuenta ARAC" />
                </div>
            </section>

            <section class="auth-panel">
                <div class="auth-panel-header">
                    <span class="auth-mini-label">Acceso seguro</span>
                    <h2>¿Olvidaste tu contraseña?</h2>
                    <p>
                        Escribe tu correo y te enviaremos un enlace para restablecerla.
                    </p>
                </div>

                @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { role = "form", @class = "auth-form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="auth-group">
                        @Html.LabelFor(m => m.Email, "Correo electrónico", new { @class = "auth-label" })
                        @Html.TextBoxFor(m => m.Email, new
                        {
                            @class = "auth-input",
                            @type = "email",
                            @placeholder = "correo@ejemplo.com",
                            autocomplete = "email"
                        })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger auth-validation" })
                    </div>

                    <button type="submit" class="auth-submit">
                        Enviar vínculo de recuperación
                    </button>

                    <div class="auth-row" style="justify-content:flex-start; margin-top:10px;">
                        <a class="auth-inline-link" href="@Url.Action("Login", "Account")">
                            Volver a iniciar sesión
                        </a>
                    </div>
                }
            </section>

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}