@model AdoptameLiberia.Models.ResetPasswordViewModel

@{
    ViewBag.Title = "Restablecer contraseña";
}

@section Styles {
    <style>
        .reset-shell {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .reset-card {
            width: 100%;
            max-width: 460px;
            background: #fff;
            border-radius: 26px;
            padding: 32px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            border: 1px solid #e5ecf6;
        }

        .reset-header {
            text-align: center;
            margin-bottom: 24px;
        }

            .reset-header h2 {
                color: #2563eb;
                margin-bottom: 8px;
            }

            .reset-header p {
                color: #6b7280;
                font-size: 0.95rem;
            }

        .reset-group {
            display: flex;
            flex-direction: column;
            margin-bottom: 16px;
        }

            .reset-group label {
                font-weight: 600;
                margin-bottom: 6px;
                color: #1f2c4c;
            }

        .reset-input {
            border: 1px solid #dbe7ff;
            border-radius: 14px;
            padding: 12px;
            outline: none;
            transition: 0.2s;
        }

            .reset-input:focus {
                border-color: #3b82f6;
            }

        .reset-btn {
            width: 100%;
            margin-top: 10px;
            padding: 12px;
            border-radius: 999px;
            border: none;
            font-weight: 800;
            color: white;
            background: linear-gradient(135deg,#3b82f6,#2563eb);
            cursor: pointer;
            transition: 0.2s;
        }

            .reset-btn:hover {
                transform: translateY(-1px);
            }

        .reset-error {
            color: #dc2626;
            margin-bottom: 10px;
            text-align: center;
            font-size: 0.9rem;
        }
    </style>
}

<div class="reset-shell">

    <div class="reset-card">

        <!-- HEADER -->
        <div class="reset-header">
            <h2>Restablecer contraseña</h2>
            <p>Ingresa una nueva contraseña para continuar</p>
        </div>

        <!-- FORM -->
        @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.Code)

            @Html.ValidationSummary("", new { @class = "reset-error" })

            <div class="reset-group">
                @Html.LabelFor(m => m.Email)
                @Html.TextBoxFor(m => m.Email, new { @class = "reset-input", placeholder = "Correo electrónico" })
            </div>

            <div class="reset-group">
                @Html.LabelFor(m => m.Password)
                @Html.PasswordFor(m => m.Password, new { @class = "reset-input", placeholder = "Nueva contraseña" })
            </div>

            <div class="reset-group">
                @Html.LabelFor(m => m.ConfirmPassword)
                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "reset-input", placeholder = "Confirmar contraseña" })
            </div>

            <button type="submit" class="reset-btn">
                Restablecer contraseña
            </button>
        }

    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}