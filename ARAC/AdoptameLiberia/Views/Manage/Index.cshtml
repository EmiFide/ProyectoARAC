@model System.Collections.Generic.IList<Microsoft.AspNet.Identity.UserLoginInfo>
@{
    ViewBag.Title = "Administrar cuenta";
}

<style>
    .manage-index-page {
        min-height: calc(100vh - 120px);
        padding: 28px 16px;
        background: linear-gradient(180deg, #f5f9ff 0%, #e8f1fb 100%);
    }

    .manage-index-container {
        max-width: 1050px;
        margin: 0 auto;
    }

    .manage-index-header {
        margin-bottom: 24px;
    }

    .manage-index-badge {
        display: inline-block;
        padding: 7px 14px;
        margin-bottom: 12px;
        border-radius: 999px;
        background: #eaf3ff;
        color: #2f74c9;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .manage-index-title {
        margin: 0 0 8px;
        color: #183b56;
        font-size: 34px;
        font-weight: 800;
        line-height: 1.1;
    }

    .manage-index-text {
        margin: 0;
        color: #5f7387;
        font-size: 15px;
        line-height: 1.6;
        max-width: 700px;
    }

    .manage-index-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
    }

    .manage-box {
        background: #ffffff;
        border: 1px solid #dbe7f3;
        border-radius: 24px;
        box-shadow: 0 18px 40px rgba(24, 59, 86, 0.08);
        padding: 24px;
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }

    .manage-box:hover {
        transform: translateY(-3px);
        box-shadow: 0 22px 45px rgba(24, 59, 86, 0.12);
        border-color: #c6d9ee;
    }

    .manage-box h3 {
        margin: 0 0 10px;
        color: #183b56;
        font-size: 22px;
        font-weight: 800;
    }

    .manage-box p {
        margin: 0 0 18px;
        color: #5f7387;
        font-size: 14px;
        line-height: 1.6;
    }

    .manage-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 14px;
        background: linear-gradient(135deg, #4f8fd8 0%, #2f74c9 100%);
        color: #ffffff !important;
        text-decoration: none !important;
        font-size: 14px;
        font-weight: 800;
        box-shadow: 0 10px 22px rgba(47, 116, 201, 0.18);
        transition: all .25s ease;
    }

    .manage-action:hover {
        transform: translateY(-1px);
        box-shadow: 0 14px 26px rgba(47, 116, 201, 0.22);
        color: #ffffff !important;
    }

    .manage-action-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 14px;
        border: 1px solid #dbe7f3;
        background: #ffffff;
        color: #183b56 !important;
        text-decoration: none !important;
        font-size: 14px;
        font-weight: 700;
        transition: all .25s ease;
    }

    .manage-action-secondary:hover {
        background: #f7fbff;
        border-color: #bfd6f0;
        color: #183b56 !important;
    }

    .manage-actions-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .text-success {
        margin-bottom: 16px;
        padding: 12px 14px;
        border-radius: 14px;
        background: #effaf3;
        border: 1px solid #c7ead2;
        color: #157347 !important;
        font-size: 14px;
        font-weight: 600;
    }

    @media (max-width: 900px) {
        .manage-index-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 768px) {
        .manage-index-page {
            padding: 18px 10px;
        }

        .manage-index-title {
            font-size: 27px;
        }

        .manage-box {
            padding: 18px;
            border-radius: 18px;
        }
    }
</style>

<div class="manage-index-page">
    <div class="manage-index-container">
        <div class="manage-index-header">
            <span class="manage-index-badge">Mi cuenta</span>
            <h1 class="manage-index-title">Administrar cuenta</h1>
            <p class="manage-index-text">
                Desde aquí puedes gestionar la seguridad y los accesos de tu cuenta de una forma más clara, moderna y ordenada.
            </p>
        </div>

        @if (ViewBag.StatusMessage != null && !String.IsNullOrWhiteSpace(ViewBag.StatusMessage))
        {
            <div class="text-success">@ViewBag.StatusMessage</div>
        }

        <div class="manage-index-grid">
            <div class="manage-box">
                <h3>Contraseña</h3>
                <p>
                    Cambia tu contraseña para mantener protegida tu cuenta y mejorar la seguridad de tu acceso.
                </p>

                <div class="manage-actions-row">
                    @if (ViewBag.HasLocalPassword != null && ViewBag.HasLocalPassword)
                    {
                        <a href="@Url.Action("ChangePassword", "Manage")" class="manage-action">
                            Cambiar contraseña
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("SetPassword", "Manage")" class="manage-action">
                            Crear contraseña
                        </a>
                    }
                </div>
            </div>

            <div class="manage-box">
                <h3>Accesos externos</h3>
                <p>
                    Administra inicios de sesión vinculados a servicios externos y revisa cómo accedes a tu cuenta.
                </p>

                <div class="manage-actions-row">
                    <a href="@Url.Action("ManageLogins", "Manage")" class="manage-action-secondary">
                        Administrar accesos
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>