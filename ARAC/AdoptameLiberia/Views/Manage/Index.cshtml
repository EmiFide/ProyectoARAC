@model AdoptameLiberia.Models.IndexViewModel
@{
    ViewBag.Title = "Mi perfil";
}

<style>
    .perfil-page {
        min-height: calc(100vh - 80px);
        padding: 42px 16px 56px;
        background: linear-gradient(180deg, #f4f7fb 0%, #edf2f7 100%);
    }

    .perfil-container {
        max-width: 980px;
        margin: 0 auto;
    }

    .perfil-header {
        margin-bottom: 26px;
        text-align: center;
    }

    .perfil-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: #eaf2ff;
        color: #2f6fc4;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 14px;
    }

    .perfil-title {
        margin: 0 0 10px;
        color: #163454;
        font-size: 38px;
        font-weight: 800;
        line-height: 1.08;
    }

    .perfil-text {
        margin: 0 auto;
        max-width: 760px;
        color: #5f7387;
        font-size: 15px;
        line-height: 1.8;
    }

    .perfil-status {
        margin: 0 auto 22px;
        max-width: 860px;
        padding: 14px 16px;
        border-radius: 16px;
        background: #edf9f1;
        border: 1px solid #cfe8d7;
        color: #1f7a45;
        font-size: 14px;
        font-weight: 700;
    }

    .perfil-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px;
        align-items: start;
    }

    .perfil-section {
        background: #ffffff;
        border: 1px solid #dbe5ef;
        border-radius: 22px;
        padding: 28px;
        box-shadow: 0 12px 30px rgba(22, 52, 84, 0.06);
    }

    .perfil-section-title {
        margin: 0 0 10px;
        color: #163454;
        font-size: 26px;
        font-weight: 800;
        line-height: 1.2;
    }

    .perfil-section-text {
        margin: 0 0 20px;
        color: #5f7387;
        font-size: 14px;
        line-height: 1.8;
    }

    .perfil-form {
        display: grid;
        gap: 16px;
    }

    .perfil-field {
        display: grid;
        gap: 7px;
    }

    .perfil-label {
        color: #163454;
        font-size: 13px;
        font-weight: 800;
        letter-spacing: .02em;
    }

    .perfil-input {
        width: 100%;
        height: 48px;
        border-radius: 14px;
        border: 1px solid #d4dfe9;
        background: #fbfdff;
        padding: 0 14px;
        color: #163454;
        font-size: 14px;
        transition: border-color .2s ease, box-shadow .2s ease, background .2s ease;
    }

        .perfil-input:focus {
            outline: none;
            border-color: #4f8fd8;
            background: #ffffff;
            box-shadow: 0 0 0 3px rgba(79, 143, 216, 0.14);
        }

    .perfil-error {
        color: #c44545;
        font-size: 12px;
        font-weight: 600;
    }

    .validation-summary-errors {
        margin-bottom: 16px;
        padding: 12px 14px;
        border-radius: 14px;
        background: #fff3f3;
        border: 1px solid #f1cccc;
        color: #b42318;
        font-size: 13px;
        font-weight: 600;
    }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

    .perfil-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 6px;
    }

    .perfil-btn {
        min-width: 180px;
        height: 48px;
        border: none;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 20px;
        text-decoration: none !important;
        font-size: 14px;
        font-weight: 800;
        cursor: pointer;
        transition: all .25s ease;
    }

    .perfil-btn-primary {
        background: linear-gradient(135deg, #4f8fd8 0%, #2f74c9 100%);
        color: #ffffff !important;
        box-shadow: 0 12px 24px rgba(47, 116, 201, 0.20);
    }

        .perfil-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 28px rgba(47, 116, 201, 0.24);
        }

    .perfil-btn-secondary {
        background: #ffffff;
        color: #163454 !important;
        border: 1px solid #d4dfe9;
    }

        .perfil-btn-secondary:hover {
            background: #f7fbff;
            border-color: #bfd1e3;
            transform: translateY(-2px);
        }

    .perfil-card-info {
        display: grid;
        gap: 14px;
        margin-bottom: 22px;
    }

    .perfil-info-item {
        padding: 16px 18px;
        background: #f8fbfe;
        border: 1px solid #e2eaf2;
        border-radius: 16px;
    }

    .perfil-info-label {
        display: block;
        margin-bottom: 6px;
        color: #6a7f94;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .perfil-info-value {
        color: #163454;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.6;
        word-break: break-word;
    }

    .perfil-password-box {
        margin-top: 8px;
        padding: 18px;
        border-radius: 18px;
        background: #f8fbfe;
        border: 1px solid #e2eaf2;
    }

        .perfil-password-box p {
            margin: 0 0 16px;
            color: #5f7387;
            font-size: 14px;
            line-height: 1.8;
        }

    @@media (max-width: 900px) {
        .perfil-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .perfil-page {
            padding: 26px 12px 40px;
        }

        .perfil-title {
            font-size: 30px;
        }

        .perfil-section {
            padding: 22px;
            border-radius: 18px;
        }

        .perfil-btn {
            width: 100%;
            min-width: 100%;
        }
    }
</style>

<div class="perfil-page">
    <div class="perfil-container">

        <div class="perfil-header">
            <span class="perfil-badge">Mi perfil</span>
            <h1 class="perfil-title">Administra tu información personal</h1>
            <p class="perfil-text">
                Desde aquí puedes actualizar tus datos principales y mantener segura tu cuenta
                
            </p>
        </div>

        @if (ViewBag.StatusMessage != null && !String.IsNullOrWhiteSpace(ViewBag.StatusMessage.ToString()))
        {
            <div class="perfil-status">@ViewBag.StatusMessage</div>
        }

        <div class="perfil-layout">
            <section class="perfil-section">
                <h2 class="perfil-section-title">Mi información</h2>
                <p class="perfil-section-text">
                    Edita tu nombre, correo electrónico y número de teléfono. Al guardar,
                    tus datos se actualizarán en tu cuenta.
                </p>

                @using (Html.BeginForm("Index", "Manage", FormMethod.Post, new { @class = "perfil-form" }))
                {
                    @Html.AntiForgeryToken()
                   

                    <div class="perfil-field">
                        <label class="perfil-label">Nombre completo</label>
                        @Html.TextBoxFor(m => m.Nombre, new { @class = "perfil-input", placeholder = "Ingresa tu nombre completo" })
                        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "perfil-error" })
                    </div>

                    <div class="perfil-field">
                        <label class="perfil-label">Correo electrónico</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "perfil-input", placeholder = "Ingresa tu correo electrónico", type = "email" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "perfil-error" })
                    </div>

                    <div class="perfil-field">
                        <label class="perfil-label">Número de teléfono</label>
                        @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "perfil-input", placeholder = "Ingresa tu número de teléfono" })
                        @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "perfil-error" })
                    </div>

                    <div class="perfil-actions">
                        <button type="submit" class="perfil-btn perfil-btn-primary">
                            Guardar datos
                        </button>

                        @if (Model.HasPassword)
                        {
                            <a href="@Url.Action("ChangePassword", "Manage")" class="perfil-btn perfil-btn-secondary">
                                Cambiar contraseña
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("SetPassword", "Manage")" class="perfil-btn perfil-btn-secondary">
                                Crear contraseña
                            </a>
                        }
                    </div>
                }
            </section>

            <section class="perfil-section">
                <h2 class="perfil-section-title">Resumen de tu cuenta</h2>
                <p class="perfil-section-text">
                    Aquí puedes visualizar rápidamente la información principal registrada en tu perfil.
                </p>

                <div class="perfil-card-info">
                    <div class="perfil-info-item">
                        <span class="perfil-info-label">Nombre completo</span>
                        <div class="perfil-info-value">
                            @(String.IsNullOrWhiteSpace(Model.Nombre) ? "No registrado" : Model.Nombre)
                        </div>
                    </div>

                    <div class="perfil-info-item">
                        <span class="perfil-info-label">Correo electrónico</span>
                        <div class="perfil-info-value">
                            @(String.IsNullOrWhiteSpace(Model.Email) ? "No registrado" : Model.Email)
                        </div>
                    </div>

                    <div class="perfil-info-item">
                        <span class="perfil-info-label">Número de teléfono</span>
                        <div class="perfil-info-value">
                            @(String.IsNullOrWhiteSpace(Model.PhoneNumber) ? "No registrado" : Model.PhoneNumber)
                        </div>
                    </div>
                </div>

               
            </section>
        </div>

    </div>
</div>