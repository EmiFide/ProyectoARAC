@model AdoptameLiberia.Models.IndexViewModel
@{
    ViewBag.Title = "Mi perfil";
}

<div class="container mt-4">

    <h2 class="mb-4">Mi perfil</h2>

    @* Mensaje de estado *@
    @if (!string.IsNullOrEmpty(ViewBag.StatusMessage as string))
    {
        <div class="alert alert-success">
            @ViewBag.StatusMessage
        </div>
    }

<div class="row">

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <strong>Mi información</strong>

            <button class="btn btn-outline-primary btn-sm"
                    data-toggle="modal"
                    data-target="#editarPerfilModal">
                Editar perfil
            </button>
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Nombre</dt>
                <dd class="col-sm-8">@Model.Nombre</dd>

                <dt class="col-sm-4">Correo</dt>
                <dd class="col-sm-8">@Model.Email</dd>

                <dt class="col-sm-4">Teléfono</dt>
                <dd class="col-sm-8">
                    @(string.IsNullOrEmpty(Model.PhoneNumber) ? "No registrado" : Model.PhoneNumber)
                </dd>
            </dl>
        </div>
    </div>

    <div class="modal fade" id="editarPerfilModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Editar perfil</h5>
                    <button type="button" class="close" data-dismiss="modal"></button>
                </div>

                @using (Html.BeginForm("Index", "Manage", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="modal-body">

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Nombre)
                            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Email)
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.PhoneNumber)
                            @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger" })
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Guardar cambios
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- SEGURIDAD -->
    <div class="col-md-5">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <strong>Seguridad</strong>
            </div>
            <div class="card-body">

                <p>
                    <strong>Contraseña:</strong>
                    @if (Model.HasPassword)
                    {
                        <span class="text-success">Configurada</span>
                    }
                    else
                    {
                        <span class="text-danger">No configurada</span>
                    }
                </p>

                <p>
                    @if (Model.HasPassword)
                    {
                        @Html.ActionLink(
                            "Cambiar contraseña",
                            "ChangePassword",
                            "Manage",
                            null,
                            new { @class = "btn btn-outline-secondary btn-sm" })
                    }
                    else
                    {
                        @Html.ActionLink(
                            "Establecer contraseña",
                            "SetPassword",
                            "Manage",
                            null,
                            new { @class = "btn btn-outline-secondary btn-sm" })
                    }
                </p>

                <hr />
            </div>
        </div>
    </div>

</div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}