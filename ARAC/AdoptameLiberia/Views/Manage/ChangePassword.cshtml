@model AdoptameLiberia.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Cambiar contraseña";
}

<style>
    .cp-page {
        min-height: calc(100vh - 80px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px 16px;
        background: linear-gradient(180deg, #f4f7fb 0%, #edf2f7 100%);
    }

    .cp-box {
        width: 100%;
        max-width: 520px;
        background: #ffffff;
        border-radius: 24px;
        padding: 32px;
        border: 1px solid #dbe5ef;
        box-shadow: 0 12px 30px rgba(22, 52, 84, 0.06);
    }

    .cp-badge {
        display: inline-block;
        margin-bottom: 12px;
        padding: 6px 14px;
        border-radius: 999px;
        background: #eaf2ff;
        color: #2f6fc4;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .cp-title {
        margin: 0 0 10px;
        font-size: 30px;
        font-weight: 800;
        color: #163454;
    }

    .cp-text {
        margin-bottom: 22px;
        font-size: 14px;
        color: #5f7387;
        line-height: 1.7;
    }

    /* ❌ elimina la linea roja */
    .validation-summary-errors {
        display: none;
    }

    .field-validation-error {
        color: #d9534f;
        font-size: 13px;
        margin-top: 4px;
        display: block;
    }

    .cp-group {
        margin-bottom: 18px;
    }

    .cp-label {
        display: block;
        margin-bottom: 6px;
        font-size: 14px;
        font-weight: 700;
        color: #163454;
    }

    .cp-input {
        width: 100%;
        height: 46px;
        border-radius: 12px;
        border: 1px solid #d3dee9;
        padding: 0 14px;
        font-size: 14px;
        transition: .2s;
    }

        .cp-input:focus {
            outline: none;
            border-color: #4f8fd8;
            box-shadow: 0 0 0 3px rgba(79, 143, 216, 0.15);
        }

    .cp-links {
        text-align: right;
        margin-bottom: 20px;
    }

        .cp-links a {
            font-size: 13px;
            color: #2f6fc4;
            font-weight: 700;
            text-decoration: none;
        }

            .cp-links a:hover {
                text-decoration: underline;
            }

    .cp-actions {
        display: flex;
        justify-content: space-between;
        margin-top: 10px;
    }

    .cp-btn {
        min-width: 150px;
        height: 46px;
        border-radius: 12px;
        border: none;
        font-size: 14px;
        font-weight: 800;
        cursor: pointer;
        transition: .25s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        text-decoration: none !important;
    }

    .cp-btn-back {
        background: #f1f4f8;
        color: #163454 !important;
        border: 1px solid #d3dee9;
    }

        .cp-btn-back:hover {
            background: #e7edf3;
        }

    .cp-btn-primary {
        background: linear-gradient(135deg, #4f8fd8 0%, #2f74c9 100%);
        color: white;
        box-shadow: 0 10px 20px rgba(47, 116, 201, 0.2);
    }

        .cp-btn-primary:hover {
            transform: translateY(-2px);
        }
</style>

<div class="cp-page">
    <div class="cp-box">

        <span class="cp-badge">Seguridad</span>
        <h2 class="cp-title">Cambiar contraseña</h2>
        <p class="cp-text">
            Actualiza tu contraseña para mantener tu cuenta protegida. Completa los campos a continuación y guarda los cambios.
        </p>

        @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { @class = "" }))
        {
            @Html.AntiForgeryToken()

            <div class="cp-group">
                <label class="cp-label">Contraseña actual</label>
                @Html.PasswordFor(m => m.OldPassword, new { @class = "cp-input", placeholder = "Ingresa tu contraseña actual" })
                @Html.ValidationMessageFor(m => m.OldPassword)
            </div>

            <div class="cp-group">
                <label class="cp-label">Contraseña nueva</label>
                @Html.PasswordFor(m => m.NewPassword, new { @class = "cp-input", placeholder = "Ingresa tu nueva contraseña" })
                @Html.ValidationMessageFor(m => m.NewPassword)
            </div>

            <div class="cp-group">
                <label class="cp-label">Confirmar contraseña</label>
                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "cp-input", placeholder = "Confirma tu nueva contraseña" })
                @Html.ValidationMessageFor(m => m.ConfirmPassword)
            </div>

            <!-- 🔥 NUEVO: OLVIDO CONTRASEÑA -->
            <div class="cp-links">
                <a href="@Url.Action("ForgotPassword", "Account")">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>

            <div class="cp-actions">
                <a href="@Url.Action("Index", "Manage")" class="cp-btn cp-btn-back">
                    Volver
                </a>

                <button type="submit" class="cp-btn cp-btn-primary">
                    Guardar cambios
                </button>
            </div>
        }
    </div>
</div>