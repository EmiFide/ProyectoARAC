@model AdoptameLiberia.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Cambiar contraseña";
}

@section Styles {
    <link href="~/Content/estilos/Manage.css" rel="stylesheet" />
}

<div class="manage-page">
    <div class="container">
        <div class="manage-container">
            <div class="manage-card">
                <div class="manage-card-header">
                    <span class="manage-badge">Seguridad</span>
                    <h1>Cambiar contraseña</h1>
                    <p>
                        Actualiza tu contraseña para mantener tu cuenta protegida.
                        Completa los campos a continuación y guarda los cambios.
                    </p>
                </div>

                @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { role = "form", @class = "manage-form" }))
                {
                    @Html.AntiForgeryToken()

                    @Html.ValidationSummary("", new { @class = "manage-summary" })

                    <div class="manage-group">
                        @Html.LabelFor(m => m.OldPassword, new { @class = "manage-label" })
                        @Html.PasswordFor(m => m.OldPassword, new
                        {
                            @class = "manage-input",
                            placeholder = "Ingresa tu contraseña actual"
                        })
                        @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "manage-validation" })
                    </div>

                    <div class="manage-group">
                        @Html.LabelFor(m => m.NewPassword, new { @class = "manage-label" })
                        @Html.PasswordFor(m => m.NewPassword, new
                        {
                            @class = "manage-input",
                            placeholder = "Ingresa tu nueva contraseña"
                        })
                        @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "manage-validation" })
                    </div>

                    <div class="manage-group">
                        @Html.LabelFor(m => m.ConfirmPassword, new { @class = "manage-label" })
                        @Html.PasswordFor(m => m.ConfirmPassword, new
                        {
                            @class = "manage-input",
                            placeholder = "Confirma tu nueva contraseña"
                        })
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "manage-validation" })
                    </div>

                    <div class="manage-actions">
                        <a href="@Url.Action("Index", "Manage")" class="manage-btn-secondary">
                            Volver
                        </a>

                        <button type="submit" class="manage-btn-primary">
                            Guardar cambios
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}