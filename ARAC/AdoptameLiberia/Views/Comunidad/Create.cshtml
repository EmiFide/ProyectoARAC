@model AdoptameLiberia.Models.Comunidad.PublicacionComunidad

@{
    ViewBag.Title = "Nueva publicación";
}

<h2>Nueva publicación</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(m => m.Titulo)
        @Html.TextBoxFor(m => m.Titulo, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Contenido)
        @Html.TextAreaFor(m => m.Contenido, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-success">Publicar</button>
}