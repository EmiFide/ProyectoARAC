@model AdoptameLiberia.Models.Comunidad.PublicacionComunidad

@{
    ViewBag.Title = "Nueva publicación";
}

@section Styles{
    <link href="~/Content/estilos/Comunidad.css" rel="stylesheet" />
}

<div class="community-form-page">
    <section class="community-form-hero">
        <div class="community-form-hero-copy">
            <span class="community-chip">Nueva publicación</span>
            <h1>Comparte algo importante con la comunidad</h1>
            <p>
                Publica mensajes claros, cercanos y útiles para que otras personas del refugio
                puedan leer, comentar y participar.
            </p>
        </div>

        <div class="community-form-hero-visual">
            <img src="~/Content/img/Comunidad2.png" alt="Nueva publicación en comunidad" />
        </div>
    </section>

    <section class="community-form-card">
        <div class="community-section-head">
            <div>
                <span class="community-section-mini">Formulario</span>
                <h2>Crear publicación</h2>
                <p>Completa la información y publica tu mensaje.</p>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "community-validation-summary" })

            <div class="community-form-grid">
                <div class="community-field">
                    @Html.LabelFor(m => m.Titulo, "Título")
                    @Html.TextBoxFor(m => m.Titulo, new
                    {
                        @class = "community-input",
                        placeholder = "Escribe un título claro para tu publicación"
                    })
                    @Html.ValidationMessageFor(m => m.Titulo, "", new { @class = "community-field-error" })
                </div>

                <div class="community-field">
                    @Html.LabelFor(m => m.Contenido, "Contenido")
                    @Html.TextAreaFor(m => m.Contenido, new
                    {
                        @class = "community-input textarea",
                        placeholder = "Comparte aquí tu mensaje con la comunidad...",
                        rows = "8"
                    })
                    @Html.ValidationMessageFor(m => m.Contenido, "", new { @class = "community-field-error" })
                </div>
            </div>

            <div class="community-form-actions">
                <button type="submit" class="community-btn-primary">Publicar</button>
                @Html.ActionLink("Cancelar", "Index", null, new { @class = "community-btn-secondary" })
            </div>
        }
    </section>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}