@model IEnumerable<AdoptameLiberia.Models.Comunidad.PublicacionComunidad>

@{
    ViewBag.Title = "Comunidad";
}

@section styles{
    <link href="~/Content/estilos/Comunidad.css" rel="stylesheet" />
}

<div class="community-shell">
    <section class="community-hero">
        <div class="community-hero-copy">
            <span class="section-kicker">Comunidad ARAC</span>
            <h1>Un espacio para compartir historias, apoyo y experiencias</h1>
            <p>Consulta publicaciones recientes y participa con contenido útil para la comunidad del refugio.</p>

            <div class="community-hero-actions">
                @Html.ActionLink("Nueva publicación", "Create", null, new { @class = "community-btn-main" })
                @Html.ActionLink("Volver al inicio", "Index", "Home", null, new { @class = "community-btn-soft" })
            </div>
        </div>

        <div class="community-hero-visual">
            <img src="~/Content/img/PerroyGato.png" alt="Comunidad ARAC" />
        </div>
    </section>

    @if (TempData["MensajeComunidad"] != null)
    {
        <div class="community-alert">@TempData["MensajeComunidad"]</div>
    }

    <section class="community-layout">
        <div class="community-main-panel">
            <div class="community-panel-head">
                <h2>Publicaciones recientes</h2>
                <p>Mensajes y aportes compartidos dentro del refugio.</p>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="community-post-grid">
                    @foreach (var item in Model)
                    {
                        <article class="community-post-card">
                            <div class="community-post-top">
                                <span class="community-post-date">@item.Fecha.ToString("dd/MM/yyyy hh:mm tt")</span>
                            </div>

                            <h3>@item.Titulo</h3>

                            <p>
                                @(item.Contenido != null && item.Contenido.Length > 220
                                    ? item.Contenido.Substring(0, 220) + "..."
                                    : item.Contenido)
                            </p>

                            @Html.ActionLink("Ver publicación", "Details", new { id = item.ID_Publicacion }, new { @class = "community-btn-main mini" })
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="community-empty">Todavía no hay publicaciones en la comunidad.</div>
            }
        </div>

        <aside class="community-side-panel">
            <div class="community-side-card">
                <h4>Qué puedes compartir</h4>
                <p>Consejos, historias de adopción, experiencias, avisos y mensajes relacionados con el refugio.</p>
            </div>

            <div class="community-side-card">
                <h4>Participación activa</h4>
                <p>Entra a cada publicación para ver más detalle y continuar la conversación.</p>
            </div>

            <div class="community-side-card">
                <h4>Espacio organizado</h4>
                <p>Esta vista se mantiene funcional, pero ahora se integra con el resto del diseño del sitio.</p>
            </div>
        </aside>
    </section>
</div>