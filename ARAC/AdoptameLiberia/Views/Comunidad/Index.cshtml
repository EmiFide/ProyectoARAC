@model IEnumerable<AdoptameLiberia.Models.Comunidad.PublicacionComunidad>
@using System.Linq

@{
    ViewBag.Title = "Comunidad";
    int paginaActual = ViewBag.PaginaActual != null ? (int)ViewBag.PaginaActual : 1;
    int totalPaginas = ViewBag.TotalPaginas != null ? (int)ViewBag.TotalPaginas : 1;
    int totalPublicaciones = ViewBag.TotalPublicaciones != null ? (int)ViewBag.TotalPublicaciones : 0;
}

@section Styles{
    <link href="~/Content/estilos/Comunidad.css" rel="stylesheet" />
}

<div class="community-page">
    <section class="community-hero">
        <div class="community-hero-copy">
            <span class="community-chip">Comunidad ARAC</span>
            <h1>Historias, apoyo y publicaciones que conectan a nuestra comunidad</h1>
            <p>
                Comparte experiencias, consejos, mensajes útiles y noticias del refugio en un espacio
                más ordenado, visual y agradable para navegar.
            </p>

            <div class="community-hero-actions">
                @Html.ActionLink("Crear publicación", "Create", null, new { @class = "community-btn-primary" })
                @Html.ActionLink("Volver al inicio", "Index", "Home", null, new { @class = "community-btn-secondary" })
            </div>
        </div>

        <div class="community-hero-visual">
            <img src="~/Content/img/PerroyGato.png" alt="Comunidad ARAC" />
        </div>
    </section>

    @if (TempData["MensajeComunidad"] != null)
    {
        <div class="community-alert-success">
            @TempData["MensajeComunidad"]
        </div>
    }

    <section class="community-top-stats">
        <div class="community-stat-card">
            <span class="community-stat-label">Publicaciones</span>
            <strong>@totalPublicaciones</strong>
        </div>

        <div class="community-stat-card">
            <span class="community-stat-label">Página actual</span>
            <strong>@paginaActual</strong>
        </div>

        <div class="community-stat-card">
            <span class="community-stat-label">Total de páginas</span>
            <strong>@totalPaginas</strong>
        </div>
    </section>

    <section class="community-content-layout">
        <div class="community-feed-panel">
            <div class="community-section-head">
                <div>
                    <span class="community-section-mini">Panel de comunidad</span>
                    <h2>Publicaciones recientes</h2>
                    <p>Un espacio más visual y limpio, sin apariencia de CRUD.</p>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="community-posts-list">
                    @foreach (var item in Model)
                    {
                        <article class="community-post-card">
                            <div class="community-post-card-top">
                                <span class="community-date-badge">@item.Fecha.ToString("dd/MM/yyyy")</span>
                                <span class="community-time-badge">@item.Fecha.ToString("hh:mm tt")</span>
                            </div>

                            <div class="community-post-main">
                                <h3>@item.Titulo</h3>

                                <p>
                                    @(item.Contenido != null && item.Contenido.Length > 230
                                        ? item.Contenido.Substring(0, 230) + "..."
                                        : item.Contenido)
                                </p>
                            </div>

                            <div class="community-post-actions">
                                @Html.ActionLink("Ver publicación", "Details", new { id = item.ID_Publicacion }, new { @class = "community-btn-primary small" })
                            </div>
                        </article>
                    }
                </div>

                if (totalPaginas > 1)
                {
                    <div class="community-pagination-wrap">
                        <nav class="community-pagination">
                            @if (paginaActual > 1)
                            {
                                <a class="community-page-arrow"
                                   href="@Url.Action("Index", new { page = paginaActual - 1 })"
                                   aria-label="Página anterior">‹</a>
                            }
                            else
                            {
                                <span class="community-page-arrow disabled">‹</span>
                            }

                            @for (int i = 1; i <= totalPaginas; i++)
                            {
                                if (i == paginaActual)
                                {
                                    <span class="community-page-number active">@i</span>
                                }
                                else
                                {
                                    <a class="community-page-number"
                                       href="@Url.Action("Index", new { page = i })">@i</a>
                                }
                            }

                            @if (paginaActual < totalPaginas)
                            {
                                <a class="community-page-arrow"
                                   href="@Url.Action("Index", new { page = paginaActual + 1 })"
                                   aria-label="Página siguiente">›</a>
                            }
                            else
                            {
                                <span class="community-page-arrow disabled">›</span>
                            }
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="community-empty-state">
                    <div class="community-empty-icon">Comunidad</div>
                    <h3>Aún no hay publicaciones</h3>
                    <p>Empieza la conversación compartiendo la primera publicación de esta sección.</p>
                    @Html.ActionLink("Crear publicación", "Create", null, new { @class = "community-btn-primary" })
                </div>
            }
        </div>

        <aside class="community-side-panel">
            <div class="community-side-card highlight">
                <span class="community-side-mini">Espacio activo</span>
                <h4>¿Qué puedes publicar?</h4>
                <p>
                    Historias de adopción, consejos, avisos, experiencias con mascotas
                    y mensajes de apoyo para la comunidad.
                </p>
            </div>

            <div class="community-side-card">
                <h4>PROHIBIDO</h4>
                <p>
                   Subir publicaciones que puedan ofender a otros o se concideren ofensivas
                </p>
            </div>
        </aside>
    </section>
</div>