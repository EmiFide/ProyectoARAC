@model AdoptameLiberia.Models.Voluntariado.Voluntario

@{
    ViewBag.Title = "Ser voluntario";
}

@section styles{
    <link href="~/Content/estilos/Voluntarios.css" rel="stylesheet" />
}

<div class="vol-shell">
    <div class="vol-hero">
        <div>
            <h1>Ser voluntario</h1>
            <p>
                Gracias por querer apoyar a ARAC. Completa este formulario con tus datos,
                disponibilidad y habilidades para enviarnos tu solicitud de voluntariado.
            </p>
        </div>
        <div class="vol-hero-image">
            <img src="~/Content/img/GatoPerro.png" alt="Ser voluntario" />
        </div>
    </div>

    <div class="vol-form-card">
        <div class="vol-panel-title">Formulario de solicitud</div>
        <div class="vol-panel-subtitle">
            Llena la información correctamente para que el equipo pueda revisar tu solicitud.
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert-vol">@TempData["Mensaje"]</div>
        }

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

            <div class="vol-form-grid">
                <div class="vol-group">
                    @Html.LabelFor(m => m.Nombre)
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(m => m.Apellido1)
                    @Html.TextBoxFor(m => m.Apellido1, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Apellido1, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(m => m.Apellido2)
                    @Html.TextBoxFor(m => m.Apellido2, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Apellido2, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(m => m.Correo)
                    @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", type = "email" })
                    @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(m => m.Telefono)
                    @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(m => m.Disponibilidad)
                    @Html.TextAreaFor(m => m.Disponibilidad, new { @class = "form-control", rows = 4, placeholder = "Ejemplo: fines de semana, tardes, apoyo en eventos..." })
                    @Html.ValidationMessageFor(m => m.Disponibilidad, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(m => m.Habilidades)
                    @Html.TextAreaFor(m => m.Habilidades, new { @class = "form-control", rows = 4, placeholder = "Ejemplo: limpieza, atención, traslado, apoyo con animales..." })
                    @Html.ValidationMessageFor(m => m.Habilidades, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="vol-form-actions">
                <button type="submit" class="vol-btn">Enviar solicitud</button>
                @Html.ActionLink("Volver al inicio", "Index", "Home", null, new { @class = "vol-btn-outline" })
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}