@model AdoptameLiberia.Models.Voluntariado.Voluntario
@using System.Linq
@using System.Collections.Generic
@using AdoptameLiberia.Models.Voluntariado

@{
    ViewBag.Title = "Ser voluntario";

    var tareasAsignadas = ViewBag.TareasAsignadas as List<ParticipacionVoluntario> ?? new List<ParticipacionVoluntario>();
    var totalTareasAsignadas = ViewBag.TotalTareasAsignadas != null ? (int)ViewBag.TotalTareasAsignadas : 0;
    var totalTareasActivas = ViewBag.TotalTareasActivas != null ? (int)ViewBag.TotalTareasActivas : 0;
}

@section styles{
    <link href="~/Content/estilos/Voluntarios.css" rel="stylesheet" />
}

@functions{
    public bool EstaMarcado(string observaciones)
    {
        return !string.IsNullOrWhiteSpace(observaciones) &&
               (observaciones.Contains("[ASISTIO]") || observaciones.Contains("[NO_ASISTIO]"));
    }

    public bool NoAsistio(string observaciones)
    {
        return !string.IsNullOrWhiteSpace(observaciones) &&
               observaciones.Contains("[NO_ASISTIO]");
    }

    public string LimpiarObservaciones(string observaciones)
    {
        if (string.IsNullOrWhiteSpace(observaciones))
        {
            return "";
        }

        return observaciones
            .Replace("[ASISTIO]", "")
            .Replace("[NO_ASISTIO]", "")
            .Replace("Pendiente de asistencia", "")
            .Trim();
    }
}

<div class="vol-shell">
    <div class="vol-hero">
        <div class="vol-hero-main">
            <span class="vol-hero-kicker">ARAC · Voluntariado</span>
            <h1>Ser voluntario</h1>
            <p>
                Sumarte como voluntario significa apoyar actividades, jornadas, rescates y tareas
                que ayudan directamente al bienestar animal. Completa el formulario con tus datos,
                tu disponibilidad y tus habilidades para que el equipo pueda revisar tu solicitud.
            </p>

            <div class="vol-hero-actions">
                <img src="~/Content/img/Voluntariohero2.jpg" alt="Voluntariado ARAC" />
            </div>
        </div>

        <div class="vol-hero-side">
            <div class="vol-hero-image">
                <img src="~/Content/img/VoluntariadoHero.png" alt="Voluntariado ARAC" />
            </div>

            <div>
                <h2 class="vol-side-card-title">¿Cómo puedes ayudar?</h2>
                <p class="vol-side-card-text">
                    Puedes participar en eventos, apoyo logístico, atención al público, acompañamiento
                    en campañas, traslados, limpieza y bienestar de animales.
                </p>
            </div>

            <ul class="vol-side-list">
                <li>Horarios flexibles según disponibilidad</li>
                <li>Apoyo en tareas operativas y comunitarias</li>
                <li>Participación en campañas y actividades</li>
            </ul>
        </div>
    </div>

    <div class="vol-dashboard">
        <section class="vol-section">
            <div class="vol-section-header">
                <div>
                    <h2 class="vol-section-title">Proceso para ser voluntario</h2>
                    <p class="vol-section-subtitle">
                        Completa tu información para que el equipo pueda revisarla y asignarte tareas cuando corresponda.
                    </p>
                </div>
            </div>

            <div class="vol-steps-grid">
                <div class="vol-step-card">
                    <div class="vol-step-number">1</div>
                    <h3>Completa el formulario</h3>
                    <p>
                        Registra tus datos personales, disponibilidad y habilidades.
                    </p>
                </div>

                <div class="vol-step-card">
                    <div class="vol-step-number">2</div>
                    <h3>Revisión del equipo</h3>
                    <p>
                        El administrador revisará tu información para validar tu solicitud.
                    </p>
                </div>

                <div class="vol-step-card">
                    <div class="vol-step-number">3</div>
                    <h3>Asignación de tareas</h3>
                    <p>
                        Cuando haya una oportunidad adecuada, se te contactará por correo o teléfono.
                    </p>
                </div>

                <div class="vol-step-card">
                    <div class="vol-step-number">4</div>
                    <h3>Te integras al voluntariado</h3>
                    <p>
                        Una vez aprobado, podrás participar en tareas y actividades de apoyo de ARAC.
                    </p>
                </div>
            </div>
        </section>

        <section class="vol-section">
            <div class="vol-section-header">
                <div>
                    <h2 class="vol-section-title">Perfil ideal</h2>
                    <p class="vol-section-subtitle">
                        No ocupas experiencia profesional; lo importante es tu disposición.
                    </p>
                </div>
            </div>

            <div class="vol-info-card" style="margin-bottom:16px;">
                <h3>Recomendado para personas que:</h3>
                <div class="vol-chip-list">
                    <span class="vol-chip">Tienen empatía</span>
                    <span class="vol-chip">Pueden apoyar en eventos</span>
                    <span class="vol-chip">Quieren ayudar a animales</span>
                    <span class="vol-chip">Tienen buena actitud</span>
                    <span class="vol-chip">Saben trabajar en equipo</span>
                </div>
            </div>

            <div class="vol-soft-card">
                <h3>Importante</h3>
                <p>
                    Procura escribir bien tu teléfono, disponibilidad y habilidades. Esa información es la que
                    permitirá al equipo contactarte y ubicarte en una tarea adecuada.
                </p>
            </div>
        </section>
    </div>

    <section class="vol-form-card" id="formSolicitud">
        <div class="vol-section-header">
            <div>
                <h2 class="vol-section-title">Formulario de solicitud</h2>
                <p class="vol-section-subtitle">
                    Completa o actualiza tus datos de voluntariado.
                </p>
            </div>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="vol-alert-success">@TempData["Mensaje"]</div>
        }

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })
            @Html.HiddenFor(m => m.ID_Voluntario)
            @Html.HiddenFor(m => m.ID_Usuario)
            @Html.HiddenFor(m => m.Estado)
            @Html.HiddenFor(m => m.Fecha_Registro)

            <div class="vol-form-grid">
                <div class="vol-group">
                    @Html.LabelFor(m => m.Nombre)
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Ingresa tu nombre" })
                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(m => m.Apellido1)
                    @Html.TextBoxFor(m => m.Apellido1, new { @class = "form-control", placeholder = "Primer apellido" })
                    @Html.ValidationMessageFor(m => m.Apellido1, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(m => m.Apellido2)
                    @Html.TextBoxFor(m => m.Apellido2, new { @class = "form-control", placeholder = "Segundo apellido" })
                    @Html.ValidationMessageFor(m => m.Apellido2, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group">
                    @Html.LabelFor(m => m.Correo)
                    @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", type = "email", placeholder = "correo@ejemplo.com", @readonly = "readonly" })
                    <div class="vol-form-hint">Este correo queda ligado a tu cuenta y se usa para mostrar tus tareas.</div>
                    @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(m => m.Telefono)
                    @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", placeholder = "Número de contacto" })
                    @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(m => m.Disponibilidad)
                    @Html.TextAreaFor(m => m.Disponibilidad, new { @class = "form-control", rows = 4, placeholder = "Ejemplo: fines de semana, tardes, apoyo en campañas o eventos..." })
                    <div class="vol-form-hint">Detalla los días, horarios o tipo de disponibilidad que tienes.</div>
                    @Html.ValidationMessageFor(m => m.Disponibilidad, "", new { @class = "text-danger" })
                </div>

                <div class="vol-group full">
                    @Html.LabelFor(m => m.Habilidades)
                    @Html.TextAreaFor(m => m.Habilidades, new { @class = "form-control", rows = 4, placeholder = "Ejemplo: atención al público, limpieza, apoyo logístico, transporte, cuidado animal..." })
                    <div class="vol-form-hint">Puedes indicar experiencia previa o tareas en las que te gustaría ayudar.</div>
                    @Html.ValidationMessageFor(m => m.Habilidades, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="vol-form-actions">
                <button type="submit" class="vol-btn">Guardar información</button>
                @Html.ActionLink("Volver al inicio", "Index", "Home", null, new { @class = "vol-btn-outline" })
            </div>
        }
    </section>

    <section class="vol-section vol-task-board">
        <div class="vol-section-header">
            <div>
                <h2 class="vol-section-title">Mis tareas asignadas</h2>
                <p class="vol-section-subtitle">
                    Aquí te aparecen las tareas que el administrador te haya asignado.
                </p>
            </div>

            @if (tareasAsignadas.Any())
            {
                <span class="vol-badge vol-badge-pending">@tareasAsignadas.Count tarea(s)</span>
            }
        </div>

        @if (!tareasAsignadas.Any())
        {
            <div class="vol-empty">
                <strong>Aún no tienes tareas asignadas.</strong>
                <p>
                    Cuando un administrador te asigne una tarea, te aparecerá aquí con su fecha,
                    hora, lugar y descripción.
                </p>
            </div>
        }
        else
        {
            <div class="vol-task-list">
                @foreach (var item in tareasAsignadas)
                {
                    var tarea = item.Tarea;
                    var estadoTexto = (tarea != null && tarea.Estado) ? "Asignada" : "Cerrada";
                    var badgeClass = (tarea != null && tarea.Estado) ? "vol-badge-pending" : "vol-badge-inactive";

                    bool asistenciaMarcada = EstaMarcado(item.Observaciones);
                    bool noAsistio = NoAsistio(item.Observaciones);
                    string observacionesLimpias = LimpiarObservaciones(item.Observaciones);

                    <article class="vol-task-card">
                        <div class="vol-task-card-top">
                            <div>
                                <h3>@(tarea != null ? tarea.Titulo : "Tarea sin título")</h3>
                                <p class="vol-task-card-subtitle">
                                    @if (tarea != null)
                                    {
                                        <text>Revisa los detalles de la actividad asignada a tu perfil.</text>
                                    }
                                </p>
                            </div>

                            @if (asistenciaMarcada && item.Asistio)
                            {
                                <span class="vol-badge vol-badge-active">Asistió</span>
                            }
                            else if (asistenciaMarcada && noAsistio)
                            {
                                <span class="vol-badge vol-badge-inactive">No asistió</span>
                            }
                            else
                            {
                                <span class="vol-badge @badgeClass">@estadoTexto</span>
                            }
                        </div>

                        <div class="vol-task-meta">
                            <div class="vol-task-meta-item">
                                <strong>Fecha</strong>
                                <span>@(tarea != null ? tarea.Fecha.ToString("dd/MM/yyyy") : "-")</span>
                            </div>

                            <div class="vol-task-meta-item">
                                <strong>Hora</strong>
                                <span>@(tarea != null && tarea.Hora.HasValue ? tarea.Hora.Value.ToString(@"hh\:mm") : "Por definir")</span>
                            </div>

                            <div class="vol-task-meta-item">
                                <strong>Lugar</strong>
                                <span>@(!string.IsNullOrWhiteSpace(tarea != null ? tarea.Lugar : null) ? tarea.Lugar : "Por definir")</span>
                            </div>
                        </div>

                        <div class="vol-task-body">
                            <div class="vol-task-block">
                                <strong>Descripción</strong>
                                <p>@(tarea != null ? tarea.Descripcion : "Sin descripción.")</p>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(observacionesLimpias))
                            {
                                <div class="vol-task-block">
                                    <strong>Observaciones</strong>
                                    <p>@observacionesLimpias</p>
                                </div>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}