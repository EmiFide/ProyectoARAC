@model AdoptameLiberia.Models.Voluntariado.Voluntario

@{
    ViewBag.Title = "Solicitud de voluntariado";
}

<h2>Solicitud de voluntariado</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(m => m.Nombre)
        @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Apellido1)
        @Html.TextBoxFor(m => m.Apellido1, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Apellido2)
        @Html.TextBoxFor(m => m.Apellido2, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Correo)
        @Html.TextBoxFor(m => m.Correo, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Telefono)
        @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Disponibilidad)
        @Html.TextAreaFor(m => m.Disponibilidad, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Habilidades)
        @Html.TextAreaFor(m => m.Habilidades, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-primary">Enviar solicitud</button>
}